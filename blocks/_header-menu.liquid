{%- doc -%}
  Modern hierarchical header menu with optimized performance and structure.
  
  @param {string} [variant] - Menu variant: 'mobile', 'navigation_bar', or default desktop menu
  @param {boolean} [transparent] - Transparent background mode
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign animation_speed = 200
  assign menu_items = block_settings.menu.links
%}

{% case variant %}
  {% when 'mobile' %}
    {%- render 'header-menu-mobile', 
      block: block,
      menu_items: menu_items
    -%}

  {% when 'navigation_bar' %}
    {%- render 'header-menu-navigation-bar',
      block: block,
      menu_items: menu_items,
      transparent: transparent
    -%}

  {% else %}
    {%- render 'header-menu-desktop',
      block: block,
      menu_items: menu_items,
      animation_speed: animation_speed
    -%}
{% endcase %}

{% stylesheet %}
  /* ========================================
     MODERN HIERARCHICAL MENU SYSTEM
     ======================================== */

  /* ROOT VARIABLES */
  :root {
    --menu-transition-speed: 200ms;
    --menu-transition-easing: cubic-bezier(0.4, 0, 0.2, 1);
    --menu-gap-mobile: 15px;
    --menu-gap-tablet: var(--gap-xl);
    --menu-gap-desktop: var(--gap-xl);
    --menu-z-index: var(--layer-header-menu);
    --menu-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    --menu-border-radius: 8px;
  }

  /* ========================================
     LEVEL 1: MOBILE MENU
     ======================================== */

  .menu-mobile {
    display: grid;
    width: 100%;
  }

  .menu-mobile__container {
    position: relative;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .menu-mobile__container::-webkit-scrollbar {
    display: none;
  }

  .menu-mobile__list {
    display: flex;
    gap: var(--menu-gap-mobile);
    width: max-content;
    margin: 0 auto;
    padding: var(--padding-sm) var(--menu-gap-mobile);
    list-style: none;
  }

  .menu-mobile__item {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .menu-mobile__link {
    display: inline-flex;
    align-items: center;
    min-height: var(--minimum-touch-target);
    padding: var(--padding-2xs) var(--padding-xs);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: var(--font-size--base);
    font-weight: 500;
    transition: color var(--menu-transition-speed) var(--menu-transition-easing);
  }

  .menu-mobile__link:hover,
  .menu-mobile__link[aria-current="page"] {
    color: var(--color-accent);
  }

  /* Scroll gradient indicators */
  .menu-mobile__container::before,
  .menu-mobile__container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 20px;
    pointer-events: none;
    z-index: 1;
  }

  .menu-mobile__container::before {
    left: 0;
    background: linear-gradient(to right, var(--color-background), transparent);
  }

  .menu-mobile__container::after {
    right: 0;
    background: linear-gradient(to left, var(--color-background), transparent);
  }

  /* ========================================
     LEVEL 2: DESKTOP MENU
     ======================================== */

  .menu-desktop {
    width: 100%;
    display: none;
  }

  @media screen and (min-width: 750px) {
    .menu-desktop {
      display: block;
    }
  }

  .menu-desktop__inner {
    display: flex;
    align-items: center;
    justify-content: var(--grid-area-alignment, center);
    gap: var(--menu-gap-desktop);
  }

  /* Top Level Items */
  .menu-desktop__item {
    position: relative;
    list-style: none;
  }

  .menu-desktop__item[aria-hidden="true"] {
    visibility: hidden;
    pointer-events: none;
  }

  .menu-desktop__link {
    display: flex;
    align-items: center;
    min-height: var(--minimum-touch-target);
    padding: var(--padding-xs) var(--padding-sm);
    font-family: var(--menu-top-level-font-family);
    font-size: var(--menu-top-level-font-size);
    font-weight: var(--menu-top-level-font-weight);
    line-height: var(--menu-top-level-font-line-height);
    text-transform: var(--menu-top-level-font-case);
    color: var(--menu-top-level-font-color);
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--menu-transition-speed) var(--menu-transition-easing);
    border-radius: var(--menu-border-radius);
  }

  .menu-desktop__link:hover,
  .menu-desktop__link:focus-visible {
    color: var(--menu-top-level-font-color);
    background-color: rgba(var(--color-foreground-rgb), 0.05);
  }

  .menu-desktop__link--active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Submenu Indicator */
  .menu-desktop__link--has-submenu::after {
    content: '';
    display: inline-block;
    width: 0;
    height: 0;
    margin-left: 8px;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    transition: transform var(--menu-transition-speed) var(--menu-transition-easing);
  }

  .menu-desktop__link--has-submenu[aria-expanded="true"]::after {
    transform: rotate(180deg);
  }

  /* Interactive States */
  .menu-desktop:has(.menu-desktop__item:hover) .menu-desktop__link:not(:hover),
  .menu-desktop:has(.menu-desktop__item:focus-within) .menu-desktop__link:not(:focus-within) {
    opacity: 0.5;
  }

  /* ========================================
     LEVEL 3: MEGA MENU / SUBMENU
     ======================================== */

  .menu-submenu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-10px);
    transition: 
      opacity var(--menu-transition-speed) var(--menu-transition-easing),
      transform var(--menu-transition-speed) var(--menu-transition-easing),
      visibility 0s var(--menu-transition-speed);
    z-index: var(--menu-z-index);
    background-color: var(--color-background);
    box-shadow: var(--menu-shadow);
    border-radius: var(--menu-border-radius);
    margin-top: var(--padding-sm);
  }

  .menu-desktop__item:hover > .menu-submenu,
  .menu-desktop__item:focus-within > .menu-submenu,
  .menu-submenu:hover {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
  }

  .menu-submenu__inner {
    padding: var(--padding-xl);
    max-height: 80vh;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  /* ========================================
     LEVEL 4: MEGA MENU GRID
     ======================================== */

  .mega-menu {
    display: grid;
    grid-template-columns: repeat(var(--menu-columns-tablet, 2), 1fr);
    gap: var(--padding-xl);
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .mega-menu {
      grid-template-columns: repeat(var(--menu-columns-desktop, 4), 1fr);
    }
  }

  .mega-menu__column {
    display: flex;
    flex-direction: column;
    gap: var(--padding-sm);
  }

  .mega-menu__column--span-2 {
    grid-column: span 2;
  }

  .mega-menu__column--span-3 {
    grid-column: span 3;
  }

  .mega-menu__column--span-4 {
    grid-column: span 4;
  }

  /* Column Header */
  .mega-menu__header {
    font-family: var(--menu-parent-font-family);
    font-size: var(--menu-parent-font-size);
    font-weight: var(--menu-parent-font-weight);
    line-height: var(--menu-parent-font-line-height);
    text-transform: var(--menu-parent-font-case);
    color: var(--menu-parent-font-color);
    margin-bottom: var(--padding-xs);
  }

  /* Column Links */
  .mega-menu__list {
    display: flex;
    flex-direction: column;
    gap: var(--padding-2xs);
    list-style: none;
  }

  .mega-menu__link {
    font-family: var(--menu-child-font-family);
    font-size: var(--menu-child-font-size);
    font-weight: var(--menu-child-font-weight);
    line-height: var(--menu-child-font-line-height);
    text-transform: var(--menu-child-font-case);
    color: var(--menu-child-font-color);
    text-decoration: none;
    padding: var(--padding-2xs) var(--padding-xs);
    border-radius: 4px;
    transition: all var(--menu-transition-speed) var(--menu-transition-easing);
    display: block;
  }

  .mega-menu__link:hover {
    color: var(--menu-child-active-font-color);
    background-color: rgba(var(--color-foreground-rgb), 0.05);
    transform: translateX(4px);
  }

  /* ========================================
     LEVEL 5: FEATURED CONTENT
     ======================================== */

  .mega-menu__featured {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--padding-md);
  }

  .mega-menu__featured-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--menu-border-radius);
  }

  .mega-menu__featured-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 300ms var(--menu-transition-easing);
  }

  .mega-menu__featured-item:hover .mega-menu__featured-image {
    transform: scale(1.05);
  }

  .mega-menu__featured-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--padding-md);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: white;
    font-size: var(--font-size--base);
    font-weight: 600;
  }

  /* ========================================
     ACCESSIBILITY & UTILITIES
     ======================================== */

  .menu-desktop__link:focus-visible,
  .mega-menu__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-desktop__link,
    .mega-menu__link,
    .menu-submenu {
      transition: none;
    }
  }

  /* Skip to content for keyboard navigation */
  .skip-to-content {
    position: absolute;
    left: -9999px;
    z-index: 9999;
    padding: var(--padding-sm);
    background-color: var(--color-background);
    color: var(--color-foreground);
    text-decoration: none;
  }

  .skip-to-content:focus {
    left: 50%;
    transform: translateX(-50%);
    top: var(--padding-sm);
  }

  /* ========================================
     RESPONSIVE ADJUSTMENTS
     ======================================== */

  @media screen and (max-width: 749px) {
    .menu-desktop {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .menu-mobile {
      display: none;
    }
  }

  @media screen and (min-width: 990px) {
    .mega-menu__featured {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
  }

  /* ========================================
     PERFORMANCE OPTIMIZATIONS
     ======================================== */

  /* GPU acceleration for animations */
  .menu-submenu,
  .mega-menu__link,
  .mega-menu__featured-image {
    will-change: transform, opacity;
  }

  /* Contain layout shifts */
  .menu-desktop,
  .menu-mobile {
    contain: layout style;
  }

  .menu-submenu {
    contain: layout style paint;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.menu",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:settings.menu",
      "default": "main-menu"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Desktop Menu"
    },
    {
      "type": "range",
      "id": "menu_columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "menu_columns_tablet",
      "label": "Columns (Tablet)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "type_font_primary_size",
      "label": "Top Level Size",
      "options": [
        { "value": "0.75rem", "label": "12px" },
        { "value": "0.875rem", "label": "14px" },
        { "value": "1rem", "label": "16px" },
        { "value": "1.125rem", "label": "18px" }
      ],
      "default": "1rem"
    },
    {
      "type": "select",
      "id": "type_font_primary_link",
      "label": "Font Family",
      "options": [
        { "value": "body", "label": "Body" },
        { "value": "subheading", "label": "Subheading" },
        { "value": "heading", "label": "Heading" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "type_case_primary_link",
      "label": "Text Case",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Featured Content"
    },
    {
      "type": "select",
      "id": "menu_style",
      "label": "Featured Content Type",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "collection_images", "label": "Collection Images" },
        { "value": "featured_products", "label": "Featured Products" },
        { "value": "featured_collections", "label": "Featured Collections" }
      ],
      "default": "collection_images"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Mobile Menu"
    },
    {
      "type": "checkbox",
      "id": "navigation_bar",
      "label": "Show Mobile Navigation Bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "drawer_accordion",
      "label": "Accordion Style",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "drawer_dividers",
      "label": "Show Dividers",
      "default": false
    }
  ]
}
{% endschema %}
