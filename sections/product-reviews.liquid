<div class="product-reviews page-width" id="reviews">
  <div class="section-header">
    <h2 class="reviews-title">Customer Reviews</h2>
    <div class="reviews-summary">
      <div class="stars">
        {% for i in (1..5) %}
          <svg class="star filled" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
      </div>
      <span class="average-rating">5.0 based on 0 reviews</span>
    </div>
  </div>

  <div class="reviews-container">
    <div class="reviews-list">
      <p class="no-reviews">No reviews yet. Be the first to review this product!</p>
    </div>

    <div class="review-form-wrapper">
      <h3 class="form-title">Write a Review</h3>
      <form class="review-form" onsubmit="return false;">
        <div class="form-group">
          <label>Rating</label>
          <div class="star-rating-input">
            {% for i in (1..5) reversed %}
              <input type="radio" id="star{{ i }}" name="rating" value="{{ i }}">
              <label for="star{{ i }}"></label>
            {% endfor %}
          </div>
        </div>
        <div class="form-group">
          <label for="review-name">Name</label>
          <input type="text" id="review-name" placeholder="John Doe" required>
        </div>
        <div class="form-group">
          <label for="review-comment">Comment</label>
          <textarea id="review-comment" rows="4" placeholder="Your feedback matters..." required></textarea>
        </div>
        <button type="submit" class="submit-review-btn">Submit Review</button>
      </form>
    </div>
  </div>
</div>

<style>
.product-reviews {
  padding: 60px 0;
  border-top: 1px solid #eee;
}
.section-header {
  margin-bottom: 40px;
  text-align: center;
}
.reviews-title {
  font-size: 32px;
  color: #1f3d2b;
  margin-bottom: 12px;
}
.reviews-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}
.stars {
  display: flex;
  gap: 2px;
}
.star {
  width: 18px;
  height: 18px;
  fill: #e5e5e5;
}
.star.filled {
  fill: #ffb800;
}
.reviews-container {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 60px;
}
.no-reviews {
  color: #666;
  font-style: italic;
}
.review-form-wrapper {
  background: #fdfdfd;
  padding: 30px;
  border-radius: 12px;
  border: 1px solid #eee;
}
.form-title {
  font-size: 20px;
  margin-bottom: 20px;
  color: #1f3d2b;
}
.form-group {
  margin-bottom: 20px;
}
.form-group label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}
.form-group input, .form-group textarea {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-family: inherit;
}
.star-rating-input {
  display: flex;
  flex-direction: row-reverse;
  justify-content: flex-end;
  gap: 5px;
}
.star-rating-input input {
  display: none;
}
.star-rating-input label {
  cursor: pointer;
  width: 24px;
  height: 24px;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23e5e5e5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>');
  background-size: contain;
  background-repeat: no-repeat;
}
.star-rating-input input:checked ~ label,
.star-rating-input label:hover,
.star-rating-input label:hover ~ label {
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23ffb800"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>');
}
.submit-review-btn {
  width: 100%;
  padding: 14px;
  background: #1f3d2b;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
}
.submit-review-btn:hover {
  opacity: 0.9;
}
@media (max-width: 990px) {
  .reviews-container {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Product Reviews",
  "settings": [],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ]
}
{% endschema %}
