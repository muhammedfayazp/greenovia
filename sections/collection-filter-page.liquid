{% comment %}
  Collection Filter Page
  Cart + icon → quantity selector
  Fully self-contained
{% endcomment %}

<section class="collection-page">

  <h1>{{ collection.title }}</h1>

  <div class="collection-grid">

    {% for product in collection.products %}
      {% assign variant = product.selected_or_first_available_variant %}
      {% assign cart_qty = 0 %}

      {% for item in cart.items %}
        {% if item.variant_id == variant.id %}
          {% assign cart_qty = item.quantity %}
        {% endif %}
      {% endfor %}

      <div class="product-card">

        <a href="{{ product.url }}">
          <img
            src="{{ product.featured_image | img_url: '400x' }}"
            alt="{{ product.title }}"
          >
        </a>

        <div class="product-title">{{ product.title }}</div>
        <div class="product-price">{{ variant.price | money }}</div>

        <!-- ACTION AREA -->
        <div
          class="product-actions {% if cart_qty > 0 %}is-active{% endif %}"
          data-variant-id="{{ variant.id }}"
          data-cart-quantity="{{ cart_qty }}"
        >

          <!-- CART + -->
          <button type="button" class="cart-btn">
            🛒
            <span class="cart-plus">+</span>
          </button>

          <!-- QTY SELECTOR -->
          <div class="qty-box">
            <button type="button" class="qty-btn qty-minus">
              <span class="icon-minus">−</span>
              <span class="icon-trash">🗑</span>
            </button>

            <input
              type="text"
              class="qty-value"
              readonly
              value="{% if cart_qty > 0 %}{{ cart_qty }}{% else %}1{% endif %}"
            >

            <button type="button" class="qty-btn qty-plus">+</button>
          </div>

        </div>

      </div>
    {% endfor %}

  </div>
</section>

<style>
/* ===== GRID ===== */
.collection-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
}

.product-card {
  position: relative;
  border: 1px solid #eee;
  border-radius: 12px;
  padding: 12px;
}

.product-card img {
  width: 100%;
  border-radius: 10px;
}

.product-title {
  margin-top: 8px;
  font-size: 14px;
}

.product-price {
  font-weight: 700;
}

/* ===== ACTIONS ===== */
.product-actions {
  position: absolute;
  bottom: 12px;
  right: 12px;
  height: 40px;
}

/* CART BUTTON */
.cart-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1f3d2b;
  color: #fff;
  border: none;
  position: relative;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(0,0,0,.15);
}

.cart-plus {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #fff;
  color: #1f3d2b;
  font-size: 12px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* QTY BOX */
.qty-box {
  position: absolute;
  right: 0;
  top: 0;
  height: 40px;
  min-width: 110px;
  background: #1f3d2b;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 6px;

  opacity: 0;
  pointer-events: none;
  transform: scale(.85);
  transition: .25s ease;
}

.product-actions.is-active .qty-box {
  opacity: 1;
  pointer-events: auto;
  transform: scale(1);
}

.product-actions.is-active .cart-btn {
  opacity: 0;
  pointer-events: none;
}

/* QTY BUTTONS */
.qty-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,.2);
  color: #fff;
  cursor: pointer;
}

.qty-value {
  width: 26px;
  text-align: center;
  border: none;
  background: transparent;
  color: #fff;
  font-weight: 700;
}

/* TRASH LOGIC */
.icon-trash {
  display: none;
}

.product-actions[data-cart-quantity="1"] .icon-minus {
  display: none;
}

.product-actions[data-cart-quantity="1"] .icon-trash {
  display: inline;
}
</style>

<script>
document.addEventListener('click', async function (e) {

  const actions = e.target.closest('.product-actions');
  if (!actions) return;

  const variantId = actions.dataset.variantId;
  const qtyInput = actions.querySelector('.qty-value');
  let qty = parseInt(qtyInput.value || 0);

  /* CART CLICK */
  if (e.target.closest('.cart-btn')) {
    qty = 1;
    await updateCart(variantId, qty);
    actions.classList.add('is-active');
  }

  /* PLUS */
  if (e.target.closest('.qty-plus')) {
    qty++;
    await updateCart(variantId, qty);
  }

  /* MINUS / TRASH */
  if (e.target.closest('.qty-minus')) {
    qty--;
    if (qty <= 0) {
      qty = 0;
      await updateCart(variantId, 0);
      actions.classList.remove('is-active');
    } else {
      await updateCart(variantId, qty);
    }
  }

  actions.dataset.cartQuantity = qty;
  qtyInput.value = qty || 1;
});

/* AJAX CART UPDATE */
async function updateCart(variantId, quantity) {
  await fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      id: variantId,
      quantity: quantity
    })
  });
}
</script>
