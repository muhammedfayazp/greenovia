<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-add-to-cart.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'product-form.js' | asset_url }}" type="module" fetchpriority="low"></script>

<div class="collection-filter-page">
  
  {%- comment -%} Breadcrumb {%- endcomment -%}
  <div class="page-width breadcrumb-section">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      
      {% assign menu_handle = section.settings.category_menu %}
      {% assign menu_links = linklists[menu_handle].links %}
      
      {% if menu_handle != blank %}
        {% assign found_breadcrumb = false %}
        {% for link in menu_links %}
          {% comment %} Ancestor check {% endcomment %}
          {% assign is_ancestor = false %}
          {% if link.active or link.child_active %}{% assign is_ancestor = true %}{% endif %}
          {% if is_ancestor == false and link.links != blank %}
             {% for child in link.links %}
               {% if child.active or child.child_active %}{% assign is_ancestor = true %}{% endif %}
               {% for grand in child.links %}
                 {% if grand.active %}{% assign is_ancestor = true %}{% endif %}
               {% endfor %}
             {% endfor %}
          {% endif %}

          {% if is_ancestor %}
            {% comment %} Show all ancestor links except utility pages {% endcomment %}
            {% assign link_title_dc = link.title | downcase | strip %}
            {% if link_title_dc != 'home' %}
                <span>/</span>
                <a href="{{ link.url }}">{{ link.title }}</a>
                {% assign found_breadcrumb = true %}
            {% endif %}
            
            {% for child_link in link.links %}
               {% assign is_child_ancestor = false %}
               {% if child_link.active or child_link.child_active %}{% assign is_child_ancestor = true %}{% endif %}
               {% if is_child_ancestor == false and child_link.links != blank %}
                 {% for grand in child_link.links %}
                   {% if grand.active %}{% assign is_child_ancestor = true %}{% endif %}
                 {% endfor %}
               {% endif %}

              {% if is_child_ancestor %}
                <span>/</span>
                {% if child_link.active and child_link.child_active == false %}
                    <span>{{ child_link.title }}</span>
                {% else %}
                    <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                {% endif %}
                {% assign found_breadcrumb = true %}
                
                {% for grandchild_link in child_link.links %}
                  {% if grandchild_link.active %}
                    <span>/</span>
                    <span>{{ grandchild_link.title }}</span>
                    {% assign found_breadcrumb = true %}
                  {% endif %}
                {% endfor %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}
        
        {% comment %} Fallback if collection isn't in menu or we are at top level {% endcomment %}
        {% if collection.handle != blank %}
           {% assign current_in_breadcrumb = false %}
           {% for link in menu_links %}
             {% if link.active %}{% assign current_in_breadcrumb = true %}{% endif %}
             {% for child in link.links %}
               {% if child.active %}{% assign current_in_breadcrumb = true %}{% endif %}
               {% for grand in child.links %}
                 {% if grand.active %}{% assign current_in_breadcrumb = true %}{% endif %}
               {% endfor %}
             {% endfor %}
           {% endfor %}
           
           {% if current_in_breadcrumb == false %}
             <span>/</span>
             <span>{{ collection.title }}</span>
           {% endif %}
        {% endif %}

      {% else %}
        <span>/</span>
        <span>{{ collection.title }}</span>
      {% endif %}
    </nav>
  </div>

  <div class="page-width collection-container">
    
    {%- comment -%} Mobile Filter Toggle {%- endcomment -%}
    <div class="mobile-filter-bar">
      <button class="mobile-filter-btn" id="mobile-filter-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 21v-7m0-4V3m8 18v-9m0-4V3m8 18v-5m0-4V3M1 14h6m2-6h6m2 8h6"/>
        </svg>
        Filter & Sort
      </button>
      <span class="mobile-product-count">{{ collection.products_count }} products</span>
    </div>

    {%- comment -%} Left Sidebar Filters {%- endcomment -%}
    <aside class="filter-sidebar" id="filter-sidebar">
      <div class="mobile-filter-header">
        <h3>Filters</h3>
        <button class="mobile-filter-close" id="mobile-filter-close">×</button>
      </div>
      
      {%- comment -%} Categories Filter {%- endcomment -%}
      <div class="filter-group">
        <div class="filter-group__header">
          <h3>Filter by</h3>
        </div>
        
        <div class="filter-section">
          <div class="filter-section__header">
            <h4>Categories</h4>
            <button class="filter-reset">Reset</button>
          </div>
          
          <div class="filter-options">
            {% assign menu_handle = section.settings.category_menu %}
            {% assign menu_links = linklists[menu_handle].links %}
            
            {% assign displayed_handles = "" %}
            {% if menu_handle != blank and menu_links.size > 0 %}
              <div class="category-tree">
                {% for link in menu_links %}
                  {% comment %} Skip utility links (Home, Contact, etc.) {% endcomment %}
                  {% assign link_title_dc = link.title | downcase | strip %}
                  {% assign link_url = link.url | remove: shop.url | remove: 'https://' | remove: 'http://' %}
                  {% if link_title_dc == 'home' or link_title_dc == 'contact' or link_title_dc == 'contact us' or link_url == '/' or link_url == '' or link_url contains 'pages/contact' %}
                    {% continue %}
                  {% endif %}

                  {% assign has_sub = false %}
                  {% if link.links != blank %}{% assign has_sub = true %}{% endif %}
                  
                  {% assign is_open = false %}
                  {% if link.active or link.child_active %}{% assign is_open = true %}{% endif %}
                  
                  {% comment %} robust check for open state {% endcomment %}
                  {% if has_sub and is_open == false %}
                    {% for child in link.links %}
                      {% if child.active or child.child_active %}{% assign is_open = true %}{% endif %}
                      {% for grand in child.links %}
                        {% if grand.active %}{% assign is_open = true %}{% endif %}
                      {% endfor %}
                    {% endfor %}
                  {% endif %}

                  <div class="category-item">
                    {% if has_sub %}
                      <details class="category-details" {% if is_open %}open{% endif %}>
                        <summary class="category-summary">
                          <a href="{{ link.url }}" class="category-link {% if link.active %}active{% endif %}">
                            <span>{{ link.title }}</span>
                            {% if link.type == 'collection_link' and link.object.handle != blank %}
                              {% assign displayed_handles = displayed_handles | append: link.object.handle | append: "," %}
                              {% if link.object.products_count > 0 %}
                                <span class="filter-count">({{ link.object.products_count }})</span>
                              {% endif %}
                            {% endif %}
                          </a>
                          <span class="category-toggle">
                            <svg class="icon-caret" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
                          </span>
                        </summary>
                        <div class="category-submenu">
                          {% for child_link in link.links %}
                            {% assign has_sub_sub = false %}
                            {% if child_link.links != blank %}{% assign has_sub_sub = true %}{% endif %}
                            
                            {% assign child_is_open = false %}
                            {% if child_link.active or child_link.child_active %}{% assign child_is_open = true %}{% endif %}

                            {% if has_sub_sub and child_is_open == false %}
                                {% for grand in child_link.links %}
                                    {% if grand.active %}{% assign child_is_open = true %}{% endif %}
                                {% endfor %}
                            {% endif %}

                            <div class="category-item">
                              {% if has_sub_sub %}
                                <details class="category-details" {% if child_is_open %}open{% endif %}>
                                  <summary class="category-summary">
                                    <a href="{{ child_link.url }}" class="category-link {% if child_link.active %}active{% endif %}">
                                      <span>{{ child_link.title }}</span>
                                      {% if child_link.type == 'collection_link' and child_link.object.handle != blank %}
                                        {% assign displayed_handles = displayed_handles | append: child_link.object.handle | append: "," %}
                                        {% if child_link.object.products_count > 0 %}
                                          <span class="filter-count">({{ child_link.object.products_count }})</span>
                                        {% endif %}
                                      {% endif %}
                                    </a>
                                    <span class="category-toggle">
                                      <svg class="icon-caret" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
                                    </span>
                                  </summary>
                                  <div class="category-submenu">
                                    {% for grandchild_link in child_link.links %}
                                       <a href="{{ grandchild_link.url }}" class="category-link nested {% if grandchild_link.active %}active{% endif %}">
                                         <span>{{ grandchild_link.title }}</span>
                                         {% if grandchild_link.type == 'collection_link' and grandchild_link.object.handle != blank %}
                                           {% assign displayed_handles = displayed_handles | append: grandchild_link.object.handle | append: "," %}
                                           {% if grandchild_link.object.products_count > 0 %}
                                             <span class="filter-count">({{ grandchild_link.object.products_count }})</span>
                                           {% endif %}
                                         {% endif %}
                                       </a>
                                    {% endfor %}
                                  </div>
                                </details>
                              {% else %}
                                 <a href="{{ child_link.url }}" class="category-link {% if child_link.active %}active{% endif %}">
                                   <span>{{ child_link.title }}</span>
                                   {% if child_link.type == 'collection_link' and child_link.object.handle != blank %}
                                      {% assign displayed_handles = displayed_handles | append: child_link.object.handle | append: "," %}
                                      {% if child_link.object.products_count > 0 %}
                                        <span class="filter-count">({{ child_link.object.products_count }})</span>
                                      {% endif %}
                                   {% endif %}
                                 </a>
                              {% endif %}
                            </div>
                          {% endfor %}
                        </div>
                      </details>
                    {% else %}
                      <a href="{{ link.url }}" class="category-link {% if link.active %}active{% endif %}">
                        <span>{{ link.title }}</span>
                        {% if link.type == 'collection_link' and link.object.handle != blank %}
                          {% assign displayed_handles = displayed_handles | append: link.object.handle | append: "," %}
                          {% if link.object.products_count > 0 %}
                            <span class="filter-count">({{ link.object.products_count }})</span>
                          {% endif %}
                        {% endif %}
                      </a>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            <div class="category-tree category-blocks">
              {% for block in section.blocks %}
                {% if block.type == 'category_filter' %}
                  {% assign filter_collection = collections[block.settings.collection] %}
                  {% if filter_collection and filter_collection.handle != blank %}
                    {% assign handle_check = filter_collection.handle | append: "," %}
                    {% if displayed_handles contains handle_check %}{% continue %}{% endif %}
                    
                    <a href="{{ filter_collection.url }}" class="category-link {% if collection.handle == filter_collection.handle %}active{% endif %}">
                      <span>{{ filter_collection.title }}</span>
                      {% if filter_collection.products_count > 0 %}
                        <span class="filter-count">({{ filter_collection.products_count }})</span>
                      {% endif %}
                    </a>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Price Filter {%- endcomment -%}
      <div class="filter-group">
        <div class="filter-section">
          <div class="filter-section__header">
            <h4>Price</h4>
            <button class="filter-reset">Reset</button>
          </div>
          
          <div class="price-inputs">
            <div class="price-range-inputs">
              <input type="number" id="min-price" placeholder="Min" min="0" value="0">
              <input type="number" id="max-price" placeholder="Max" min="0" value="600">
            </div>
            
            <div class="price-slider-container">
              <div class="price-slider-track" id="price-track"></div>
              <input type="range" id="range-min" min="0" max="600" value="0" step="10">
              <input type="range" id="range-max" min="0" max="600" value="600" step="10">
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Flower Color Filter {%- endcomment -%}
      <div class="filter-group">
        <div class="filter-section">
          <div class="filter-section__header">
            <h4>Flower Color</h4>
            <button class="filter-reset">Reset</button>
          </div>
          
          <div class="filter-options">
            {% assign flower_colors = 'Red,Pink,White,Yellow,Purple,Orange' | split: ',' %}
            {% for color in flower_colors %}
              <label class="filter-checkbox">
                <input type="checkbox" name="flower_color" value="{{ color | downcase }}" data-filter="flower-color">
                <span>{{ color }}</span>
              </label>
            {% endfor %}
          </div>
        </div>
      </div>

      {%- comment -%} Pot Color Filter {%- endcomment -%}
      <div class="filter-group">
        <div class="filter-section">
          <div class="filter-section__header">
            <h4>Pot Color</h4>
            <button class="filter-reset">Reset</button>
          </div>
          
          <div class="filter-options">
            {% assign pot_colors = 'White,Black,Grey,Terracotta,Brown' | split: ',' %}
            {% for color in pot_colors %}
              <label class="filter-checkbox">
                <input type="checkbox" name="pot_color" value="{{ color | downcase }}" data-filter="pot-color">
                <span>{{ color }}</span>
              </label>
            {% endfor %}
          </div>
        </div>
      </div>

      {%- comment -%} Flowering Status Filter {%- endcomment -%}
      <div class="filter-group">
        <div class="filter-section">
          <div class="filter-section__header">
            <h4>Flowering</h4>
            <button class="filter-reset">Reset</button>
          </div>
          
          <div class="filter-options">
            <label class="filter-checkbox">
              <input type="checkbox" name="flowering" value="with-flower">
              <span>With Flower</span>
            </label>
            <label class="filter-checkbox">
              <input type="checkbox" name="flowering" value="without-flower">
              <span>Without Flower</span>
            </label>
          </div>
        </div>
      </div>

      {%- comment -%} Shop by Style {%- endcomment -%}
      {% if section.settings.show_style_filter %}
        <div class="filter-group style-filter-group">
          <div class="filter-section">
            <h4>Shop by Style</h4>
            
            <div class="style-cards swiper-container">
              <div class="swiper-wrapper">
                {% for block in section.blocks %}
                  {% if block.type == 'style_card' %}
                    <a href="{{ block.settings.link }}" class="style-card swiper-slide">
                      {% if block.settings.image %}
                        <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}">
                      {% endif %}
                      <span>{{ block.settings.title }}</span>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M9 18l6-6-6-6"/>
                      </svg>
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}

      <div class="mobile-filter-footer">
        <button class="mobile-apply-btn" id="mobile-filter-apply">Apply Filters</button>
      </div>
    </aside>

    {%- comment -%} Main Content Area {%- endcomment -%}
    {% paginate collection.products by 24 %}
    <main class="collection-main">
      
      {%- comment -%} Header with title, count, and sort {%- endcomment -%}
      <div class="collection-header">
        <div class="collection-title-area">
          <h1>{{ collection.title }}</h1>
          <p class="product-count">
            {% if collection.products_count > 0 %}
               {% assign current_start = paginate.current_offset | plus: 1 %}
               {% assign current_end = paginate.current_offset | plus: collection.products.size %}
               <span class="count-display">{{ current_start }}-{{ current_end }}</span> of {{ collection.products_count }} products
            {% else %}
               0 products
            {% endif %}
          </p>
        </div>
        
        <div class="collection-sort">
          <select id="sort-by" class="sort-select">
            <option value="featured">Featured</option>
            <option value="best-selling">Best Selling</option>
            <option value="title-ascending">Alphabetically, A-Z</option>
            <option value="title-descending">Alphabetically, Z-A</option>
            <option value="price-ascending">Price, low to high</option>
            <option value="price-descending">Price, high to low</option>
            <option value="created-ascending">Date, old to new</option>
            <option value="created-descending">Date, new to old</option>
          </select>
        </div>
      </div>

      {%- comment -%} Product Grid {%- endcomment -%}
      <div class="product-grid" id="product-grid">
        {% for product in collection.products %}
        {%- assign type_lower = product.type | downcase -%}
        {%- assign tags_lower = product.tags | join: ',' | downcase -%}
        {%- assign clean_flower_color = product.options_by_name['Flower Color'].values | join: ',' | downcase -%}
        {%- assign clean_pot_color = product.options_by_name['Pot Color'].values | join: ',' | downcase -%}
        {%- assign generic_color = product.options_by_name['Color'].values | join: ',' | downcase -%}
        
        {%- assign is_pot = false -%}
        {%- if type_lower contains 'pot' or type_lower contains 'planter' or type_lower contains 'vase' or type_lower contains 'basket' or type_lower contains 'accessory' -%}
          {%- assign is_pot = true -%}
        {%- endif -%}
        {%- if tags_lower contains 'pot' or tags_lower contains 'planter' -%}
          {%- assign is_pot = true -%}
        {%- endif -%}
        {%- if clean_pot_color != blank -%}
          {%- assign is_pot = true -%}
        {%- endif -%}

        {%- if is_pot -%}
          {%- assign final_pot_color = clean_pot_color | append: ' ' | append: generic_color -%}
          {%- assign final_flower_color = clean_flower_color -%}
        {%- else -%}
          {%- assign final_flower_color = clean_flower_color | append: ' ' | append: generic_color -%}
          {%- assign final_pot_color = clean_pot_color -%}
        {%- endif -%}

          <div class="product-card" 
               data-price="{{ product.price }}" 
               data-tags="{{ product.tags | join: ',' | downcase }}"
               data-flower-color="{{ final_flower_color }}"
               data-pot-color="{{ final_pot_color }}">
            
            <div class="product-card__image-container">
              <a href="{{ product.url }}" class="product-card__image">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" 
                       alt="{{ product.title | escape }}"
                       loading="lazy">
                {% endif %}
                
                {%- comment -%} HOT badge {%- endcomment -%}
                {% if product.tags contains 'hot' or product.tags contains 'trending' %}
                  <span class="product-badge">HOT</span>
                {% endif %}
              </a>
            </div>
            
            <div class="product-card__info">
              <div class="product-card__vendor">{{ product.vendor }}</div>
              <a href="{{ product.url }}" class="product-card__name">
                {{ product.title }}
              </a>
              
              <div class="product-card__bottom">
                <div class="product-card__price">
                  {% if product.compare_at_price > product.price %}
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="price-current">{{ product.price | money }}</span>
                </div>
                
                {%- comment -%} Quantity and Add to Cart {%- endcomment -%}
                {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}
                <div class="product-card__form-wrapper" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-product-id="{{ product.id }}">
                  <div class="product-card__actions {% if cart_qty > 0 %}is-active{% endif %}" data-cart-quantity="{{ cart_qty }}">
                  
                    <div class="product-card__qty-selector">
                      <button type="button" class="qty__btn qty__minus" data-action="decrease">
                        <span class="qty__minus-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line></svg></span>
                        <span class="qty__trash-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></span>
                      </button>
                      <span class="qty__current">{{ cart_qty }}</span>
                      <button type="button" class="qty__btn qty__plus" data-action="increase">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                      </button>
                    </div>

                    <div class="product-card__atc-wrapper">
                      <button type="button" class="product-card__atc-trigger" data-action="add-to-cart" aria-label="Add to cart">
                        <svg viewBox="0 0 24 24" fill="none">
                          <path d="M3 3h2l2.2 11.4a2 2 0 0 0 2 1.6h7.5a2 2 0 0 0 2-1.6L21 7H6"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          <circle cx="10" cy="20" r="1.5" fill="currentColor"/>
                          <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {% if paginate.pages > 1 %}
        <div class="pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="pagination-prev">← Previous</a>
          {% endif %}
          
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {% else %}
              {% if part.title == paginate.current_page %}
                <span class="current">{{ part.title }}</span>
              {% else %}
                <span>{{ part.title }}</span>
              {% endif %}
            {% endif %}
          {% endfor %}
          
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="pagination-next">Next →</a>
          {% endif %}
        </div>
      {% endif %}
    {% endpaginate %}

    </main>

  </div>
</div>

<style>
/* Base Styles */
.collection-filter-page {
  background: #f6f7f2;
  min-height: 100vh;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.page-width {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Breadcrumb */
.breadcrumb-section {
  padding: 16px 24px;
  background: #fff;
  border-bottom: 1px solid #e5e5e5;
}

.breadcrumb {
  font-size: 14px;
  color: #666;
}

.breadcrumb a {
  color: #666;
  text-decoration: none;
}

.breadcrumb a:hover {
  color: #1f3d2b;
}

.breadcrumb span {
  margin: 0 8px;
}

/* Container Layout */
.collection-container {
  display: grid;
  grid-template-columns: 250px 1fr;
  gap: 40px;
  padding: 32px 0;
}

/* Sidebar Filters */
.filter-sidebar {
  position: sticky;
  top: 20px;
  height: fit-content;
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
}

.filter-group {
  margin-bottom: 32px;
}

.filter-group__header h3 {
  font-size: 20px;
  font-weight: 600;
  color: #1f3d2b;
  margin: 0 0 16px;
}

.filter-section {
  margin-bottom: 24px;
}

.filter-section__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.filter-section__header h4 {
  font-size: 16px;
  font-weight: 600;
  color: #1f3d2b;
