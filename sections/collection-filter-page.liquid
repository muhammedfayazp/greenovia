{% layout none %}
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ collection.title }}</title>

  <style>
    /* ===== GRID ===== */
    .collection-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 20px;
    }

    .product-card {
      position: relative;
      border: 1px solid #eee;
      border-radius: 12px;
      padding: 12px;
    }

    .product-card img {
      width: 100%;
      border-radius: 10px;
    }

    .product-title {
      font-size: 14px;
      margin: 10px 0 4px;
    }

    .price {
      font-weight: 700;
    }

    /* ===== ACTION AREA ===== */
    .modern-product-actions {
      position: absolute;
      bottom: 12px;
      right: 12px;
      height: 40px;
    }

    /* CART + PLUS */
    .modern-cart-btn {
      width: 40px;
      height: 40px;
      border-radius: 999px;
      background: #1f3d2b;
      color: #fff;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: pointer;
      transition: all .25s ease;
      box-shadow: 0 4px 10px rgba(0,0,0,.15);
    }

    .cart-plus-badge {
      position: absolute;
      top: -4px;
      right: -4px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #fff;
      color: #1f3d2b;
      font-size: 12px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* QTY PILL */
    .modern-qty-selector {
      position: absolute;
      right: 0;
      top: 0;
      height: 40px;
      min-width: 110px;
      padding: 0 6px;
      background: #1f3d2b;
      border-radius: 999px;
      display: flex;
      align-items: center;
      gap: 6px;

      opacity: 0;
      pointer-events: none;
      transform: scale(.85);
      transition: all .3s ease;
    }

    .modern-product-actions.is-active .modern-qty-selector {
      opacity: 1;
      pointer-events: auto;
      transform: scale(1);
    }

    .modern-product-actions.is-active .modern-cart-btn {
      opacity: 0;
      pointer-events: none;
      transform: scale(.85);
    }

    /* QTY BUTTONS */
    .qty__btn {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(255,255,255,.2);
      color: #fff;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .qty__btn:hover {
      background: rgba(255,255,255,.3);
    }

    .qty__current {
      width: 26px;
      text-align: center;
      background: transparent;
      border: none;
      color: #fff;
      font-weight: 700;
    }

    .qty__trash-icon {
      display: none;
    }

    .modern-product-actions[data-cart-quantity="1"] .qty__minus-icon {
      display: none;
    }

    .modern-product-actions[data-cart-quantity="1"] .qty__trash-icon {
      display: flex;
    }
  </style>
</head>

<body>

<h1>{{ collection.title }}</h1>

<div class="collection-grid">

{% for product in collection.products %}
  {% assign variant = product.selected_or_first_available_variant %}
  {% assign cart_qty = 0 %}

  {% for item in cart.items %}
    {% if item.variant_id == variant.id %}
      {% assign cart_qty = item.quantity %}
    {% endif %}
  {% endfor %}

  <div class="product-card">
    <a href="{{ product.url }}">
      <img src="{{ product.featured_image | img_url: '400x' }}" alt="">
    </a>

    <div class="product-title">{{ product.title }}</div>
    <div class="price">{{ variant.price | money }}</div>

    <div
      class="modern-product-actions {% if cart_qty > 0 %}is-active{% endif %}"
      data-variant-id="{{ variant.id }}"
      data-cart-quantity="{{ cart_qty }}"
    >

      <!-- CART + PLUS -->
      <button class="modern-cart-btn cart-plus-btn" type="button">
        🛒
        <span class="cart-plus-badge">+</span>
      </button>

      <!-- QTY -->
      <div class="modern-qty-selector">
        <button class="qty__btn qty__minus" type="button">
          <span class="qty__minus-icon">−</span>
          <span class="qty__trash-icon">🗑</span>
        </button>

        <input class="qty__current" type="text" readonly value="{{ cart_qty | default: 1 }}">

        <button class="qty__btn qty__plus" type="button">+</button>
      </div>

    </div>
  </div>
{% endfor %}

</div>

<script>
document.addEventListener('click', async (e) => {
  const actions = e.target.closest('.modern-product-actions');
  if (!actions) return;

  const variantId = actions.dataset.variantId;
  const qtyInput = actions.querySelector('.qty__current');
  let qty = parseInt(qtyInput.value || 0);

  /* ADD TO CART */
  if (e.target.closest('.cart-plus-btn')) {
    qty = 1;
    await updateCart(variantId, qty);
    actions.classList.add('is-active');
  }

  /* PLUS */
  if (e.target.closest('.qty__plus')) {
    qty++;
    await updateCart(variantId, qty);
  }

  /* MINUS / TRASH */
  if (e.target.closest('.qty__minus')) {
    qty--;
    if (qty <= 0) {
      await updateCart(variantId, 0);
      actions.classList.remove('is-active');
      qty = 0;
    } else {
      await updateCart(variantId, qty);
    }
  }

  actions.dataset.cartQuantity = qty;
  qtyInput.value = qty || 1;
});

/* AJAX CART UPDATE */
async function updateCart(variantId, quantity) {
  await fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      id: variantId,
      quantity: quantity
    })
  });
}
</script>

</body>
</html>
