</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const checkboxes = document.querySelectorAll('.filter-checkbox input[type="checkbox"]');
  const minPrice = document.getElementById('min-price');
  const maxPrice = document.getElementById('max-price');
  const rangeMin = document.getElementById('range-min');
  const rangeMax = document.getElementById('range-max');
  const productCards = document.querySelectorAll('.product-card');
  
  // Price slider update function
  function updatePriceSlider() {
    if (!rangeMin || !rangeMax) return;
    
    const minVal = parseInt(rangeMin.value);
    const maxVal = parseInt(rangeMax.value);
    
    minPrice.value = minVal;
    maxPrice.value = maxVal;
    
    const priceTrack = document.getElementById('price-track');
    const percentMin = (minVal / 600) * 100;
    const percentMax = (maxVal / 600) * 100;
    priceTrack.style.left = percentMin + '%';
    priceTrack.style.width = (percentMax - percentMin) + '%';
  }
  
  // Filter function
  function filterProducts() {
    const selectedFlowerColors = Array.from(document.querySelectorAll('input[name="flower_color"]:checked')).map(cb => cb.value);
    const selectedPotColors = Array.from(document.querySelectorAll('input[name="pot_color"]:checked')).map(cb => cb.value);
    const selectedFlowering = Array.from(document.querySelectorAll('input[name="flowering"]:checked')).map(cb => cb.value);
    const min = parseFloat(minPrice.value) || 0;
    const max = parseFloat(maxPrice.value) || Infinity;
    
    let visibleCount = 0;
    
    productCards.forEach(card => {
      const price = parseFloat(card.dataset.price) / 100;
      const tags = card.dataset.tags.toLowerCase();
      const flowerColors = card.dataset.flowerColor.toLowerCase();
      const potColors = card.dataset.potColor.toLowerCase();
      
      let showCard = true;
      
      // Price filter
      if (price < min || price > max) {
        showCard = false;
      }
      
      // Flower Color Filter
      if (selectedFlowerColors.length > 0) {
        const productFlowerTokens = flowerColors.split(/[ ,]+/).filter(Boolean);
        const hasMatchingColor = selectedFlowerColors.some(color => productFlowerTokens.includes(color));
        if (!hasMatchingColor) showCard = false;
      }

      // Pot Color Filter
      if (selectedPotColors.length > 0) {
        const productPotTokens = potColors.split(/[ ,]+/).filter(Boolean);
        const hasMatchingPot = selectedPotColors.some(color => productPotTokens.includes(color));
        if (!hasMatchingPot) showCard = false;
      }

      // Flowering Status Filter
      if (selectedFlowering.length > 0) {
        const isWithFlower = tags.includes('with-flower') || flowerColors.trim().length > 0;
        const isWithoutFlower = tags.includes('without-flower') || (flowerColors.trim().length === 0 && !tags.includes('with-flower'));

        const wantsWithFlower = selectedFlowering.includes('with-flower');
        const wantsWithoutFlower = selectedFlowering.includes('without-flower');

        if (wantsWithFlower && !wantsWithoutFlower && !isWithFlower) showCard = false;
        if (wantsWithoutFlower && !wantsWithFlower && !isWithoutFlower) showCard = false;
      }
      
      card.style.display = showCard ? 'block' : 'none';
      if (showCard) visibleCount++;
    });
    
    // Update count
    const countDisplay = document.querySelector('.count-display');
    if (countDisplay) {
      countDisplay.textContent = `1-${visibleCount}`;
    }
  }

  // Price Slider Logic
  function handleRangeInput(e) {
    let minVal = parseInt(rangeMin.value);
    let maxVal = parseInt(rangeMax.value);
    
    if (maxVal - minVal < 10) {
      if (e.target.id === 'range-min') {
        rangeMin.value = maxVal - 10;
      } else {
        rangeMax.value = minVal + 10;
      }
    }
    
    updatePriceSlider();
    filterProducts();
  }
  
  // Event listeners
  checkboxes.forEach(cb => cb.addEventListener('change', filterProducts));
  
  if (rangeMin && rangeMax) {
    rangeMin.addEventListener('input', handleRangeInput);
    rangeMax.addEventListener('input', handleRangeInput);
    updatePriceSlider();
  }
  
  if (minPrice && maxPrice) {
    minPrice.addEventListener('input', function() {
      let val = parseInt(this.value);
      if (val < parseInt(rangeMax.value)) {
        rangeMin.value = val;
        updatePriceSlider();
        filterProducts();
      }
    });
    maxPrice.addEventListener('input', function() {
      let val = parseInt(this.value);
      if (val > parseInt(rangeMin.value)) {
        rangeMax.value = val;
        updatePriceSlider();
        filterProducts();
      }
    });
  }
  
  // Reset buttons
  document.querySelectorAll('.filter-reset').forEach(btn => {
    btn.addEventListener('click', function() {
      const section = this.closest('.filter-section');
      section.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
      
      if (section.querySelector('#min-price')) {
        rangeMin.value = 0;
        rangeMax.value = 600;
        updatePriceSlider();
      }
      
      filterProducts();
    });
  });
  
  // Sort functionality
  const sortSelect = document.getElementById('sort-by');
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      window.location.href = window.location.pathname + '?sort_by=' + this.value;
    });
  }
  
  // Mobile Filter Logic
  const mobileToggle = document.getElementById('mobile-filter-toggle');
  const mobileClose = document.getElementById('mobile-filter-close');
  const mobileApply = document.getElementById('mobile-filter-apply');
  const sidebar = document.getElementById('filter-sidebar');
  
  if (mobileToggle) {
    mobileToggle.addEventListener('click', function() {
      sidebar.classList.add('active');
      document.body.classList.add('filter-open');
      document.body.style.overflow = 'hidden';
    });
  }
  
  function closeFilter() {
    sidebar.classList.remove('active');
    document.body.classList.remove('filter-open');
    document.body.style.overflow = '';
  }
  
  if (mobileClose) mobileClose.addEventListener('click', closeFilter);
  if (mobileApply) mobileApply.addEventListener('click', closeFilter);
  
  document.addEventListener('click', function(e) {
    if (document.body.classList.contains('filter-open') && 
        !sidebar.contains(e.target) && 
        !mobileToggle.contains(e.target)) {
      closeFilter();
    }
  });

  // ===== CUSTOM CART HANDLING - NO REDIRECTS =====
  
  // Update UI for a specific product card
  function updateProductCardUI(wrapper, quantity) {
    const actions = wrapper.querySelector('.product-card__actions');
    const qtyDisplay = wrapper.querySelector('.qty__current');
    
    if (!actions || !qtyDisplay) return;
    
    actions.dataset.cartQuantity = quantity;
    qtyDisplay.textContent = quantity;
    
    if (quantity > 0) {
      actions.classList.add('is-active');
    } else {
      actions.classList.remove('is-active');
    }
  }
  
  // Sync all cards from cart data
  async function syncAllCardsFromCart() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      
      document.querySelectorAll('.product-card__form-wrapper').forEach(wrapper => {
        const variantId = wrapper.dataset.variantId;
        if (!variantId) return;
        
        const cartItem = cart.items.find(item => item.variant_id.toString() === variantId.toString());
        const quantity = cartItem ? cartItem.quantity : 0;
        
        updateProductCardUI(wrapper, quantity);
      });
      
      // Update cart count in header if exists
      // Skip dispatching new cart:update event as we are already responding to one
      updateCartCount(cart.item_count, true);
      
    } catch (error) {
      console.error('Failed to sync cart:', error);
    }
  }
  
  // Update cart count in header
  function updateCartCount(count, skipDispatch = false) {
    if (skipDispatch) return;

    // Dispatch event for cart drawer/icon updates
    document.dispatchEvent(new CustomEvent('cart:update', {
      bubbles: true,
      detail: {
        data: { itemCount: count }
      }
    }));
  }
  
  // Handle Add to Cart
  async function handleAddToCart(wrapper, variantId) {
    const actions = wrapper.querySelector('.product-card__actions');
    if (!actions) return;
    
    // Add loading state
    actions.classList.add('is-loading');
    
    try {
      const formData = new FormData();
      formData.append('id', variantId);
      formData.append('quantity', 1);
      
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        body: formData
      });
      
      if (!response.ok) throw new Error('Failed to add to cart');
      
      const result = await response.json();
      
      // Get current cart quantity for this variant
      const cartResponse = await fetch('/cart.js');
      const cart = await cartResponse.json();
      const cartItem = cart.items.find(item => item.variant_id.toString() === variantId.toString());
      const quantity = cartItem ? cartItem.quantity : 1;
      
      // Update UI
      updateProductCardUI(wrapper, quantity);
      updateCartCount(cart.item_count);
      
    } catch (error) {
      console.error('Add to cart failed:', error);
      alert('Failed to add item to cart. Please try again.');
    } finally {
      actions.classList.remove('is-loading');
    }
  }
  
  // Handle Quantity Change
  async function handleQuantityChange(wrapper, variantId, newQuantity) {
    const actions = wrapper.querySelector('.product-card__actions');
    if (!actions) return;
    
    // Optimistic UI update
    updateProductCardUI(wrapper, newQuantity);
    
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variantId.toString(),
          quantity: newQuantity
        })
      });
      
      if (!response.ok) throw new Error('Failed to update cart');
      
      const cart = await response.json();
      
      // Verify the update
      const cartItem = cart.items.find(item => item.variant_id.toString() === variantId.toString());
      const actualQuantity = cartItem ? cartItem.quantity : 0;
      
      // Update UI with actual quantity
      updateProductCardUI(wrapper, actualQuantity);
      updateCartCount(cart.item_count);
      
    } catch (error) {
      console.error('Quantity update failed:', error);
      // Revert to cart state on error
      syncAllCardsFromCart();
    }
  }
  
  // Attach event listeners to all product cards
  document.querySelectorAll('.product-card__form-wrapper').forEach(wrapper => {
    const variantId = wrapper.dataset.variantId;
    if (!variantId) return;
    
    const actions = wrapper.querySelector('.product-card__actions');
    if (!actions) return;
    
    // Add to Cart button
    const addBtn = wrapper.querySelector('[data-action="add-to-cart"]');
    if (addBtn) {
      addBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        handleAddToCart(wrapper, variantId);
      });
    }
    
    // Decrease quantity button
    const decreaseBtn = wrapper.querySelector('[data-action="decrease"]');
    if (decreaseBtn) {
      decreaseBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const currentQty = parseInt(actions.dataset.cartQuantity) || 0;
        const newQty = Math.max(0, currentQty - 1);
        
        handleQuantityChange(wrapper, variantId, newQty);
      });
    }
    
    // Increase quantity button
    const increaseBtn = wrapper.querySelector('[data-action="increase"]');
    if (increaseBtn) {
      increaseBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        const currentQty = parseInt(actions.dataset.cartQuantity) || 0;
        const newQty = currentQty + 1;
        
        handleQuantityChange(wrapper, variantId, newQty);
      });
    }
  });
  
  // Listen for external cart updates (from other sections)
  document.addEventListener('cart:update', () => {
    syncAllCardsFromCart();
  });

  // Initial filter run
  filterProducts();
  
  // Show page after first filter
  document.querySelector('.collection-filter-page').style.opacity = '1';
});
</script>

