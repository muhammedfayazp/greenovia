{% stylesheet %}
.trust-bar {
  background: #f8faf5;
  border-top: 1px solid #e0ebd5;
  border-bottom: 1px solid #e0ebd5;
  overflow: hidden;
}

.trust-bar__track {
  display: flex;
  align-items: stretch;
  max-width: 1400px;
  margin: 0 auto;
}

.trust-bar__item {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 1.125rem 2rem;
  flex: 1;
  flex-shrink: 0;          /* never shrink below content */
  min-width: 200px;        /* minimum so text never collapses */
}

.trust-bar__divider {
  width: 1px;
  background: #ddebd0;
  align-self: stretch;
  margin: 0.75rem 0;
  flex-shrink: 0;
}

.trust-bar__icon {
  width: 40px;
  height: 40px;
  background: #e8f3de;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #2D5016;
}

.trust-bar__icon svg {
  width: 20px;
  height: 20px;
}

.trust-bar__text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.trust-bar__text strong {
  font-size: 0.875rem;
  font-weight: 700;
  color: #1f3d2b;
  white-space: nowrap;
}

.trust-bar__text span {
  font-size: 0.75rem;
  color: #6b8a5a;
  white-space: nowrap;
}

/* Mobile: horizontal scroll strip */
@media (max-width: 900px) {
  .trust-bar__track {
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    /* fade hint on right edge */
    -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
    mask-image: linear-gradient(to right, black 85%, transparent 100%);
  }
  .trust-bar__track::-webkit-scrollbar { display: none; }

  .trust-bar__item {
    padding: 0.875rem 1.25rem;
    min-width: 180px;
  }
}

@media (max-width: 480px) {
  .trust-bar__item {
    padding: 0.875rem 1rem;
    min-width: 160px;
    gap: 0.625rem;
  }
  .trust-bar__icon {
    width: 34px;
    height: 34px;
  }
  .trust-bar__icon svg {
    width: 16px;
    height: 16px;
  }
  .trust-bar__text strong { font-size: 0.8125rem; }
  .trust-bar__text span { font-size: 0.6875rem; }
}
{% endstylesheet %}

