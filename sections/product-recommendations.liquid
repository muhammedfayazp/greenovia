
 

{% assign recommended_product_id = section.settings.product.id | default: product.id %}

<product-recommendations
  class="product-recommendations"
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.limit }}"
  data-product-id="{{ recommended_product_id }}"
  data-intent="{{ section.settings.type }}"
>

  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if recommendations.performed and recommendations.products_count > 0 %}
      <div class="recommendations-grid">
        {% for product in recommendations.products %}
          <a href="{{ product.url }}" class="recommendation-card">
            <div class="recommendation-image">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 500 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                >
              {% endif %}
            </div>

            <div class="recommendation-info">
              <h3>{{ product.title }}</h3>
              <span class="price">
                {{ product.price | money }}
              </span>
            </div>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

</product-recommendations>
{% stylesheet %}
.product-recommendations {
  padding: 3rem 0;
}

.section-heading {
  margin-bottom: 1.5rem;
  font-size: 1.6rem;
  font-weight: 600;
}

.recommendations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 1.5rem;
}

.recommendation-card {
  display: block;
  text-decoration: none;
  color: inherit;
}

.recommendation-image {
  aspect-ratio: 3 / 4;
  background: #f6f6f6;
  overflow: hidden;
  border-radius: 12px;
}

.recommendation-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .3s ease;
}

.recommendation-card:hover img {
  transform: scale(1.05);
}

.recommendation-info {
  margin-top: .75rem;
}

.recommendation-info h3 {
  font-size: .95rem;
  font-weight: 500;
  margin: 0 0 .25rem;
}

.price {
  font-weight: 600;
}
{% endstylesheet %}
{% schema %}
{
   "name": "t:names.product_recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Base product",
      "info": "Leave empty to use current product"
    },
    {
      "type": "select",
      "id": "type",
      "label": "Recommendation type",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ],
      "default": "related"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product recommendations (simple)",
      "category": "Products"
    }
  ]
}
{% endschema %}

 