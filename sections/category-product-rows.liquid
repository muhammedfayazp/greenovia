<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="hps">
  <div class="page-width">

    {% for block in section.blocks %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank and col.products.size > 0 %}

      <div class="hps__section" {{ block.shopify_attributes }}>
        <div class="hps__head">
          <h2>{{ col.title }}</h2>
          <a href="{{ col.url }}">View all →</a>
        </div>

        <div class="swiper hps__swiper" data-swiper>
          <div class="swiper-wrapper">

            {% for product in col.products limit: 12 %}
            <div class="swiper-slide hps__card">

              <a href="{{ product.url }}" class="hps__img">
                {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy' }}
              </a>

              <div class="hps__info">
                <div class="hps__title">{{ product.title }}</div>
                <div class="hps__price">{{ product.price | money }}</div>

                {% if product.available %}
                <div class="qty-atc" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                  <button class="qty-btn minus">−</button>
                  <span class="qty-count">0</span>
                  <button class="qty-btn plus">+</button>
                </div>
                {% else %}
                <div class="soldout">Sold out</div>
                {% endif %}
              </div>

            </div>
            {% endfor %}

          </div>
        </div>
      </div>

      {% endif %}
    {% endfor %}

  </div>
</section>

<style>
.hps { padding: 50px 0; background:#f6f7f2; }
.hps__head { display:flex; justify-content:space-between; margin-bottom:16px; }
.hps__head h2 { margin:0; font-size:24px; }
.hps__head a { text-decoration:none; font-weight:500; }

.hps__card {
  background:#fff;
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 6px 16px rgba(0,0,0,.08);
}

.hps__img img { width:100%; display:block; }

.hps__info { padding:12px; }
.hps__title {
  font-size:14px;
  font-weight:600;
  margin-bottom:6px;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.hps__price { font-weight:700; margin-bottom:10px; }

.qty-atc {
  display:flex;
  align-items:center;
  background:#0066ff;
  border-radius:8px;
  height:36px;
  overflow:hidden;
}

.qty-btn {
  width:34px;
  height:36px;
  border:none;
  background:transparent;
  color:#fff;
  font-size:18px;
  cursor:pointer;
}

.qty-count {
  flex:1;
  text-align:center;
  color:#fff;
  font-weight:600;
}

.soldout {
  font-size:13px;
  color:#999;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {

  /* Swiper */
  document.querySelectorAll('[data-swiper]').forEach(el => {
    new Swiper(el, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      breakpoints: {
        480: { slidesPerView: 1.5 },
        640: { slidesPerView: 2.5 },
        990: { slidesPerView: 4 },
        1200: { slidesPerView: 5 }
      }
    });
  });

  /* Quantity + Cart Drawer */
  document.querySelectorAll('.qty-atc').forEach(wrapper => {
    const variantId = wrapper.dataset.variantId;
    const minus = wrapper.querySelector('.minus');
    const plus = wrapper.querySelector('.plus');
    const countEl = wrapper.querySelector('.qty-count');

    plus.addEventListener('click', async () => {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      });

      countEl.textContent = parseInt(countEl.textContent) + 1;
      openDrawer();
    });

    minus.addEventListener('click', async () => {
      let qty = parseInt(countEl.textContent);
      if (qty <= 0) return;
      qty--;

      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      });

      countEl.textContent = qty;
      openDrawer();
    });
  });

  function openDrawer() {
    const drawer = document.querySelector('cart-drawer');
    if (drawer) {
      drawer.open();
    } else {
      document.dispatchEvent(new CustomEvent('cart:open', { bubbles:true }));
    }
  }

});
</script>

{% schema %}
{
  "name": "Category Product Rows",
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Rows",
      "blocks": [
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
