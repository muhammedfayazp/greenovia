<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="catprodrows">
  <div class="catprodrows__container page-width">

    {% for block in section.blocks %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank and col.products.size > 0 %}
        
        <script
          src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
          type="module"
          fetchpriority="low"
        ></script>

        <div class="catprodrows__section" {{ block.shopify_attributes }}>
          
          {%- comment -%} Category Header {%- endcomment -%}
          <div class="catprodrows__head">
            <h2 class="catprodrows__title">{{ col.title }}</h2>
            <a href="{{ col.url }}" class="catprodrows__more">
              View all →
            </a>
          </div>

          {%- comment -%} Products Slider {%- endcomment -%}
          <div class="catprodrows__swiper swiper swiper-{{ block.id }}">
            <div class="swiper-wrapper">
              {% for product in col.products limit: 12 %}
                <div class="catprodrows__card swiper-slide">
                  
                  <div class="catprodrows__img-container">
                    <a href="{{ product.url }}" class="catprodrows__img">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.title | escape }}"
                          loading="lazy"
                        >
                      {% endif %}
                    </a>
                    <button type="button" class="catprodrows__heart" aria-label="Add to wishlist" data-product-id="{{ product.id }}">
                      {% render 'icon', icon: 'heart' %}
                    </button>
                  </div>

                  <div class="catprodrows__info">
                    <a href="{{ product.url }}">
                      <h3>{{ product.title }}</h3>
                    </a>

                    <div class="catprodrows__price">
                      {{ product.price | money }}
                    </div>

                    {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}

                    <product-form-component class="catprodrows__form-wrapper" data-section-id="{{ section.id }}" data-product-id="{{ product.id }}">
                      <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                      {%- form 'product', product, id: nil, class: 'catprodrows__form' -%}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" ref="variantId">
                        
                        <div class="catprodrows__actions {% if cart_qty > 0 %}is-active{% endif %}" data-cart-quantity="{{ cart_qty }}">
                          
                          <cart-quantity-selector-component class="catprodrows__qty-selector" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                            <button type="button" class="qty__btn" ref="minusButton">
                              <span class="qty__minus-icon">−</span>
                              <span class="qty__trash-icon">{% render 'icon', icon: 'delete' %}</span>
                            </button>
                            <input 
                              type="number" 
                              name="quantity" 
                              value="{{ cart_qty | at_least: 1 }}" 
                              min="0" 
                              {% if product.selected_or_first_available_variant.quantity_rule.max %}max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"{% endif %}
                              step="{{ product.selected_or_first_available_variant.quantity_rule.increment | default: 1 }}"
                              class="visually-hidden" 
                              ref="quantityInput"
                              data-cart-quantity="{{ cart_qty }}"
                            >
                            <span class="qty__current" ref="quantityDisplay">{{ cart_qty }}</span>
                            <button type="button" class="qty__btn" ref="plusButton">+</button>
                          </cart-quantity-selector-component>

                          <add-to-cart-component class="catprodrows__atc-wrapper">
                            <button type="submit" class="catprodrows__atc-trigger" aria-label="Add to cart" ref="addToCartButton">
                              <span>+</span>
                            </button>
                          </add-to-cart-component>
                        </div>
                      {%- endform -%}
                    </product-form-component>
                  </div>

                </div>
              {% endfor %}
            </div>
          </div>

        </div>
      {% endif %}
    {% endfor %}

  </div>
</section>

<style>
.catprodrows{
  background:#f6f7f2;
  padding: 30px 0 50px;
}
.catprodrows__container{
  padding-left: 24px !important;
  padding-right: 24px !important;
}

/* Each category section */
.catprodrows__section{
  margin-bottom: 50px;
}
.catprodrows__section:last-child{
  margin-bottom: 0;
}

/* Category Header */
.catprodrows__head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom: 26px;
}
.catprodrows__title{
  margin:0;
  font-size: 28px;
  color:#1f3d2b;
}
.catprodrows__more{
  font-size:14px;
  color:#1f3d2b;
  text-decoration:none;
  white-space:nowrap;
}
.catprodrows__more:hover{ text-decoration: underline; }

/* Swiper */
.catprodrows__swiper{ width:100%; }

/* Product Card */
.catprodrows__card{
  height:100%;
  display:flex;
  flex-direction:column;
  background:#fff;
  border-radius:18px;
  overflow:hidden;
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
  transition: transform .25s ease;
}
.catprodrows__card:hover{
  transform: translateY(-4px);
}

/* Image */
.catprodrows__img{
  display:block;
  aspect-ratio: 1/1;
  background:#eee;
}
.catprodrows__img img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* Info */
.catprodrows__info{
  padding: 12px;
  text-align:center;
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}
.catprodrows__info h3{
  margin:0 0 6px;
  font-size:15px;
  font-weight:600;
  color:#1f3d2b;
}
.catprodrows__info a{ text-decoration:none; }

.catprodrows__price{
  font-size:15px;
  margin-bottom: 10px;
  color:#1f3d2b;
  font-weight:500;
}

/* Image Container */
.catprodrows__img-container {
  position: relative;
  overflow: hidden;
}

/* Heart Icon */
.catprodrows__heart {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 32px;
  height: 32px;
  background: #fff;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  cursor: pointer;
  z-index: 2;
  transition: transform 0.2s ease;
  padding: 0;
  color: #1f3d2b;
}
.catprodrows__heart:hover { transform: scale(1.1); }
.catprodrows__heart svg { width: 18px; height: 18px; stroke-width: 1.5; }
.catprodrows__heart.is-active { color: #ff3b30; }

/* Actions & Buttons */
.catprodrows__actions {
  position: relative;
  display: flex;
  justify-content: flex-end;
  height: 40px;
}

.catprodrows__atc-trigger {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1f3d2b;
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

.catprodrows__qty-selector {
  position: absolute;
  right: 0;
  top: 0;
  height: 40px;
  width: 40px;
  background: #1f3d2b;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4px;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing: border-box;
}

.catprodrows__actions.is-active .catprodrows__atc-wrapper {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.8);
}

.catprodrows__actions.is-active .catprodrows__qty-selector {
  width: 100%;
  opacity: 1;
  pointer-events: auto;
}

.catprodrows__qty-selector .qty__btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  padding: 0;
}

.catprodrows__qty-selector .qty__trash-icon {
  display: none;
}

.catprodrows__actions[data-cart-quantity="1"] .qty__minus-icon {
  display: none;
}

.catprodrows__actions[data-cart-quantity="1"] .qty__trash-icon {
  display: flex;
}

.catprodrows__qty-selector .qty__btn svg { width: 14px; height: 14px; }

.catprodrows__qty-selector .qty__current {
  color: #fff;
  font-weight: 600;
  font-size: 16px;
}

/* Mobile */
@media (max-width: 768px){
  .catprodrows__container{
    padding-left: 16px !important;
    padding-right: 16px !important;
  }
  .catprodrows__card{
    max-width: 260px;
  }
  .catprodrows__title{ font-size:24px; }
  .catprodrows__section{
    margin-bottom: 40px;
  }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Initialize each category slider
  {% for block in section.blocks %}
    {% assign col = collections[block.settings.collection] %}
    {% if col != blank and col.products.size > 0 %}
      new Swiper('.swiper-{{ block.id }}', {
        slidesPerView: 1.2,
        spaceBetween: 16,
        grabCursor: true,
        freeMode: true,
        breakpoints: {
          480: { slidesPerView: 1.5 },
          640: { slidesPerView: 2.5 },
          990: { slidesPerView: 4, freeMode: false },
          1200: { slidesPerView: 5, freeMode: false }
        }
      });
    {% endif %}
  {% endfor %}

  // Bridge Logic for syncing theme components with custom UI
  const themeEvents = {
    cartUpdate: 'cart:update',
    qtyUpdate: 'quantity-selector:update'
  };

  // 1. Sync all cards when cart is updated globally
  document.addEventListener(themeEvents.cartUpdate, (event) => {
    const cart = event.detail.resource;
    if (!cart || !cart.items) return;

    document.querySelectorAll('.catprodrows__form-wrapper').forEach(wrapper => {
      const variantId = wrapper.querySelector('[ref="variantId"]')?.value;
      if (!variantId) return;

      const item = cart.items.find(i => i.variant_id.toString() === variantId.toString());
      const qty = item ? item.quantity : 0;
      
      const actions = wrapper.querySelector('.catprodrows__actions');
      const display = wrapper.querySelector('.qty__current');
      const input = wrapper.querySelector('quantity-selector-component input');

      if (actions) {
        actions.dataset.cartQuantity = qty;
        actions.classList.toggle('is-active', qty > 0);
      }
      if (display) display.textContent = qty;
      if (input) {
        input.dataset.cartQuantity = qty;
        input.value = qty > 0 ? qty : 1; // Keep input at 1 for next add if removed
      }
    });
  });

  // 2. Handle immediate updates from quantity selectors in this section
  document.addEventListener(themeEvents.qtyUpdate, async (event) => {
    const qtySelector = event.target.closest('cart-quantity-selector-component');
    if (!qtySelector || !qtySelector.closest('.catprodrows')) return;

    const wrapper = qtySelector.closest('.catprodrows__form-wrapper');
    const variantId = wrapper.querySelector('[ref="variantId"]')?.value;
    const quantity = event.detail.quantity;
    const display = qtySelector.querySelector('[ref="quantityDisplay"]');
    
    // Optimistic UI update for the display text
    if (display) display.textContent = quantity;

    // Trigger cart change
    const res = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ 
        id: variantId.toString(), 
        quantity: quantity,
        sections_url: window.location.pathname
      })
    });
    const cart = await res.json();

    // Re-dispatch standard theme event to update header/drawer
    document.dispatchEvent(new CustomEvent(themeEvents.cartUpdate, {
      bubbles: true,
      detail: {
        resource: cart,
        data: {
          itemCount: 0, // Using 0 because we just want to trigger a refresh without adding delta
          source: 'catprodrows-bridge'
        }
      }
    }));
  });

  // Favorite toggle (remains as is)
  document.querySelectorAll('.catprodrows__heart').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('is-active');
    });
  });
});
</script>

{% schema %}
{
  "name": "Category Product Rows",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Rows",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
