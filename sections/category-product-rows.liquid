<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<style>
/* CRITICAL LOAD CSS - STABLE LAYOUT */
.catprodrows {
  padding: 60px 0;
  background: #f6f7f2;
  opacity: 0;
  transition: opacity 0.4s ease;
}
.catprodrows.is-visible { opacity: 1; }

.catprodrows__container {
  padding-left: 20px !important;
  padding-right: 20px !important;
  max-width: 1400px;
  margin: 0 auto;
}

.catprodrows__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24px;
}
.catprodrows__title {
  margin: 0;
  font-size: 32px;
  color: #1f3d2b;
}
.catprodrows__more {
  color: #1f3d2b;
  text-decoration: none;
  font-weight: 500;
}

.catprodrows__swiper { 
  overflow: hidden; 
}

.catprodrows__swiper .swiper-wrapper {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
}
.catprodrows__card {
  flex: 0 0 calc(20% - 20px) !important;
  min-width: 240px !important;
  background: #fff;
  border-radius: 18px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
}
.catprodrows__img {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #f0f0f0;
  overflow: hidden;
}
.catprodrows__img img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

.catprodrows__info {
  padding: 12px;
  display: flex;
  flex-direction: column;
}
.catprodrows__vendor {
  font-size: 11px;
  text-transform: uppercase;
  color: #777;
  letter-spacing: 0.5px;
  margin-bottom: 2px;
}
.catprodrows__name {
  font-size: 15px;
  font-weight: 600;
  color: #1f3d2b;
  text-decoration: none;
  line-height: 1.3;
  margin-bottom: 8px;
}
.catprodrows__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  gap: 8px;
}
.catprodrows__price {
  font-size: 16px;
  font-weight: 700;
  color: #1f3d2b;
}

/* Actions & Buttons */
.catprodrows__actions {
  position: relative;
  display: flex;
  justify-content: flex-end;
  height: 40px;
}
.catprodrows__atc-trigger {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1f3d2b;
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.catprodrows__atc-trigger svg { width: 20px; height: 20px; }

.catprodrows__qty-selector {
  position: absolute;
  right: 0;
  top: 0;
  height: 40px;
  background: #1f3d2b;
  border-radius: 20px;
  display: flex;
  align-items: center;
  padding: 0 4px;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}
.catprodrows__actions.is-active .catprodrows__qty-selector {
  opacity: 1;
  pointer-events: auto;
  min-width: 105px;
}
.catprodrows__actions.is-active .catprodrows__atc-wrapper { opacity: 0; pointer-events: none; }

.catprodrows__qty-selector .qty__btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.catprodrows__qty-selector .qty__current {
  color: #fff;
  font-weight: 700;
  padding: 0 8px;
}

@media (max-width: 990px) {
  .catprodrows__card {
    flex: 0 0 70% !important;
    min-width: 260px !important;
  }
  .catprodrows__title { font-size: 24px; }
}
</style>

<section class="catprodrows">
  <div class="catprodrows__container page-width">

    {%- if section.blocks.size > 0 -%}
      <script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
    {%- endif -%}

    {% for block in section.blocks %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank and col.products.size > 0 %}
        <div class="catprodrows__section" {{ block.shopify_attributes }}>
              
              <div class="catprodrows__head">
                <h2 class="catprodrows__title">{{ col.title }}</h2>
                <a href="{{ col.url }}" class="catprodrows__more">View all →</a>
              </div>

              <div class="catprodrows__swiper swiper swiper-{{ block.id }}">
                <div class="swiper-wrapper">
                  {% for product in col.products limit: 12 %}
                    {% if product.available %}
                    <div class="catprodrows__card swiper-slide">
                      
                      <div class="catprodrows__img-container">
                        <a href="{{ product.url }}" class="catprodrows__img">
                          {% if product.featured_image %}
                            <img
                              src="{{ product.featured_image | image_url: width: 400 }}"
                              alt="{{ product.title | escape }}"
                              loading="lazy"
                            >
                          {% endif %}
                        </a>
                      </div>

                      <div class="catprodrows__info">
                        <div class="catprodrows__vendor">{{ product.vendor }}</div>
                        <a href="{{ product.url }}" class="catprodrows__name">{{ product.title }}</a>
                        
                        <div class="catprodrows__bottom">
                          <div class="catprodrows__price">
                            {{ product.price | money }}
                          </div>

                          {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}

                          <product-form-component class="catprodrows__form-wrapper" data-section-id="{{ section.id }}" data-product-id="{{ product.id }}" on:submit="/handleSubmit">
                            <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                            {%- form 'product', product, id: nil, class: 'catprodrows__form' -%}
                              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" ref="variantId">
                              
                              <div class="catprodrows__actions {% if cart_qty > 0 %}is-active{% endif %}" data-cart-quantity="{{ cart_qty }}">
                              
                                <cart-quantity-selector-component class="catprodrows__qty-selector" data-variant-id="{{ product.selected_or_first_available_variant.id }}" ref="quantitySelector">
                                  <button type="button" class="qty__btn" ref="minusButton" on:click="/decreaseQuantity">
                                    <span class="qty__minus-icon">{{ 'icon-minus.svg' | inline_asset_content }}</span>
                                    <span class="qty__trash-icon">{{ 'icon-delete.svg' | inline_asset_content }}</span>
                                  </button>
                                  <input 
                                    type="number" 
                                    name="quantity" 
                                    value="{{ cart_qty | at_least: 1 }}" 
                                    min="0" 
                                    {% if product.selected_or_first_available_variant.quantity_rule.max %}max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"{% endif %}
                                    step="{{ product.selected_or_first_available_variant.quantity_rule.increment | default: 1 }}"
                                    class="visually-hidden" 
                                    ref="quantityInput"
                                    data-cart-quantity="{{ cart_qty }}"
                                    on:blur="/setQuantity"
                                    on:focus="/selectInputValue"
                                  >
                                  <span class="qty__current" ref="quantityDisplay">{{ cart_qty }}</span>
                                  <button type="button" class="qty__btn" ref="plusButton" on:click="/increaseQuantity">{{ 'icon-plus.svg' | inline_asset_content }}</button>
                                </cart-quantity-selector-component>

                                <add-to-cart-component class="catprodrows__atc-wrapper">
                                  <button type="submit" class="catprodrows__atc-trigger" aria-label="Add to cart" ref="addToCartButton">
                                    {{ 'icon-add-to-cart.svg' | inline_asset_content }}
                                  </button>
                                </add-to-cart-component>
                              </div>
                            {%- endform -%}
                          </product-form-component>
                        </div>
                      </div>

                    </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>

            </div>
          {% endif %}
        {% endfor %}

  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Initialize each category slider
  {% for block in section.blocks %}
    {% assign col = collections[block.settings.collection] %}
    {% if col != blank and col.products.size > 0 %}
      const swiper = new Swiper('.swiper-{{ block.id }}', {
        slidesPerView: 1.2,
        spaceBetween: 16,
        grabCursor: true,
        freeMode: true,
        breakpoints: {
          480: { slidesPerView: 1.5 },
          640: { slidesPerView: 2.5 },
          990: { slidesPerView: 4, freeMode: false },
          1200: { slidesPerView: 5, freeMode: false }
        }
      });
      // Show section after Swiper is ready
      document.querySelectorAll('.catprodrows').forEach(s => s.classList.add('is-visible'));
    {% endif %}
  {% endfor %}

  // Bridge Logic for syncing theme components with custom UI
  const themeEvents = {
    cartUpdate: 'cart:update',
    qtyUpdate: 'quantity-selector:update'
  };

  // 1. Sync all cards when cart is updated globally
  document.addEventListener(themeEvents.cartUpdate, async (event) => {
    let cart = event.detail.resource;
    if (!cart || !cart.items) {
      const res = await fetch('/cart.js');
      cart = await res.json();
    }
    if (!cart || !cart.items) return;

    document.querySelectorAll('.catprodrows__form-wrapper').forEach(wrapper => {
      const variantId = wrapper.querySelector('[ref="variantId"]')?.value;
      if (!variantId) return;

      const item = cart.items.find(i => i.variant_id.toString() === variantId.toString());
      const qty = item ? item.quantity : 0;
      
      const actions = wrapper.querySelector('.catprodrows__actions');
      const display = wrapper.querySelector('.qty__current');
      const input = wrapper.querySelector('cart-quantity-selector-component input');

      if (actions) {
        actions.dataset.cartQuantity = qty;
        actions.classList.toggle('is-active', qty > 0);
      }
      if (display) display.textContent = qty;
      if (input) {
        input.dataset.cartQuantity = qty;
        input.value = qty > 0 ? qty : 1; // Keep input at 1 for next add if removed
      }
    });
  });

  // 2. Handle immediate updates from quantity selectors in this section
  document.addEventListener(themeEvents.qtyUpdate, async (event) => {
    const qtySelector = event.target.closest('cart-quantity-selector-component');
    if (!qtySelector || !qtySelector.closest('.catprodrows')) return;

    const wrapper = qtySelector.closest('.catprodrows__form-wrapper');
    const variantId = wrapper.querySelector('[ref="variantId"]')?.value;
    const quantity = event.detail.quantity;
    const display = qtySelector.querySelector('[ref="quantityDisplay"]');
    
    // Optimistic UI update for the display text
    if (display) display.textContent = quantity;

    try {
      // Trigger cart change
      const res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          id: variantId.toString(), 
          quantity: quantity,
          sections_url: window.location.pathname
        })
      });
      const cart = await res.json();

      // Dispatch cart:update with forced cart-icon refresh
      const updateEvent = new CustomEvent(themeEvents.cartUpdate, {
        bubbles: true,
        detail: {
          resource: cart,
          data: {
            itemCount: cart.item_count,
            source: 'catprodrows'
          }
        }
      });
      document.dispatchEvent(updateEvent);

      // Sync all product cards on the page
      document.querySelectorAll('.catprodrows__actions').forEach(actions => {
        const vIdInput = actions.closest('product-form-component')?.querySelector('[name="id"]');
        const vId = vIdInput?.value;
        if (!vId) return;
        
        const item = cart.items.find(i => i.variant_id.toString() === vId.toString());
        const qty = item ? item.quantity : 0;
        
        actions.dataset.cartQuantity = qty;
        const display = actions.querySelector('.qty__current');
        if (display) display.textContent = qty;
        
        if (qty > 0) {
          actions.classList.add('is-active');
        } else {
          actions.classList.remove('is-active');
        }
      });
    } catch (e) {
      console.error('Cart update failed', e);
    }
  });

  // Handle successful ATCs from product-form.js too
  document.addEventListener('cart:update', async (event) => {
    if (event.detail?.data?.source === 'catprodrows') return;
    
    // If update came from elsewhere, sync our cards
    // Use the resource if available, otherwise fetch
    let cart = event.detail?.resource;
    if (!cart || !cart.items) {
      const res = await fetch('/cart.js');
      cart = await res.json();
    }
    
    document.querySelectorAll('.catprodrows__actions').forEach(actions => {
      const vIdInput = actions.closest('product-form-component')?.querySelector('[name="id"]');
      const vId = vIdInput?.value;
      if (!vId) return;
      const item = cart.items.find(i => i.variant_id.toString() === vId.toString());
      const qty = item ? item.quantity : 0;
      actions.dataset.cartQuantity = qty;
      const display = actions.querySelector('.qty__current');
      if (display) display.textContent = qty;
      if (qty > 0) actions.classList.add('is-active');
      else actions.classList.remove('is-active');
    });
  });

  // Wishlist functionality (keeping for future use if needed)
});
</script>

{% schema %}
{
  "name": "Category Product Rows",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Rows",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}