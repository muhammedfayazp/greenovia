<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="catprodrows">
  <div class="catprodrows__container page-width">

    {% for block in section.blocks %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank and col.products.size > 0 %}

        <div class="catprodrows__section" {{ block.shopify_attributes }}>
          
          <div class="catprodrows__head">
            <h2 class="catprodrows__title">{{ col.title }}</h2>
            <a href="{{ col.url }}" class="catprodrows__more">View all →</a>
          </div>

          <div class="swiper catprodrows__swiper" data-swiper>
            <div class="swiper-wrapper">

              {% for product in col.products limit: 12 %}
                <div class="swiper-slide catprodrows__card">

                  <a href="{{ product.url }}" class="catprodrows__img">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy' }}
                    {% endif %}
                  </a>

                  <div class="catprodrows__info">
                    <div class="catprodrows__vendor">{{ product.vendor }}</div>

                    <a href="{{ product.url }}" class="catprodrows__name">
                      {{ product.title }}
                    </a>

                    <div class="catprodrows__bottom">
                      <span class="catprodrows__price">
                        {{ product.price | money }}
                      </span>

                      {% if product.available %}
                        <form method="post" action="/cart/add">
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          <button type="submit" class="catprodrows__atc">
                            Add
                          </button>
                        </form>
                      {% else %}
                        <span class="catprodrows__soldout">Sold out</span>
                      {% endif %}
                    </div>
                  </div>

                </div>
              {% endfor %}

            </div>
          </div>

        </div>

      {% endif %}
    {% endfor %}

  </div>
</section>

<style>
.catprodrows {
  padding: 60px 0;
  background: #f6f7f2;
}

.catprodrows__container {
  max-width: 1400px;
  margin: auto;
  padding: 0 20px;
}

.catprodrows__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.catprodrows__title {
  font-size: 28px;
  color: #1f3d2b;
  margin: 0;
}

.catprodrows__more {
  color: #1f3d2b;
  text-decoration: none;
  font-weight: 500;
}

.catprodrows__swiper {
  padding-bottom: 10px;
}

.catprodrows__card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
  display: flex;
  flex-direction: column;
}

.catprodrows__img img {
  width: 100%;
  height: auto;
  display: block;
}

.catprodrows__info {
  padding: 12px;
}

.catprodrows__vendor {
  font-size: 11px;
  text-transform: uppercase;
  color: #777;
  margin-bottom: 4px;
}

.catprodrows__name {
  font-size: 15px;
  font-weight: 600;
  color: #1f3d2b;
  text-decoration: none;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.catprodrows__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
}

.catprodrows__price {
  font-weight: 700;
  font-size: 16px;
  color: #1f3d2b;
}

.catprodrows__atc {
  background: #1f3d2b;
  color: #fff;
  border: none;
  padding: 6px 14px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 13px;
}

.catprodrows__atc:hover {
  background: #2a523a;
}

.catprodrows__soldout {
  font-size: 13px;
  color: #999;
}

@media (max-width: 768px) {
  .catprodrows__title {
    font-size: 22px;
  }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('[data-swiper]').forEach(swiperEl => {
    new Swiper(swiperEl, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      breakpoints: {
        480: { slidesPerView: 1.5 },
        640: { slidesPerView: 2.5 },
        990: { slidesPerView: 4 },
        1200: { slidesPerView: 5 }
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Category Product Rows",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Rows",
      "blocks": [
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
