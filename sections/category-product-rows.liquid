<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="catprodrows">
  <div class="catprodrows__container page-width">

    {% for block in section.blocks %}
      {% assign col = collections[block.settings.collection] %}
      {% if col != blank and col.products.size > 0 %}
        
        <div class="catprodrows__section" {{ block.shopify_attributes }}>
          
          {%- comment -%} Category Header {%- endcomment -%}
          <div class="catprodrows__head">
            <h2 class="catprodrows__title">{{ col.title }}</h2>
            <a href="{{ col.url }}" class="catprodrows__more">
              View all →
            </a>
          </div>

          {%- comment -%} Products Slider {%- endcomment -%}
          <div class="catprodrows__swiper swiper swiper-{{ block.id }}">
            <div class="swiper-wrapper">
              {% for product in col.products limit: 12 %}
                <div class="catprodrows__card swiper-slide">
                  
                  <div class="catprodrows__img-container">
                    <a href="{{ product.url }}" class="catprodrows__img">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.title | escape }}"
                          loading="lazy"
                        >
                      {% endif %}
                    </a>
                    <button type="button" class="catprodrows__heart" aria-label="Add to wishlist" data-product-id="{{ product.id }}">
                      {% render 'icon', icon: 'heart' %}
                    </button>
                  </div>

                  <div class="catprodrows__info">
                    <a href="{{ product.url }}">
                      <h3>{{ product.title }}</h3>
                    </a>

                    <div class="catprodrows__price">
                      {{ product.price | money }}
                    </div>

                    {%- assign cart_qty = 0 -%}
                    {%- for item in cart.items -%}
                      {%- if item.variant_id == product.selected_or_first_available_variant.id -%}
                        {%- assign cart_qty = item.quantity -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}

                    <product-form class="catprodrows__form-wrapper" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                      <div class="catprodrows__actions {% if cart_qty > 0 %}is-active{% endif %}">
                        <div class="catprodrows__qty-selector">
                          <button type="button" class="qty__btn" data-action="minus">{% if cart_qty == 1 %}{% render 'icon', icon: 'delete' %}{% else %}−{% endif %}</button>
                          <span class="qty__current">{{ cart_qty }}</span>
                          <button type="button" class="qty__btn" data-action="plus">+</button>
                        </div>
                        
                        <button type="button" class="catprodrows__atc-trigger" aria-label="Add to cart">
                          <span>+</span>
                        </button>
                      </div>
                    </product-form>
                  </div>

                </div>
              {% endfor %}
            </div>
          </div>

        </div>
      {% endif %}
    {% endfor %}

  </div>
</section>

<style>
.catprodrows{
  background:#f6f7f2;
  padding: 30px 0 50px;
}
.catprodrows__container{
  padding-left: 24px !important;
  padding-right: 24px !important;
}

/* Each category section */
.catprodrows__section{
  margin-bottom: 50px;
}
.catprodrows__section:last-child{
  margin-bottom: 0;
}

/* Category Header */
.catprodrows__head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom: 26px;
}
.catprodrows__title{
  margin:0;
  font-size: 28px;
  color:#1f3d2b;
}
.catprodrows__more{
  font-size:14px;
  color:#1f3d2b;
  text-decoration:none;
  white-space:nowrap;
}
.catprodrows__more:hover{ text-decoration: underline; }

/* Swiper */
.catprodrows__swiper{ width:100%; }

/* Product Card */
.catprodrows__card{
  height:100%;
  display:flex;
  flex-direction:column;
  background:#fff;
  border-radius:18px;
  overflow:hidden;
  box-shadow: 0 6px 18px rgba(0,0,0,.08);
  transition: transform .25s ease;
}
.catprodrows__card:hover{
  transform: translateY(-4px);
}

/* Image */
.catprodrows__img{
  display:block;
  aspect-ratio: 1/1;
  background:#eee;
}
.catprodrows__img img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* Info */
.catprodrows__info{
  padding: 12px;
  text-align:center;
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}
.catprodrows__info h3{
  margin:0 0 6px;
  font-size:15px;
  font-weight:600;
  color:#1f3d2b;
}
.catprodrows__info a{ text-decoration:none; }

.catprodrows__price{
  font-size:15px;
  margin-bottom: 10px;
  color:#1f3d2b;
  font-weight:500;
}

/* Image Container */
.catprodrows__img-container {
  position: relative;
  overflow: hidden;
}

/* Heart Icon */
.catprodrows__heart {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 32px;
  height: 32px;
  background: #fff;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  cursor: pointer;
  z-index: 2;
  transition: transform 0.2s ease;
  padding: 0;
  color: #1f3d2b;
}
.catprodrows__heart:hover { transform: scale(1.1); }
.catprodrows__heart svg { width: 18px; height: 18px; stroke-width: 1.5; }
.catprodrows__heart.is-active { color: #ff3b30; }

/* Actions & Buttons */
.catprodrows__actions {
  position: relative;
  display: flex;
  justify-content: flex-end;
  height: 40px;
}

.catprodrows__atc-trigger {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #1f3d2b;
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

.catprodrows__qty-selector {
  position: absolute;
  right: 0;
  top: 0;
  height: 40px;
  width: 40px;
  background: #1f3d2b;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4px;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing: border-box;
}

.catprodrows__actions.is-active .catprodrows__atc-trigger {
  opacity: 0;
  pointer-events: none;
  transform: scale(0.8);
}

.catprodrows__actions.is-active .catprodrows__qty-selector {
  width: 100%;
  opacity: 1;
  pointer-events: auto;
}

.catprodrows__qty-selector .qty__btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.catprodrows__qty-selector .qty__btn svg { width: 14px; height: 14px; }

.catprodrows__qty-selector .qty__current {
  color: #fff;
  font-weight: 600;
  font-size: 16px;
}

/* Mobile */
@media (max-width: 768px){
  .catprodrows__container{
    padding-left: 16px !important;
    padding-right: 16px !important;
  }
  .catprodrows__card{
    max-width: 260px;
  }
  .catprodrows__title{ font-size:24px; }
  .catprodrows__section{
    margin-bottom: 40px;
  }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Initialize each category slider
  {% for block in section.blocks %}
    {% assign col = collections[block.settings.collection] %}
    {% if col != blank and col.products.size > 0 %}
      new Swiper('.swiper-{{ block.id }}', {
        slidesPerView: 1.2,
        spaceBetween: 16,
        grabCursor: true,
        freeMode: true,
        breakpoints: {
          480: { slidesPerView: 1.5 },
          640: { slidesPerView: 2.5 },
          990: { slidesPerView: 4, freeMode: false },
          1200: { slidesPerView: 5, freeMode: false }
        }
      });
    {% endif %}
  {% endfor %}

  // Noon-style ATC Logic
  const updateCart = async (variantId, quantity) => {
    const res = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId.toString(), quantity: quantity })
    });
    return res.json();
  };

  const addCart = async (variantId) => {
    const res = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
    });
    return res.json();
  };
  
// Example of the updated dispatch logic
document.dispatchEvent(new CustomEvent('cart:update', {
  bubbles: true,
  detail: {
    resource: cart,
    data: {
      itemCount: cart.item_count
    }
  }
}));
  document.querySelectorAll('.catprodrows__form-wrapper').forEach(wrapper => {
    const variantId = wrapper.dataset.variantId;
    const actions = wrapper.querySelector('.catprodrows__actions');
    const trigger = wrapper.querySelector('.catprodrows__atc-trigger');
    const display = wrapper.querySelector('.qty__current');
    const minusBtn = wrapper.querySelector('[data-action="minus"]');

    trigger?.addEventListener('click', async () => {
      actions.classList.add('is-active');
      display.textContent = '1';
      await addCart(variantId);
      // Trigger global cart update if needed
      document.dispatchEvent(new CustomEvent('cart:updated'));
    });

    wrapper.addEventListener('click', async (e) => {
      const btn = e.target.closest('.qty__btn');
      if (!btn) return;

      let current = parseInt(display.textContent);
      const action = btn.dataset.action;

      if (action === 'plus') {
        current++;
      } else {
        current = Math.max(0, current - 1);
      }

      display.textContent = current;
      
      // Update minus button icon if it becomes 0 or 1
      if(current <= 1) {
        minusBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6"/></svg>';
      } else {
        minusBtn.innerHTML = '−';
      }

      if (current === 0) {
        actions.classList.remove('is-active');
      }

      await updateCart(variantId, current);
      document.dispatchEvent(new CustomEvent('cart:updated'));
    });
  });

  // Favorite toggle
  document.querySelectorAll('.catprodrows__heart').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('is-active');
      // Potential wishlist API call here
    });
  });
});
</script>

{% schema %}
{
  "name": "Category Product Rows",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Product Rows",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
