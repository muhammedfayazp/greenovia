{% stylesheet %}
*, *::before, *::after { box-sizing: border-box; }

.gvs-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 40px;
}

.gvs-section-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #1f3d2b;
  margin-bottom: 20px;
}

/* ===== HERO ===== */
.gvs-hero {
  background: #0d2b1a;
  padding: 120px 40px 100px;
  position: relative;
  overflow: hidden;
}

.gvs-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 70% 50%, rgba(45,110,71,0.3) 0%, transparent 70%);
  pointer-events: none;
}

.gvs-hero__inner {
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.gvs-hero .gvs-section-label {
  color: rgba(255,255,255,0.45);
  margin-bottom: 24px;
}

.gvs-hero__title {
  font-family: 'Lora', 'Georgia', serif;
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 400;
  color: #fff;
  line-height: 1.1;
  margin: 0 0 24px;
  letter-spacing: -0.02em;
}

.gvs-hero__sub {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  color: rgba(255,255,255,0.65);
  max-width: 520px;
  line-height: 1.7;
  margin: 0 0 40px;
}

.gvs-hero__cta {
  display: inline-block;
  padding: 14px 32px;
  background: #fff;
  color: #0d2b1a;
  border-radius: 999px;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.15s ease;
}

.gvs-hero__cta:hover {
  background: #e8f5ee;
  transform: translateY(-2px);
}

.gvs-hero__scroll-line {
  width: 1px;
  height: 60px;
  background: rgba(255,255,255,0.2);
  margin: 64px 0 0;
}

/* ===== SERVICES ===== */
.gvs-services {
  padding: 100px 0;
  background: #fff;
}

.gvs-services__title {
  font-family: 'Lora', 'Georgia', serif;
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 400;
  color: #0d2b1a;
  margin: 0 0 72px;
  line-height: 1.2;
}

.gvs-services__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border: 1px solid #e8e4de;
  border-radius: 16px;
  overflow: hidden;
}

.gvs-service-col {
  padding: 48px 40px;
  border-right: 1px solid #e8e4de;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.gvs-service-col:last-child {
  border-right: none;
}

.gvs-service-col__icon {
  width: 52px;
  height: 52px;
  background: #f0f7f3;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f3d2b;
  margin-bottom: 20px;
  flex-shrink: 0;
}

.gvs-service-col__heading {
  font-family: 'Lora', 'Georgia', serif;
  font-size: 1.2rem;
  font-weight: 500;
  color: #0d2b1a;
  margin: 0 0 28px;
  line-height: 1.3;
}

.gvs-service-list {
  list-style: none;
  margin: 0 0 32px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  flex: 1;
}

.gvs-service-list li {
  font-size: 0.9rem;
  color: #4a4a4a;
  line-height: 1.5;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding-top: 14px;
  border-top: 1px solid #f0ede8;
}

.gvs-service-list li:first-child {
  border-top: none;
  padding-top: 0;
}

.gvs-num {
  font-size: 0.7rem;
  font-weight: 700;
  color: #1f3d2b;
  opacity: 0.5;
  letter-spacing: 0.05em;
  flex-shrink: 0;
  margin-top: 2px;
}

.gvs-service-link {
  font-size: 0.85rem;
  font-weight: 600;
  color: #1f3d2b;
  text-decoration: none;
  letter-spacing: 0.02em;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: gap 0.15s ease;
}

.gvs-service-link:hover {
  gap: 8px;
}

/* ===== WHY US ===== */
.gvs-why {
  background: #0d2b1a;
  padding: 100px 0;
}

.gvs-why__title {
  font-family: 'Lora', 'Georgia', serif;
  font-size: clamp(1.8rem, 3vw, 2.75rem);
  font-weight: 400;
  color: #fff;
  margin: 0 0 64px;
  line-height: 1.2;
}

.gvs-why__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}

.gvs-why__item {
  padding: 36px 0 36px;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-right: 40px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.gvs-why__num {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.3);
}

.gvs-why__item p {
  font-size: 0.9375rem;
  color: rgba(255,255,255,0.72);
  line-height: 1.65;
  margin: 0;
}

/* ===== PROCESS ===== */
.gvs-process {
  padding: 100px 0;
  background: #f8f6f2;
}

.gvs-process__title {
  font-family: 'Lora', 'Georgia', serif;
  font-size: clamp(1.8rem, 3vw, 2.75rem);
  font-weight: 400;
  color: #0d2b1a;
  margin: 0 0 64px;
}

.gvs-process__steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
}

.gvs-step {
  padding-right: 32px;
  position: relative;
}

.gvs-step__circle {
  width: 44px;
  height: 44px;
  background: #1f3d2b;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 0.9rem;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}

.gvs-step__line {
  position: absolute;
  top: 22px;
  left: 44px;
  right: 0;
  height: 1px;
  background: #d0c8bc;
}

.gvs-step:last-child .gvs-step__line {
  display: none;
}

.gvs-step h4 {
  font-family: 'Lora', 'Georgia', serif;
  font-size: 1.05rem;
  font-weight: 500;
  color: #0d2b1a;
  margin: 0 0 10px;
}

.gvs-step p {
  font-size: 0.875rem;
  color: #666;
  line-height: 1.65;
  margin: 0;
}

/* ===== CTA ===== */
.gvs-cta {
  background: #1f3d2b;
  padding: 100px 40px;
  text-align: center;
}

.gvs-cta__title {
  font-family: 'Lora', 'Georgia', serif;
  font-size: clamp(2rem, 4vw, 3.25rem);
  font-weight: 400;
  color: #fff;
  margin: 0 0 20px;
  line-height: 1.2;
}

.gvs-cta__sub {
  font-size: 1rem;
  color: rgba(255,255,255,0.65);
  max-width: 480px;
  margin: 0 auto 40px;
  line-height: 1.7;
}

.gvs-cta__btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.gvs-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  border-radius: 999px;
  font-size: 0.9rem;
  font-weight: 700;
  text-decoration: none;
  transition: transform 0.15s ease, opacity 0.15s ease;
  letter-spacing: 0.02em;
}

.gvs-btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

.gvs-btn--white {
  background: #fff;
  color: #0d2b1a;
}

.gvs-btn--outline {
  background: transparent;
  color: #fff;
  border: 1.5px solid rgba(255,255,255,0.4);
}

.gvs-btn--outline:hover {
  border-color: rgba(255,255,255,0.8);
  opacity: 1;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .gvs-hero { padding: 80px 24px 72px; }
  .gvs-wrap { padding: 0 24px; }
  .gvs-services { padding: 72px 0; }
  .gvs-services__grid { grid-template-columns: 1fr; border-radius: 12px; }
  .gvs-service-col { border-right: none; border-bottom: 1px solid #e8e4de; padding: 36px 28px; }
  .gvs-service-col:last-child { border-bottom: none; }
  .gvs-why { padding: 72px 0; }
  .gvs-why__grid { grid-template-columns: 1fr 1fr; }
  .gvs-process { padding: 72px 0; }
  .gvs-process__steps { grid-template-columns: 1fr 1fr; gap: 40px; }
  .gvs-step__line { display: none; }
  .gvs-cta { padding: 72px 24px; }
}

@media (max-width: 600px) {
  .gvs-hero__title { font-size: 2.4rem; }
  .gvs-why__grid { grid-template-columns: 1fr; }
  .gvs-process__steps { grid-template-columns: 1fr; gap: 32px; }
  .gvs-services__title,
  .gvs-why__title,
  .gvs-process__title { margin-bottom: 40px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Greenovia Services",
  "settings": []
}
{% endschema %}
