{% comment %} Greenovia Services Page {% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500&display=swap" rel="stylesheet">

<!-- ===== HERO ===== -->
<section class="gvs-hero">
  <div class="gvs-hero__inner">
    <p class="gvs-label">GREENOVIA GARDEN CENTER</p>
    <h1 class="gvs-hero__title">Built for the UAE.<br>Designed to grow.</h1>
    <p class="gvs-hero__sub">From landscape design to ongoing maintenance, we deliver complete green solutions for homes, villas, offices, and commercial spaces across the UAE.</p>
    <a href="#gvs-services" class="gvs-hero__cta">Explore Our Services</a>
  </div>
  <div class="gvs-hero__scroll-line"></div>
</section>

<!-- ===== SERVICES ===== -->
<section class="gvs-services" id="gvs-services">
  <div class="gvs-wrap">

    <div class="gvs-section-label">WHAT WE DO</div>
    <h2 class="gvs-services__title">One partner.<br>End-to-end green care.</h2>

    <div class="gvs-services__grid">

      <!-- Column 1 -->
      <div class="gvs-service-col">
        <div class="gvs-service-col__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M12 2C7 2 3 7 3 12c0 3 1.5 5.5 4 7v3h10v-3c2.5-1.5 4-4 4-7 0-5-4-10-9-10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M12 2c1 4-1 7-4 9 2 0 5-1 6-4 0 4-2 7-5 8 4 0 8-3 9-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
        <h3 class="gvs-service-col__heading">Landscape Design &amp; Execution</h3>
        <ul class="gvs-service-list">
          <li><span class="gvs-num">001.</span> Garden Design &amp; Consultation</li>
          <li><span class="gvs-num">002.</span> Softscape &amp; Planting</li>
          <li><span class="gvs-num">003.</span> Hardscape, Pathways &amp; Features</li>
          <li><span class="gvs-num">004.</span> Irrigation System Installation</li>
        </ul>
        <a href="/pages/contact" class="gvs-service-link">Get a quote →</a>
      </div>

      <!-- Column 2 -->
      <div class="gvs-service-col">
        <div class="gvs-service-col__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="gvs-service-col__heading">Garden Maintenance</h3>
        <ul class="gvs-service-list">
          <li><span class="gvs-num">001.</span> Annual Maintenance Contracts (AMC)</li>
          <li><span class="gvs-num">002.</span> Lawn Care &amp; Trimming</li>
          <li><span class="gvs-num">003.</span> Seasonal Planting &amp; Replacement</li>
          <li><span class="gvs-num">004.</span> Fertilisation &amp; Pest Control</li>
        </ul>
        <a href="/pages/contact" class="gvs-service-link">Get a quote →</a>
      </div>

      <!-- Column 3 -->
      <div class="gvs-service-col">
        <div class="gvs-service-col__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M7 10c1-2 3-3 5-3s4 1 5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="10" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="gvs-service-col__heading">Plant Supply &amp; Styling</h3>
        <ul class="gvs-service-list">
          <li><span class="gvs-num">001.</span> Wholesale &amp; Bulk Plant Supply</li>
          <li><span class="gvs-num">002.</span> Indoor Plant Styling for Offices &amp; Homes</li>
          <li><span class="gvs-num">003.</span> Green Walls &amp; Vertical Gardens</li>
          <li><span class="gvs-num">004.</span> Corporate &amp; Commercial Plant Programs</li>
        </ul>
        <a href="/pages/contact" class="gvs-service-link">Get a quote →</a>
      </div>

    </div>
  </div>
</section>

<!-- ===== WHY US — DARK ===== -->
<section class="gvs-why">
  <div class="gvs-wrap">
    <div class="gvs-section-label" style="color:rgba(255,255,255,0.45)">WHY GREENOVIA</div>
    <h2 class="gvs-why__title">Why leading clients choose Greenovia.</h2>
    <div class="gvs-why__grid">
      <div class="gvs-why__item">
        <span class="gvs-why__num">01</span>
        <p>UAE-based team with deep knowledge of desert climate growing conditions.</p>
      </div>
      <div class="gvs-why__item">
        <span class="gvs-why__num">02</span>
        <p>End-to-end service — design, supply, install, and maintain under one roof.</p>
      </div>
      <div class="gvs-why__item">
        <span class="gvs-why__num">03</span>
        <p>Proven experience in villas, offices, hotels, and commercial landscapes.</p>
      </div>
      <div class="gvs-why__item">
        <span class="gvs-why__num">04</span>
        <p>Premium-quality plants sourced and inspected before every delivery.</p>
      </div>
      <div class="gvs-why__item">
        <span class="gvs-why__num">05</span>
        <p>Transparent pricing with AMC packages tailored to your property size.</p>
      </div>
      <div class="gvs-why__item">
        <span class="gvs-why__num">06</span>
        <p>Dedicated after-service care — we stand behind every plant we deliver.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="gvs-process">
  <div class="gvs-wrap">
    <div class="gvs-section-label">OUR PROCESS</div>
    <h2 class="gvs-process__title">Simple from start to finish.</h2>
    <div class="gvs-process__steps">
      <div class="gvs-step">
        <div class="gvs-step__circle">1</div>
        <div class="gvs-step__line"></div>
        <h4>Consultation</h4>
        <p>Share your space and goals — we visit, assess, and listen.</p>
      </div>
      <div class="gvs-step">
        <div class="gvs-step__circle">2</div>
        <div class="gvs-step__line"></div>
        <h4>Design &amp; Quote</h4>
        <p>We create a tailored plan with a clear, itemised quote.</p>
      </div>
      <div class="gvs-step">
        <div class="gvs-step__circle">3</div>
        <div class="gvs-step__line"></div>
        <h4>Execution</h4>
        <p>Our team delivers and installs with care and precision.</p>
      </div>
      <div class="gvs-step">
        <div class="gvs-step__circle">4</div>
        <div class="gvs-step__line"></div>
        <h4>Ongoing Care</h4>
        <p>AMC or on-call maintenance — your garden stays green year-round.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="gvs-cta">
  <div class="gvs-wrap">
    <h2 class="gvs-cta__title">Ready to transform your space?</h2>
    <p class="gvs-cta__sub">Get in touch and we'll put together a plan built around your space, budget, and timeline.</p>
    <div class="gvs-cta__btns">
      <a href="/pages/contact" class="gvs-btn gvs-btn--white">Request a Quote</a>
      <a href="https://wa.me/971XXXXXXXXX?text=Hi%20Greenovia%2C%20I'm%20interested%20in%20your%20services!" target="_blank" class="gvs-btn gvs-btn--outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
