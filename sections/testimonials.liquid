<section class="gv-testimonials">
  <div class="gv-testimonials__container page-width">

    <div class="gv-testimonials__header">
      <p class="gv-testimonials__label">What Our Customers Say</p>
      <h2 class="gv-testimonials__heading">Loved by Plant Enthusiasts</h2>
    </div>

    <div class="gv-testimonials__grid">

      <div class="gv-testimonials__card">
        <div class="gv-testimonials__stars">★★★★★</div>
        <p class="gv-testimonials__quote">"My Monstera arrived perfectly packed and so healthy. It's been three months and it's thriving! Greenovia's quality is unmatched in Dubai."</p>
        <div class="gv-testimonials__author">
          <div class="gv-testimonials__avatar">S</div>
          <div>
            <strong>Sara Al Mansoori</strong>
            <span>Dubai, UAE</span>
          </div>
        </div>
      </div>

      <div class="gv-testimonials__card gv-testimonials__card--featured">
        <div class="gv-testimonials__badge">Most Helpful</div>
        <div class="gv-testimonials__stars">★★★★★</div>
        <p class="gv-testimonials__quote">"Ordered 6 plants for my new apartment. All arrived the next day, beautifully wrapped. The plant care card they include is so thoughtful. Will definitely order again!"</p>
        <div class="gv-testimonials__author">
          <div class="gv-testimonials__avatar">R</div>
          <div>
            <strong>Rahul Sharma</strong>
            <span>Abu Dhabi, UAE</span>
          </div>
        </div>
      </div>

      <div class="gv-testimonials__card">
        <div class="gv-testimonials__stars">★★★★★</div>
        <p class="gv-testimonials__quote">"The team gave me expert advice on which plants suit my indoor lighting. My office is now a green paradise. Customer service is top-notch!"</p>
        <div class="gv-testimonials__author">
          <div class="gv-testimonials__avatar">L</div>
          <div>
            <strong>Layla Hassan</strong>
            <span>Sharjah, UAE</span>
          </div>
        </div>
      </div>

    </div>

    <div class="gv-testimonials__stats">
      <div class="gv-testimonials__stat">
        <strong>4.9/5</strong>
        <span>Average Rating</span>
      </div>
      <div class="gv-testimonials__stat-divider"></div>
      <div class="gv-testimonials__stat">
        <strong>2,400+</strong>
        <span>Happy Customers</span>
      </div>
      <div class="gv-testimonials__stat-divider"></div>
      <div class="gv-testimonials__stat">
        <strong>500+</strong>
        <span>Plant Varieties</span>
      </div>
      <div class="gv-testimonials__stat-divider"></div>
      <div class="gv-testimonials__stat">
        <strong>5 Years</strong>
        <span>Serving the UAE</span>
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.gv-testimonials {
  padding: 80px 0;
  background: #ffffff;
}

.gv-testimonials__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.gv-testimonials__header {
  text-align: center;
  margin-bottom: 3rem;
}

.gv-testimonials__label {
  font-size: 0.8125rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #5A7C3E;
  margin: 0 0 0.75rem;
}

.gv-testimonials__heading {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 700;
  color: #1f3d2b;
  margin: 0;
  line-height: 1.2;
}

/* Cards grid */
.gv-testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 4rem;
}

.gv-testimonials__card {
  background: #f8faf5;
  border: 1px solid #e0ebd5;
  border-radius: 20px;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: relative;
  transition: box-shadow 0.25s ease, transform 0.25s ease;
}

.gv-testimonials__card:hover {
  box-shadow: 0 8px 32px rgba(45,80,22,0.10);
  transform: translateY(-3px);
}

.gv-testimonials__card--featured {
  background: #1f3d2b;
  border-color: #1f3d2b;
}

.gv-testimonials__card--featured .gv-testimonials__stars,
.gv-testimonials__card--featured .gv-testimonials__quote {
  color: #fff;
}

.gv-testimonials__card--featured .gv-testimonials__author strong {
  color: #fff;
}

.gv-testimonials__card--featured .gv-testimonials__author span {
  color: rgba(255,255,255,0.6);
}

.gv-testimonials__badge {
  position: absolute;
  top: -12px;
  left: 1.5rem;
  background: #5A7C3E;
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 999px;
}

.gv-testimonials__stars {
  color: #f4b942;
  font-size: 1.125rem;
  letter-spacing: 2px;
}

.gv-testimonials__quote {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: #3d5c33;
  margin: 0;
  flex: 1;
  font-style: italic;
}

.gv-testimonials__author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(0,0,0,0.07);
}

.gv-testimonials__card--featured .gv-testimonials__author {
  border-top-color: rgba(255,255,255,0.15);
}

.gv-testimonials__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #2D5016;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1rem;
  flex-shrink: 0;
}

.gv-testimonials__card--featured .gv-testimonials__avatar {
  background: rgba(255,255,255,0.2);
}

.gv-testimonials__author strong {
  display: block;
  font-size: 0.875rem;
  color: #1f3d2b;
}

.gv-testimonials__author span {
  font-size: 0.75rem;
  color: #6b8a5a;
}

/* Stats row */
.gv-testimonials__stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  background: #1f3d2b;
  border-radius: 20px;
  padding: 2rem;
}

.gv-testimonials__stat {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.gv-testimonials__stat strong {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  color: #fff;
  font-family: 'Playfair Display', serif;
}

.gv-testimonials__stat span {
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.6);
}

.gv-testimonials__stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.15);
}

@media (max-width: 900px) {
  .gv-testimonials__grid {
    grid-template-columns: 1fr 1fr;
  }
  .gv-testimonials__card:last-child {
    grid-column: 1 / -1;
  }
}

@media (max-width: 600px) {
  .gv-testimonials { padding: 48px 0; }
  .gv-testimonials__container { padding: 0 16px; }
  .gv-testimonials__grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .gv-testimonials__card:last-child { grid-column: auto; }
  .gv-testimonials__stats {
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 16px;
  }
  .gv-testimonials__stat-divider { display: none; }
  .gv-testimonials__stat { flex: 0 0 calc(50% - 0.625rem); }
  .gv-testimonials__stat strong { font-size: 1.375rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": []
}
{% endschema %}
