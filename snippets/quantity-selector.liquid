{% stylesheet %}
.quantity-selector-wrapper {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: calc(var(--gap-sm) / 2);

  @media screen and (min-width: 750px) {
    gap: var(--gap-sm);
  }
}

/* MAIN CONTAINER */
.quantity-selector {
  display: flex;
  align-items: center;
  background-color: #124128 !important; /* locked green */
  border-radius: 50px;
  height: 36px;
  min-width: 90px;
  padding: 0 6px;
  overflow: hidden;

  /* prevent all visual effects */
  transition: none !important;
}

/* BUTTONS */
.quantity-selector .button {
  width: 30px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;

  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  outline: none !important;

  color: #ffffff !important;
  cursor: pointer;

  transition: none !important;
}

/* ICONS (SVG + INLINE) */
.quantity-selector .button svg,
.quantity-selector .button .icon-minus,
.quantity-selector .button .icon-plus {
  width: 12px;
  height: 12px;
  fill: #ffffff !important;
  color: #ffffff !important;

  transition: none !important;
}

/* INPUT */
.quantity-selector input {
  width: 30px;
  height: 100%;
  text-align: center;

  border: none !important;
  background: transparent !important;
  box-shadow: none !important;
  outline: none !important;

  font-size: 1.3rem;
  color: #ffffff !important;

  padding: 0;
  margin: 0;

  -moz-appearance: textfield;
}

/* REMOVE NUMBER SPINNERS */
.quantity-selector input::-webkit-outer-spin-button,
.quantity-selector input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* DISABLE ALL HOVER / FOCUS / ACTIVE STATES */
.quantity-selector:hover,
.quantity-selector:focus,
.quantity-selector:active,
.quantity-selector .button:hover,
.quantity-selector .button:focus,
.quantity-selector .button:active,
.quantity-selector input:hover,
.quantity-selector input:focus {
  background-color: #124128 !important;
  color: #ffffff !important;
  box-shadow: none !important;
  outline: none !important;
}

/* DISABLED STATE (OPTIONAL – still same color, just opacity) */
.quantity-selector .button:disabled,
.quantity-selector input:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
{% endstylesheet %}
