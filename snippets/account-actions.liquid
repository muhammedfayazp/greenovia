<div class="account-actions">
  <div class="account-actions__main-menu">
    <header class="account-actions__header">
      <h2
        id="account-drawer-heading"
        class="account-actions__title h5"
      >
        {% if customer and customer.first_name != blank %}
          {{ 'content.account_title_personalized' | t: first_name: customer.first_name }}
        {% else %}
          {{ 'content.account_title' | t }}
        {% endif %}
      </h2>
      {% if customer %}
        <span class="account-actions__email">
          {% if customer.email %}
            {{ customer.email }}
          {% elsif customer.phone %}
            {{ customer.phone }}
          {% endif %}
        </span>
      {% endif %}
    </header>

    {% unless customer %}
      <div
        class="account-actions__sign-ins"
        data-skip-subtree-update="true"
      >
        <script
          src="{{ 'account-login-actions.js' | asset_url }}"
          type="module"
          fetchpriority="low"
        ></script>
        <account-login-actions class="account-actions__shop-login">
          {{ shop | login_button }}
        </account-login-actions>

        <a
          href="{% if request.design_mode %}{{ routes.account_url }}{% else %}{{ routes.storefront_login_url }}{% endif %}"
          class="account-actions__link button"
        >
          <span class="account-actions__sign-in-text">
            {{ 'actions.sign_in_options' | t }}
          </span>
          <span class="account-actions__fallback-text">
            {{ 'actions.log_in' | t }}
          </span>
        </a>
      </div>
    {% endunless %}

    <nav class="account-actions__nav">
      <ul class="account-actions__list">
        <li class="account-actions__list-item">
          <a
            href="{{ routes.account_url }}"
            class="account-actions__link button-secondary"
          >
            <span
              class="account-actions__icon"
              aria-hidden="true"
            >
              {{- 'icon-orders.svg' | inline_asset_content -}}
            </span>
            {{ 'content.account_orders' | t }}
          </a>
        </li>
        <li class="account-actions__list-item">
          <a
            href="{{ routes.account_addresses_url }}"
            class="account-actions__link button-secondary"
          >
            <span
              class="account-actions__icon"
              aria-hidden="true"
            >
              {{- 'icon-account.svg' | inline_asset_content -}}
            </span>
            {{ 'content.account_profile' | t }}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>

{% stylesheet %}
  .account-actions {
    background-color: var(--color-background);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: height var(--animation-values);

    &:has([data-active]) .account-actions__main-menu {
      visibility: hidden;
    }
  }

  /* Header — subtle green tint strip */
  .account-actions__header {
    padding: 1.25rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px solid #e8f0e0;
    background: #f6faf2;
  }

  .account-actions__title {
    --font-h5--size: var(--font-size--lg);
    margin: 0;
    font-size: 1rem !important;
    font-weight: 700;
    color: #1f3d2b;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .account-actions__email {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    color: #6b8a5a;
    font-size: 0.8125rem;
    max-width: var(--account-actions-max-width);
    word-break: break-all;
  }

  /* Sign-in buttons area */
  .account-actions__sign-ins {
    padding: 1.25rem 1.5rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Override Shop Pay purple button to match brand */
  .account-actions__shop-login {
    --buttons-radius: var(--style-border-radius-buttons-primary);
  }

  .account-actions__shop-login shop-login-button,
  .account-actions__shop-login [type="submit"],
  .account-actions__shop-login button {
    background-color: #1f3d2b !important;
    border-color: #1f3d2b !important;
  }

  /* "Other sign in options" button — outlined style */
  .account-actions__sign-ins > a.button {
    background: transparent !important;
    color: #1f3d2b !important;
    border: 1.5px solid #1f3d2b !important;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0;
  }

  .account-actions__sign-ins > a.button:hover {
    background: #f0f7eb !important;
  }

  .account-actions__sign-in-text {
    display: inline;
  }

  .account-actions__fallback-text {
    display: none;
  }

  .account-actions__sign-ins:not(:has(shop-login-button)) {
    gap: 0;

    .account-actions__sign-in-text { display: none; }
    .account-actions__fallback-text { display: block; }
  }

  /* Nav links (Orders + Profile) */
  .account-actions__nav {
    padding: 0.875rem 1.5rem 1.25rem;
    border-top: 1px solid #e8f0e0;
  }

  .account-actions__list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;

    @media screen and (max-width: 300px) {
      grid-template-columns: 1fr;
    }
  }

  .account-actions__link.button-secondary {
    width: auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    background: #f6faf2 !important;
    border: 1.5px solid #d4e8c4 !important;
    color: #1f3d2b !important;
    border-radius: 10px !important;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.18s ease;
  }

  .account-actions__link.button-secondary:hover {
    background: #e8f3de !important;
    border-color: #5A7C3E !important;
  }

  .account-actions__icon {
    display: flex;
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    margin-block: -4px;
    color: #5A7C3E;
  }

  /* This triggers iOS < 16.4. The outline bug is not recognized as a lack of @supports */

  @supports not (background-color: rgb(from red 150 g b / alpha)) {
    /**
    There is a bug in safari < 16.4 that causes the outline to not follow the elements border radius. This is a workaround.
    Using element selector to increase specificity.
  **/

    .account-actions :is(a.button, a.button-secondary):focus-visible {
      outline: none;
      overflow: visible;
      position: relative;

      &::after {
        content: '';
        position: absolute;
        inset: calc(-1 * var(--focus-outline-offset));
        border: var(--focus-outline-width) solid currentColor;
        border-radius: var(--style-border-radius-buttons-secondary);
        display: inherit;
      }
    }

    .account-actions a.button:focus-visible::after {
      border-color: var(--button-background-color);
      border-radius: var(--style-border-radius-buttons-primary);
    }
  }
{% endstylesheet %}
