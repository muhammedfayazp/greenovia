{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
{%- enddoc -%}

<div class="cart__summary-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart__summary-item cart__original-total">
        <span class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</span>
        <span class="cart__original-total-value cart-secondary-typography">
          {{- cart.original_total_price | money -}}
        </span>
      </span>
      <div class="cart__summary-discounts">
        <ul
          class="discounts list-unstyled"
          role="list"
          aria-label="{{ 'content.discounts' | t }}"
        >
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                <span class="cart__discount-title">{{ discount.title | escape }}</span>
              </span>
              <span class="cart__discount-value cart-secondary-typography"
                >-{{ discount.total_allocated_amount | money -}}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        {% render 'cart-note' %}
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% render 'cart-discount', section_id: section.id %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart__total-container{% if settings.show_installments %} cart__total-container--has-installments{% endif %}">
    <span
      class="cart__summary-item cart__total"
      role="status"
    >
      <span class="cart__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart__summary-item cart__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart__summary-item tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>
</div>

<div class="cart__ctas">
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% endif %}
    form="cart-form"
  >
    {{ 'content.checkout' | t }}
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  /* Cart Actions Container - Minimal Padding */
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-block: 1px solid rgba(0, 0, 0, 0.1);
    padding: 0.75rem 0;
    margin-block-start: 0.5rem;
  }

  .cart-actions__divider {
    border-block-start: 1px solid rgba(0, 0, 0, 0.1);
    margin: 0.25rem 0;
  }

  /* Summary Totals Container */
  .cart__summary-totals {
    padding-bottom: 6rem; /* Space for sticky checkout button */
  }

  .cart__summary-totals:not(:has(.cart-actions)) {
    margin-block-start: 0.5rem;
    border-block-start: 1px solid rgba(0, 0, 0, 0.1);
    padding-block-start: 0.75rem;
  }

  /* Original Total (Subtotal before discounts) */
  .cart__original-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.5rem 0;
  }

  .cart__original-total-label {
    font-size: 15px;
    font-weight: 600;
    color: #000000;
  }

  .cart__original-total-value {
    font-size: 15px;
    font-weight: 700;
    color: #000000;
  }

  /* Discounts Section - HIGH VISIBILITY */
  .cart__summary-discounts {
    margin-top: 0.5rem;
  }

  .discounts {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cart__discount {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.75rem 1rem;
    background: #10b981; /* Solid bright green */
    border: 2px solid #059669;
    border-radius: 8px;
    margin-bottom: 0.5rem;
  }

  .cart__discount:last-child {
    margin-bottom: 0;
  }

  .cart__discount-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 15px;
    font-weight: 700;
    color: #ffffff; /* White text for high contrast */
  }

  .cart__discount-label svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    fill: #ffffff;
  }

  .cart__discount-title {
    line-height: 1.4;
    color: #ffffff;
  }

  .cart__discount-value {
    font-size: 16px;
    font-weight: 800;
    color: #ffffff; /* White for high contrast */
    white-space: nowrap;
    margin-left: 1rem;
  }

  /* Total Container */
  .cart__total-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .cart__total-container--has-installments {
    gap: 0.75rem;
  }

  .cart__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.75rem 0;
    border-top: 2px solid #000000;
  }

  .cart__total-label {
    font-size: 16px;
    font-weight: 700;
    color: #000000;
  }

  .cart__total-value {
    font-size: 22px;
    font-weight: 800;
    color: #000000;
  }

  /* Installments */
  .cart__installments {
    color: #666666;
    font-size: 13px;
    line-height: 1.5;
  }

  /* Tax Note */
  .tax-note {
    font-size: 12px;
    color: #666666;
    line-height: 1.5;
  }

  /* CTAs Container - Sticky Bottom with HIGH VISIBILITY */
  .cart__ctas {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #ffffff;
    padding: 1rem;
    border-top: 2px solid #e5e7eb;
    box-shadow: 0 -6px 20px rgba(0, 0, 0, 0.15);
    z-index: 1000;
  }

  /* Checkout Button - MAXIMUM VISIBILITY */
  .cart__checkout-button {
    background: #10b981; /* Bright solid green */
    color: #ffffff;
    border-radius: 10px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.5px;
    width: 100%;
    padding: 1.125rem 2rem;
    border: 3px solid #059669;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
    text-transform: uppercase;
  }

  .cart__checkout-button:hover:not(:disabled) {
    background: #059669;
    border-color: #047857;
    box-shadow: 0 6px 16px rgba(16, 185, 129, 0.5);
    transform: translateY(-2px);
  }

  .cart__checkout-button:active:not(:disabled) {
    transform: translateY(0);
    box-shadow: 0 3px 8px rgba(16, 185, 129, 0.3);
  }

  .cart__checkout-button:disabled {
    background: #d1d5db;
    color: #9ca3af;
    border-color: #d1d5db;
    cursor: not-allowed;
    box-shadow: none;
  }

  /* Additional Checkout Buttons */
  .additional-checkout-buttons {
    margin-top: 0.75rem;
  }

  .additional-checkout-buttons--vertical {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .cart__total-label {
      font-size: 15px;
    }

    .cart__total-value {
      font-size: 20px;
    }

    .cart__discount-label,
    .cart__discount-value {
      font-size: 14px;
    }

    .cart__checkout-button {
      font-size: 16px;
      padding: 1rem 1.5rem;
    }
  }
{% endstylesheet %}
