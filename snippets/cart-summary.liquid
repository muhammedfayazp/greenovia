{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
{%- enddoc -%}

<div class="cart__summary-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart__summary-item cart__original-total">
        <span class="cart__original-total-label">{{ 'content.cart_subtotal' | t }}</span>
        <span class="cart__original-total-value cart-secondary-typography">
          {{- cart.original_total_price | money -}}
        </span>
      </span>
      <div class="cart__summary-discounts">
        <ul
          class="discounts list-unstyled"
          role="list"
          aria-label="{{ 'content.discounts' | t }}"
        >
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="cart__summary-item cart__discount">
              <span class="cart__discount-label">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                <span class="cart__discount-title">{{ discount.title | escape }}</span>
              </span>
              <span class="cart__discount-value cart-secondary-typography"
                >-{{ discount.total_allocated_amount | money -}}
              </span>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        {% render 'cart-note' %}
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% if settings.show_add_discount_code %}
        {% render 'cart-discount', section_id: section.id %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart__total-container{% if settings.show_installments %} cart__total-container--has-installments{% endif %}">
    <span
      class="cart__summary-item cart__total"
      role="status"
    >
      <span class="cart__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart__summary-item cart__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart__summary-item tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>

  <div class="cart__ctas">
    <button
      type="submit"
      id="checkout"
      class="cart__checkout-button button"
      name="checkout"
      {% if cart == empty %}
        disabled
      {% endif %}
      form="cart-form"
    >
      {{ 'content.checkout' | t }}
    </button>

    {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
      <div
        class="
          additional-checkout-buttons
          {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
        "
      >
        {{ content_for_additional_checkout_buttons }}
      </div>
    {% endif %}
  </div>
</div>

<style>
  /* Cart Actions Container - Minimal Padding */
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-block: 1px solid rgba(var(--color-foreground-rgb), 0.1);
    padding: 0.75rem 0;
    margin-block-start: 0.5rem;
  }

  .cart-actions__divider {
    border-block-start: 1px solid rgba(var(--color-foreground-rgb), 0.1);
    margin: 0.25rem 0;
  }

  /* Summary Totals Container */
  .cart__summary-totals {
    padding-bottom: 1rem;
  }

  .cart__summary-totals:not(:has(.cart-actions)) {
    margin-block-start: 0.5rem;
    border-block-start: 1px solid rgba(var(--color-foreground-rgb), 0.1);
    padding-block-start: 0.75rem;
  }

  /* Original Total (Subtotal before discounts) */
  .cart__original-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.5rem 0;
  }

  .cart__original-total-label {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .cart__original-total-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-foreground);
  }

  /* Discounts Section */
  .cart__summary-discounts {
    margin-top: 0.5rem;
  }

  .discounts {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cart__discount {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(var(--color-primary-rgb), 0.1);
    border: 1px solid var(--color-primary);
    border-radius: var(--style-border-radius-sm);
    margin-bottom: 0.5rem;
  }

  .cart__discount-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .cart__discount-label svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: currentColor;
    fill: none;
  }

  .cart__discount-title {
    line-height: 1.4;
  }

  .cart__discount-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
    margin-left: 1rem;
  }

  /* Total Container */
  .cart__total-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .cart__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 0.75rem 0;
    border-top: 2px solid var(--color-foreground-heading);
  }

  .cart__total-label {
    font-family: var(--font-heading--family);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-foreground-heading);
  }

  .cart__total-value {
    font-family: var(--font-heading--family);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground-heading);
  }

  /* Checkout Button */
  .cart__checkout-button {
    background: var(--color-primary);
    color: white;
    border-radius: var(--style-border-radius-buttons-primary);
    font-size: 1.125rem;
    font-weight: 600;
    width: 100%;
    padding: 1rem 2rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(var(--color-primary-rgb), 0.3);
    text-transform: var(--button-text-case-primary);
  }

  .cart__checkout-button:hover:not(:disabled) {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(var(--color-primary-rgb), 0.4);
  }

  .cart__checkout-button:disabled {
    background: rgba(var(--color-foreground-rgb), 0.1);
    color: rgba(var(--color-foreground-rgb), 0.4);
    cursor: not-allowed;
    box-shadow: none;
  }
</style>

<script>
  // Listen for cart updates and update totals dynamically
  document.addEventListener('cart:updated', function(event) {
    const cart = event.detail;
    
    // Get money format
    const moneyFormat = window.theme && window.theme.moneyFormat ? window.theme.moneyFormat : '{{amount}}';
    
    // Format money helper
    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return 'Dhs.' + (cents / 100).toFixed(2);
    }
    
    // Update estimated total
    const cartTotalValueEl = document.querySelector('.cart__total-value');
    if (cartTotalValueEl && cart.total_price !== undefined) {
      const formattedPrice = formatMoney(cart.total_price);
      cartTotalValueEl.textContent = formattedPrice;
      
      // Also update the text-component value attribute if it exists
      const textComponent = document.querySelector('text-component[ref="cartTotal"]');
      if (textComponent) {
        textComponent.setAttribute('value', formattedPrice);
      }
    }
    
    // Update original total (subtotal) if there are discounts
    const originalTotalEl = document.querySelector('.cart__original-total-value');
    if (originalTotalEl && cart.original_total_price !== undefined) {
      originalTotalEl.textContent = formatMoney(cart.original_total_price);
    }
    
    // Update discount amounts
    if (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length > 0) {
      cart.cart_level_discount_applications.forEach((discount, index) => {
        const discountValueEl = document.querySelectorAll('.cart__discount-value')[index];
        if (discountValueEl) {
          discountValueEl.textContent = '-' + formatMoney(discount.total_allocated_amount);
        }
      });
    }
    
    // Disable/enable checkout button based on cart count
    const checkoutBtn = document.getElementById('checkout');
    if (checkoutBtn) {
      if (cart.item_count === 0) {
        checkoutBtn.disabled = true;
      } else {
        checkoutBtn.disabled = false;
      }
    }
  });
</script>
