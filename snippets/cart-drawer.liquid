{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  id="CartDrawerMain"
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  {%- comment -%} Cart Icon Button {%- endcomment -%}
  <button
    class="button header-actions__action button-unstyled cart-trigger-btn"
    on:click="/open"
    aria-haspopup="dialog"
    aria-label="{{ 'accessibility.cart' | t }}"
    aria-describedby="cart-bubble-text"
    data-testid="cart-drawer-trigger"
  >
    {% render 'cart-icon-component' %}
  </button>

  {%- comment -%} Cart Drawer Dialog {%- endcomment -%}
  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{% endif %}"
    aria-labelledby="{% if cart.empty? %}cart-drawer-heading-empty{% else %}cart-drawer-heading{% endif %}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      {%- if cart.empty? -%}
        {%- comment -%} Empty Cart State {%- endcomment -%}
        <div class="cart-drawer__header">
          <h2 class="cart-drawer__heading" id="cart-drawer-heading-empty">
            <svg class="cart-icon-large" width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 2L7.17 4H3C1.9 4 1 4.9 1 6V18C1 19.1 1.9 20 3 20H21C22.1 20 23 19.1 23 18V6C23 4.9 22.1 4 21 4H16.83L15 2H9Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ 'content.your_cart' | t }}
          </h2>
          <button
            ref="closeButton"
            on:click="#CartDrawerMain/close"
            class="button close-button cart-drawer__close-button button-unstyled"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <div class="cart-drawer__content cart-drawer__content--empty">
          <cart-items-component
            class="cart-items-component"
            data-section-id="{{ section.id }}"
          >
            <div class="empty-cart-illustration">
              <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
                <circle cx="60" cy="60" r="58" fill="#f0f7f4" stroke="#1a5c3a" stroke-width="2"/>
                <path d="M40 45L35 55L35 75C35 76.1 35.9 77 37 77H83C84.1 77 85 76.1 85 75V55L80 45H40Z" fill="#e8f5e9" stroke="#1a5c3a" stroke-width="2"/>
                <path d="M50 55V50C50 44.5 54.5 40 60 40C65.5 40 70 44.5 70 50V55" stroke="#1a5c3a" stroke-width="2" stroke-linecap="round"/>
                <circle cx="60" cy="90" r="3" fill="#1a5c3a"/>
              </svg>
            </div>
            
            <h3 class="empty-cart-heading">
              {{ 'content.your_cart_is_empty' | t }}
            </h3>
            
            <p class="empty-cart-text">
              Start adding your favorite items to your cart!
            </p>
            
            <button 
              class="empty-cart-btn"
              on:click="#CartDrawerMain/close"
            >
              Continue Shopping
            </button>
          </cart-items-component>
        </div>
      {%- else -%}
        {%- comment -%} Cart with Items {%- endcomment -%}
        <div class="cart-drawer__header" id="cart-drawer-header">
          <h2 class="cart-drawer__heading" id="cart-drawer-heading">
            <span class="cart-icon-wrapper">
              <svg class="cart-icon-large" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
                <path d="M3 6h18"></path>
                <path d="M16 10a4 4 0 0 1-8 0"></path>
              </svg>
            </span>
            <span class="cart-heading-text">{{ 'content.cart_title' | t }}</span>
            <span class="cart-count-bubble">
              {%- if cart.item_count < 100 -%}
                <span aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </span>
          </h2>

          <button
            ref="closeButton"
            on:click="#CartDrawerMain/close"
            class="button close-button cart-drawer__close-button button-unstyled"
            aria-label="{{ 'actions.close_dialog' | t }}"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>

        <cart-items-component
          class="cart-items-component"
          data-section-id="{{ section.id }}"
        >
          <div
            class="cart-drawer__content"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 70px;"
          >
            <scroll-hint class="cart-drawer__items">
              {% render 'cart-products', drawer_context: 'drawer' %}
            </scroll-hint>

            <div class="cart-drawer__summary">
              {% render 'cart-summary' %}
            </div>
          </div>
        </cart-items-component>
      {%- endif -%}
    </div>
  </dialog>
</cart-drawer-component>

<style>
/* ==========================================
   MODERN CART DRAWER - GREEN GARDEN THEME
   ========================================== */

:root {
  --cart-drawer-width: 420px;
  --cart-drawer-padding: 20px;
  --cart-drawer-padding-desktop: 24px;
  --cart-header-height: 70px;
  --cart-green: #1a5c3a;
  --cart-green-light: #2d6e47;
  --cart-green-dark: #0d3d26;
  --cart-sage: #9db5a5;
  --cart-cream: #faf8f5;
}

/* ==========================================
   CART DRAWER BASE
   ========================================== */

.cart-items-component {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.cart-drawer__dialog {
  overflow: hidden;
  width: var(--cart-drawer-width);
  max-width: 100vw;
  border-radius: 0;
  border: none;
  box-shadow: 
    -4px 0 24px rgba(0, 0, 0, 0.1),
    -2px 0 12px rgba(0, 0, 0, 0.05);
}

.cart-drawer__inner {
  height: 100%;
  overflow: hidden;
  background: var(--cart-cream);
}

.cart-drawer__content {
  height: calc(100% - var(--header-height));
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  overflow-x: hidden;
}

/* ==========================================
   CART HEADER - MODERN DESIGN
   ========================================== */

.cart-drawer__header {
  background: white !important;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 1.5rem 1.5rem 0.5rem;
  position: sticky;
  top: 0;
  z-index: 100;
  color: #1a5c3a !important;
}

@media screen and (min-width: 750px) {
  .cart-drawer__header {
    padding: var(--cart-drawer-padding-desktop);
  }
}

.cart-drawer__heading {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0;
  color: #1a5c3a;
  font-family: inherit;
}

.cart-icon-large {
  color: #1a5c3a;
  flex-shrink: 0;
}

.cart-heading-text {
  font-family: serif; /* Better if I can use the theme's serif font */
  font-size: 2.75rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.cart-count-bubble {
  font-size: 2.25rem;
  font-weight: 500;
  color: #1a5c3a;
  opacity: 1;
}

/* Close Button - Modern Style */
.cart-drawer__close-button {
  background: none;
  border: none;
  color: #1a5c3a;
  cursor: pointer;
  transition: opacity 0.2s ease;
  padding: 0;
}

.cart-drawer__close-button:hover {
  opacity: 0.7;
  transform: none;
}

.cart-drawer__close-button:active {
  transform: scale(0.95);
}

.cart-drawer__close-button svg {
  color: #1a5c3a;
  stroke-width: 2.5;
}

/* ==========================================
   EMPTY CART STATE - BEAUTIFUL DESIGN
   ========================================== */

.cart-drawer__content--empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px 24px;
  min-height: 400px;
}

.empty-cart-illustration {
  margin-bottom: 24px;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10px);
  }
}

.empty-cart-heading {
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--cart-green-dark);
  margin: 0 0 12px 0;
  letter-spacing: -0.02em;
}

.empty-cart-text {
  font-size: 1rem;
  color: #666;
  margin: 0 0 32px 0;
  line-height: 1.5;
}

.empty-cart-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  background: linear-gradient(135deg, var(--cart-green) 0%, var(--cart-green-dark) 100%);
  color: white;
  font-size: 1rem;
  font-weight: 600;
  border: none;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.25s ease;
  box-shadow: 
    0 4px 12px rgba(26, 92, 58, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  letter-spacing: 0.02em;
}

.empty-cart-btn:hover {
  transform: translateY(-2px);
  box-shadow: 
    0 6px 20px rgba(26, 92, 58, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.15);
}

.empty-cart-btn:active {
  transform: translateY(0);
}

/* ==========================================
   CART ITEMS AREA
   ========================================== */

.cart-drawer__items {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 16px;
  background: white;
}

/* Custom Scrollbar */
.cart-drawer__items::-webkit-scrollbar {
  width: 6px;
}

.cart-drawer__items::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.03);
}

.cart-drawer__items::-webkit-scrollbar-thumb {
  background: rgba(26, 92, 58, 0.3);
  border-radius: 3px;
}

.cart-drawer__items::-webkit-scrollbar-thumb:hover {
  background: rgba(26, 92, 58, 0.5);
}

/* ==========================================
   CART SUMMARY - MODERN STICKY FOOTER
   ========================================== */

.cart-drawer__summary {
  background: white;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  position: sticky;
  bottom: 0;
  z-index: 10;
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.05);
  padding: 20px;
  padding-bottom: 30px; /* Extra space for bottom safe areas/comfort */
}

/* ==========================================
   CART TRIGGER BUTTON (HEADER)
   ========================================== */

.cart-trigger-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.cart-trigger-btn:hover {
  transform: scale(1.05);
}

.cart-trigger-btn:active {
  transform: scale(0.95);
}

/* ==========================================
   MOBILE RESPONSIVE
   ========================================== */

@media screen and (max-width: 749px) {
  :root {
    --cart-drawer-width: 100vw;
    --cart-drawer-padding: 16px;
  }
  
  .cart-drawer__dialog {
    width: 100vw;
    max-width: 100vw;
  }
  
  .cart-drawer__heading {
    font-size: 1.125rem;
    gap: 10px;
  }
  
  .cart-count-bubble {
    width: 28px;
    height: 28px;
    font-size: 0.8rem;
  }
  
  .cart-drawer__close-button {
    width: 36px;
    height: 36px;
  }
  
  .cart-drawer__close-button svg {
    width: 18px;
    height: 18px;
  }
  
  .cart-icon-large {
    width: 20px;
    height: 20px;
  }
  
  .empty-cart-illustration svg {
    width: 100px;
    height: 100px;
  }
  
  .empty-cart-heading {
    font-size: 1.25rem;
  }
  
  .empty-cart-text {
    font-size: 0.9rem;
  }
  
  .empty-cart-btn {
    padding: 12px 28px;
    font-size: 0.95rem;
  }
  
  .cart-drawer__items {
    padding: 12px;
  }
}

@media screen and (max-width: 480px) {
  .cart-drawer__heading {
    font-size: 1rem;
  }
  
  .cart-count-bubble {
    width: 26px;
    height: 26px;
    font-size: 0.75rem;
  }
  
  .empty-cart-content {
    padding: 32px 20px;
  }
  
  .empty-cart-heading {
    font-size: 1.125rem;
  }
}

/* ==========================================
   ANIMATIONS & TRANSITIONS
   ========================================== */

.cart-drawer__dialog[open] {
  animation: slideInRight 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.cart-drawer__dialog.dialog-closing {
  animation: slideOutRight 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

@keyframes slideOutRight {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(100%);
  }
}

/* ==========================================
   ACCESSIBILITY
   ========================================== */

.cart-drawer__close-button:focus-visible,
.empty-cart-btn:focus-visible,
.cart-trigger-btn:focus-visible {
  outline: 2px solid var(--cart-green);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  .cart-drawer__dialog[open],
  .empty-cart-illustration {
    animation: none !important;
  }
  
  * {
    transition-duration: 0.01ms !important;
  }
}

/* ==========================================
   LOADING STATE
   ========================================== */

.cart-drawer__content.loading {
  opacity: 0.6;
  pointer-events: none;
}

.cart-drawer__content.loading::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40px;
  height: 40px;
  border: 3px solid rgba(26, 92, 58, 0.2);
  border-top-color: var(--cart-green);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}
</style>
