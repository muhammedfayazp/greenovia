{% liquid
  assign block_settings = block.settings
%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div
  {{ block.shopify_attributes }}
  class="modern-cart-wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? %}
    {%- comment -%} Empty State {%- endcomment -%}
    <div class="cart-empty-state">
      <div class="cart-empty-backdrop"></div>
      
      <div class="cart-empty-icon-wrapper">
        <div class="cart-empty-icon-circle">
          <svg width="52" height="52" viewBox="0 0 48 48" fill="none" class="cart-empty-icon-svg">
            <path d="M8 16L6 20V38C6 39.1 6.9 40 8 40H40C41.1 40 42 39.1 42 38V20L40 16H8Z" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 16V10C16 7.8 17.8 6 20 6H28C30.2 6 32 7.8 32 10V16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="28" r="1.2" fill="currentColor"/>
          </svg>
        </div>
      </div>

      <div class="cart-empty-content">
        <h1 class="cart-empty-heading">Your cart is empty</h1>
        <p class="cart-empty-text">Discover beautiful items and start building your collection today.</p>
        
        <div class="cart-empty-actions">
          <a
            class="cart-empty-button cart-empty-button--primary"
            href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
          >
            Continue Shopping
          </a>
          <a
            class="cart-empty-button cart-empty-button--secondary"
            href="{{ routes.root_url }}"
          >
            Return Home
          </a>
        </div>
      </div>

      <div class="cart-empty-decoration">
        <div class="cart-empty-decoration-item cart-empty-decoration-item--1"></div>
        <div class="cart-empty-decoration-item cart-empty-decoration-item--2"></div>
        <div class="cart-empty-decoration-item cart-empty-decoration-item--3"></div>
      </div>
    </div>
  {%- else -%}
    {%- comment -%} Cart Items {%- endcomment -%}
    <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">{{- cart.item_count -}}</span>
    
    <form
      action="{{ routes.cart_url }}"
      class="modern-cart-form"
      id="cart-form"
      method="post"
    >
      <div class="modern-cart-items" id="cart-items-container">
        {% for item in cart.items %}
          <div
            class="cart-item"
            ref="cartItemRows[]"
            data-parent-key="{{ item.parent_relationship.parent.key }}"
            data-key="{{ item.key }}"
            data-line-index="{{ item.index }}"
          >
            {%- comment -%} Product Image {%- endcomment -%}
            <div class="cart-item__image-wrapper">
              <a href="{{ item.url }}" class="cart-item__image-link">
                {% if item.image %}
                  <img 
                    src="{{ item.image | image_url: width: 200 }}" 
                    alt="{{ item.product.title | escape }}"
                    class="cart-item__img" 
                    loading="lazy"
                  />
                {% else %}
                  <div class="cart-item__image-placeholder">
                    <svg viewBox="0 0 100 100" fill="none">
                      <rect width="100" height="100" fill="#f8f8f8"/>
                      <path d="M30 40L50 60L70 40M50 30V70" stroke="#d0d0d0" stroke-width="2"/>
                    </svg>
                  </div>
                {% endif %}
              </a>
            </div>

            {%- comment -%} Product Details {%- endcomment -%}
            <div class="cart-item__main">
              <div class="cart-item__header">
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  
                  {%- comment -%} Variants {%- endcomment -%}
                  {% if item.product.has_only_default_variant == false %}
                    <div class="cart-item__variants">
                      {% for option in item.options_with_values %}
                        <span class="cart-item__variant-item">{{ option.value }}</span>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
                <div class="cart-item__price-main"><img src="{{ 'icon-dirham.svg' | asset_url }}" class="price-symbol" aria-hidden="true" alt="">{{ item.final_line_price | money_without_currency }}</div>
              </div>

              {%- comment -%} Controls Row {%- endcomment -%}
              <div class="cart-item__footer">
                <div class="cart-item__quantity-group">
                  <div class="cart-item__quantity">
                    <button
                      type="button"
                      class="qty-btn qty-btn--minus"
                      data-action="decrease"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Decrease quantity"
                    >
                      <svg width="12" height="2" viewBox="0 0 12 2" fill="none">
                        <path d="M0 1H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>

                    <input
                      type="number"
                      class="qty-input"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Quantity"
                      readonly
                    />

                    <button
                      type="button"
                      class="qty-btn qty-btn--plus"
                      data-action="increase"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Increase quantity"
                    >
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M6 0V12M0 6H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                  </div>
                </div>

                <div class="cart-item__line-total"><img src="{{ 'icon-dirham.svg' | asset_url }}" class="price-symbol" aria-hidden="true" alt="">{{ item.final_line_price | money_without_currency }}</div>

                <button
                  type="button"
                  class="cart-item__remove"
                  data-action="remove"
                  data-line="{{ item.index | plus: 1 }}"
                  aria-label="Remove {{ item.product.title | escape }}"
                  title="Remove from cart"
                >
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M3 5h12M7 8v4M11 8v4M4 5l1 9a1 1 0 001 1h6a1 1 0 001-1l1-9M7 5V3.5A.5.5 0 017.5 3h3a.5.5 0 01.5.5V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>

              {%- comment -%} Error Message {%- endcomment -%}
              <div class="cart-item__error hidden" data-error="{{ item.index | plus: 1 }}">
                <span class="cart-item__error-text"></span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </form>
  {%- endif -%}
</div>

<style>
/* ==========================================
   ENHANCED CART DESIGN - REFINED & PREMIUM
   ========================================== */

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Outfit:wght@400;500;600;700&display=swap');

:root {
  --cart-primary: #1a5c3a;
  --cart-primary-hover: #174F19;
  --cart-primary-light: #e6f2eb;
  --cart-text-primary: #0f0f0f;
  --cart-text-secondary: #5a5a5a;
  --cart-text-tertiary: #888888;
  --cart-border: #e8eaed;
  --cart-bg: #ffffff;
  --cart-bg-hover: #ffffff;
  --cart-red: #d32f2f;
  --cart-red-light: #ffebee;
  --cart-shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --cart-shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.modern-cart-wrapper {
  width: 100%;
  padding: 0;
  font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--cart-text-primary);
}

/* ==========================================
   PERFECT EMPTY STATE - REFINED
   ========================================== */

.cart-empty-state {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rem 2rem 5rem;
  text-align: center;
  min-height: 500px;
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  margin: 1.5rem;
}

.cart-empty-backdrop {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 50%, rgba(26, 92, 58, 0.03) 0%, transparent 50%),
              radial-gradient(circle at 70% 80%, rgba(26, 92, 58, 0.02) 0%, transparent 50%);
  pointer-events: none;
}

.cart-empty-decoration {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.cart-empty-decoration-item {
  position: absolute;
  border-radius: 50%;
  opacity: 0.04;
}

.cart-empty-decoration-item--1 {
  width: 300px;
  height: 300px;
  background: var(--cart-primary);
  top: -100px;
  right: -100px;
  animation: float 6s ease-in-out infinite;
}

.cart-empty-decoration-item--2 {
  width: 200px;
  height: 200px;
  background: var(--cart-primary);
  bottom: -50px;
  left: -50px;
  animation: float 8s ease-in-out infinite 1s;
}

.cart-empty-decoration-item--3 {
  width: 150px;
  height: 150px;
  background: var(--cart-primary);
  top: 50%;
  left: 10%;
  animation: float 7s ease-in-out infinite 2s;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(20px); }
}

.cart-empty-icon-wrapper {
  position: relative;
  z-index: 2;
  margin-bottom: 2.5rem;
  animation: fadeInDown 0.6s ease-out forwards;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cart-empty-icon-circle {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(230, 242, 235, 0.8) 0%, rgba(230, 242, 235, 0.4) 100%);
  border: 2px solid rgba(26, 92, 58, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  box-shadow: 0 8px 24px rgba(26, 92, 58, 0.08);
}

.cart-empty-icon-svg {
  color: var(--cart-primary);
  display: block;
  width: 52px;
  height: 52px;
  filter: drop-shadow(0 2px 4px rgba(26, 92, 58, 0.1));
}

.cart-empty-content {
  position: relative;
  z-index: 2;
  max-width: 480px;
  animation: fadeInUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cart-empty-heading {
  font-family: 'Playfair Display', serif;
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--cart-text-primary);
  margin: 0 0 1rem 0;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.cart-empty-text {
  font-size: 1rem;
  color: var(--cart-text-secondary);
  margin: 0 0 2.5rem 0;
  line-height: 1.6;
  font-weight: 400;
}

.cart-empty-actions {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-top: 2.5rem;
}

.cart-empty-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.95rem 2.5rem;
  font-size: 0.95rem;
  font-weight: 600;
  border: none;
  border-radius: 8px;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: -0.01em;
  position: relative;
  overflow: hidden;
}

.cart-empty-button::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 100%);
  pointer-events: none;
}

.cart-empty-button--primary {
  background: linear-gradient(135deg, var(--cart-primary) 0%, #0f5038 100%);
  color: white;
  box-shadow: 0 4px 15px rgba(26, 92, 58, 0.25);
}

.cart-empty-button--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(26, 92, 58, 0.35);
}

.cart-empty-button--primary:active {
  transform: translateY(0);
}

.cart-empty-button--secondary {
  background: white;
  color: var(--cart-primary);
  border: 2px solid var(--cart-border);
}

.cart-empty-button--secondary:hover {
  border-color: var(--cart-primary);
  background: var(--cart-primary-light);
  transform: translateY(-1px);
}

/* ==========================================
   FILLED CART - HEADER & ITEMS
   ========================================== */

.modern-cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 1rem;
  border-bottom: 1px solid var(--cart-border);
  background: #ffffff;
}

.modern-cart-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--cart-text-primary);
  margin: 0;
  letter-spacing: -0.02em;
}

.modern-cart-count {
  font-size: 0.875rem;
  color: var(--cart-text-secondary);
  font-weight: 500;
  background: var(--cart-primary-light);
  padding: 0.4rem 0.8rem;
  border-radius: 20px;
}

.modern-cart-items {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ==========================================
   CART ITEM - PREMIUM LAYOUT
   ========================================== */

.cart-item {
  display: flex;
  gap: 1rem;
  padding: 1rem 1rem;
  background: var(--cart-bg);
  border-bottom: 1px solid var(--cart-border);
  transition: all 0.2s ease;
  position: relative;
  align-items: stretch;
}

.cart-item:hover {
  background: var(--cart-bg-hover);
}

.cart-item:last-child {
  border-bottom: none;
}

/* ==========================================
   PRODUCT IMAGE
   ========================================== */

.cart-item__image-wrapper {
  width: 85px;
  height: 85px;
  flex-shrink: 0;
}

.cart-item__image-link {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #ffffff;
  border: 1px solid #e5e5e5;
  transition: all 0.2s ease;
  position: relative;
  padding: 8px;
}

.cart-item__image-link:hover {
  border-color: var(--cart-primary);
  box-shadow: var(--cart-shadow-sm);
}

.cart-item__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.cart-item__image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--cart-bg-hover);
}

/* ==========================================
   PRODUCT DETAILS
   ========================================== */

.cart-item__main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.cart-item__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 0.75rem;
}

.cart-item__info {
  flex: 1;
  min-width: 0;
}

.cart-item__title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--cart-text-primary);
  text-decoration: none;
  line-height: 1.35;
  display: block;
  margin-bottom: 0.35rem;
  letter-spacing: -0.01em;
  transition: color 0.2s ease;
}

.cart-item__title:hover {
  color: var(--cart-primary);
}

.cart-item__variants {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin: 0;
}

.cart-item__variant-item {
  font-size: 0.8125rem;
  color: var(--cart-text-tertiary);
  padding: 0.25rem 0.5rem;
  background: var(--cart-bg-hover);
  border-radius: 4px;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

.cart-item__price-main {
  font-size: 1rem;
  font-weight: 700;
  color: var(--cart-text-primary);
  white-space: nowrap;
  flex-shrink: 0;
  letter-spacing: -0.01em;
}

/* FOOTER: Controls Row */
.cart-item__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(0, 0, 0, 0.04);
}

.cart-item__quantity-group {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.cart-item__quantity-label {
  font-size: 0.8125rem;
  color: var(--cart-text-secondary);
  font-weight: 600;
  white-space: nowrap;
}

.cart-item__quantity {
  display: inline-flex;
  align-items: center;
  background: #ffffff;
  border-radius: 6px;
  padding: 2px;
  border: 1px solid var(--cart-border);
  gap: 0px;
  transition: all 0.15s ease;
}

.cart-item__quantity:focus-within {
  border-color: var(--cart-primary);
  box-shadow: 0 0 0 2px rgba(26, 92, 58, 0.1);
}

.qty-btn {
  width: 32px;
  height: 32px;
  background: transparent;
  border: none;
  color: var(--cart-text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s ease;
  padding: 0;
  border-radius: 4px;
}

.qty-btn:hover:not(:disabled) {
  background: rgba(26, 92, 58, 0.08);
  color: var(--cart-primary);
}

.qty-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.qty-input {
  width: 40px;
  border: none;
  background: transparent;
  text-align: center;
  font-weight: 700;
  color: var(--cart-text-primary);
  font-size: 0.9375rem;
  padding: 0 2px;
  margin: 0;
  letter-spacing: -0.01em;
  font-family: inherit;
}

.qty-input:hover,
.qty-input:focus {
  background: transparent !important;
  outline: none;
}

.qty-input:focus {
  outline: none;
}

.cart-item__line-total {
  font-weight: 700;
  color: var(--cart-primary);
  font-size: 1rem;
  white-space: nowrap;
  letter-spacing: -0.01em;
  min-width: 60px;
  text-align: right;
}

.cart-item__remove {
  color: var(--cart-text-tertiary);
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 6px;
  transition: all 0.2s ease;
  line-height: 1;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
}

.cart-item__remove:hover {
  color: var(--cart-red);
  background: var(--cart-red-light);
  transform: scale(1.05);
}

/* ==========================================
   ERROR MESSAGE
   ========================================== */

.cart-item__error {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 0.75rem;
  background: var(--cart-red-light);
  border: 1px solid rgba(211, 47, 47, 0.2);
  border-radius: 4px;
  font-size: 0.75rem;
  color: var(--cart-red);
  line-height: 1.4;
  margin-top: 0.5rem;
  animation: slideDown 0.25s ease;
}

.cart-item__error.hidden {
  display: none;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==========================================
   MOBILE RESPONSIVE
   ========================================== */

@media screen and (max-width: 749px) {
  .cart-item {
    padding: 0.875rem 0.75rem;
    gap: 0.75rem;
  }

  .cart-item__image-wrapper {
    width: 75px;
    height: 75px;
  }

  .cart-item__title {
    font-size: 0.875rem;
  }

  .cart-item__variant-item {
    font-size: 0.75rem;
  }

  .cart-item__price-main {
    font-size: 0.9375rem;
  }

  .cart-item__line-total {
    font-size: 0.9375rem;
  }

  .qty-btn {
    width: 30px;
    height: 30px;
  }

  .qty-input {
    width: 36px;
    font-size: 0.875rem;
  }

  .modern-cart-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .modern-cart-title {
    font-size: 1.5rem;
  }
}

@media screen and (max-width: 480px) {
  .cart-item {
    gap: 0.5rem;
    padding: 0.75rem 0.625rem;
    flex-wrap: wrap;
  }

  .cart-item__image-wrapper {
    width: 70px;
    height: 70px;
  }

  .cart-item__header {
    width: 100%;
    flex-basis: 100%;
    gap: 0.5rem;
  }

  .cart-item__title {
    font-size: 0.8125rem;
  }

  .cart-item__footer {
    width: 100%;
    flex-basis: 100%;
  }

  .cart-item__quantity-label {
    font-size: 0.75rem;
  }

  .cart-empty-state {
    padding: 2.5rem 1rem 3rem;
    min-height: 400px;
  }

  .cart-empty-icon-circle {
    width: 110px;
    height: 110px;
  }

  .cart-empty-icon-svg {
    width: 44px;
    height: 44px;
  }

  .cart-empty-heading {
    font-size: 1.75rem;
  }

  .cart-empty-text {
    font-size: 0.9375rem;
  }

  .modern-cart-count {
    font-size: 0.75rem;
  }
}

/* ==========================================
   ACCESSIBILITY
   ========================================== */

.visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}

.qty-btn:focus-visible,
.cart-item__remove:focus-visible,
.cart-item__title:focus-visible,
.cart-empty-button:focus-visible {
  outline: 2px solid var(--cart-primary);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation: none !important;
    transition: none !important;
  }
}
</style>

<script>
  // Enhanced Cart Functionality with Auto-Update
  (function() {
    'use strict';

    const CartManager = {
      init() {
        this.cartForm = document.querySelector('.modern-cart-form');

        this.moneyFormat = window.theme?.moneyFormat || '{{amount}}';
        this.bindEvents();
        this.listenForCartChanges();
      },

      bindEvents() {
        // Use event delegation so buttons work after DOM updates/replacement
        document.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-action]');
          if (!btn) return;
          const action = btn.dataset.action;
          if (action === 'decrease') {
            e.preventDefault();
            this.handleDecrease(btn);
          } else if (action === 'increase') {
            e.preventDefault();
            this.handleIncrease(btn);
          } else if (action === 'remove') {
            e.preventDefault();
            this.handleRemove(btn);
          }
        });
      },

      handleDecrease(button) {
        const btn = button;
        const line = parseInt(btn.dataset.line);
        let input = null;
        const cartItem = btn.closest('[data-line-index]');
        if (cartItem) input = cartItem.querySelector('.qty-input');
        if (!input) input = document.querySelector(`.qty-input[data-line="${line}"]`);
        if (!input) return;
        const currentValue = parseInt(input.value) || 0;
        const newValue = Math.max(0, currentValue - 1);
        if (newValue >= 0) this.updateQuantity(line, newValue, btn);
      },

      handleIncrease(button) {
        const btn = button;
        const line = parseInt(btn.dataset.line);
        let input = null;
        const cartItem = btn.closest('[data-line-index]');
        if (cartItem) input = cartItem.querySelector('.qty-input');
        if (!input) input = document.querySelector(`.qty-input[data-line="${line}"]`);
        if (!input) return;
        const currentValue = parseInt(input.value) || 0;
        const newValue = currentValue + 1;
        this.updateQuantity(line, newValue, btn);
      },

      handleRemove(button) {
        const btn = button;
        const line = parseInt(btn.dataset.line);
        this.updateQuantity(line, 0, btn);
      },

      updateQuantity(line, newQuantity, button) {
        if (button) button.disabled = true;

        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: newQuantity
          })
        })
        .then(response => response.json())
        .then(cart => {
          if (newQuantity === 0) {
            this.removeCartItem(line, cart);
          } else {
            this.updateCartDisplay(cart);
          }
        })
        .catch(error => {
          console.error('Cart update error:', error);
          this.showError(line, 'Unable to update quantity');
        })
        .finally(() => {
          if (button) button.disabled = false;
        });
      },

      removeCartItem(line, cart) {
        const cartItem = document.querySelector(`[data-line-index="${line - 1}"]`);
        if (cartItem) {
          cartItem.style.opacity = '0';
          cartItem.style.transform = 'translateX(-20px)';
          
          setTimeout(() => {
            cartItem.remove();
            this.updateCartDisplay(cart);
          }, 250);
        } else {
          this.updateCartDisplay(cart);
        }
      },

      updateCartDisplay(cart) {
        // Update cart count in all possible locations
        const cartCountSelectors = [
          '[ref="cartItemCount"]',
          '.cart-count',
          '.cart-item-count',
          '[data-cart-count]',
          '#cart-count',
          '.cart-drawer__count',
          '[data-cart-item-count]'
        ];
        
        cartCountSelectors.forEach(selector => {
          const elements = document.querySelectorAll(selector);
          elements.forEach(el => {
            el.textContent = cart.item_count;
            el.setAttribute('data-count', cart.item_count);
          });
        });

        // Update each cart item
        cart.items.forEach((item, index) => {
          const cartItem = document.querySelector(`[data-line-index="${index}"]`);
          
          if (cartItem) {
            const qtyInput = cartItem.querySelector('.qty-input');
            if (qtyInput) {
              qtyInput.value = item.quantity;
            }

            const lineTotal = cartItem.querySelector('.cart-item__line-total');
            if (lineTotal) {
              lineTotal.textContent = this.formatMoney(item.final_line_price);
            }

            const price = cartItem.querySelector('.cart-item__price-main');
            if (price) {
              price.textContent = this.formatMoney(item.final_line_price);
            }
          }
        });

        // Dispatch custom event for other scripts
        document.dispatchEvent(new CustomEvent('cart:updated', { 
          detail: cart,
          bubbles: true 
        }));
        
        // Show empty state if no items
        if (cart.item_count === 0) {
          this.showEmptyCart();
        }
      },

      showEmptyCart() {
        const cartWrapper = document.querySelector('.modern-cart-wrapper');
        if (!cartWrapper) return;
        
        const cartForm = cartWrapper.querySelector('.modern-cart-form');
        if (cartForm) {
          cartForm.style.opacity = '0';
          cartForm.style.transform = 'translateY(-10px)';
          
          setTimeout(() => {
            cartWrapper.innerHTML = `
              <div class="cart-empty-state">
                <div class="cart-empty-backdrop"></div>
                <div class="cart-empty-icon-wrapper">
                  <div class="cart-empty-icon-circle">
                    <svg width="52" height="52" viewBox="0 0 48 48" fill="none" class="cart-empty-icon-svg">
                      <path d="M8 16L6 20V38C6 39.1 6.9 40 8 40H40C41.1 40 42 39.1 42 38V20L40 16H8Z" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16 16V10C16 7.8 17.8 6 20 6H28C30.2 6 32 7.8 32 10V16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="24" cy="28" r="1.2" fill="currentColor"/>
                    </svg>
                  </div>
                </div>
                <div class="cart-empty-content">
                  <h1 class="cart-empty-heading">Your cart is empty</h1>
                  <p class="cart-empty-text">Discover beautiful items and start building your collection today.</p>
                  <div class="cart-empty-actions">
                    <a class="cart-empty-button cart-empty-button--primary" href="/collections/all">Continue Shopping</a>
                    <a class="cart-empty-button cart-empty-button--secondary" href="/">Return Home</a>
                  </div>
                </div>
                <div class="cart-empty-decoration">
                  <div class="cart-empty-decoration-item cart-empty-decoration-item--1"></div>
                  <div class="cart-empty-decoration-item cart-empty-decoration-item--2"></div>
                  <div class="cart-empty-decoration-item cart-empty-decoration-item--3"></div>
                </div>
              </div>
            `;
          }, 250);
        }
      },

      showError(line, message) {
        const errorEl = document.querySelector(`[data-error="${line}"]`);
        if (errorEl) {
          const textEl = errorEl.querySelector('.cart-item__error-text');
          if (textEl) textEl.textContent = message;
          errorEl.classList.remove('hidden');
          setTimeout(() => errorEl.classList.add('hidden'), 3500);
        }
      },

      formatMoney(cents) {
        const amount = (cents / 100).toFixed(2);
        const symbol = `<img src="{{ 'icon-dirham.svg' | asset_url }}" class="price-symbol" aria-hidden="true" alt="">`;
        if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
          const raw = Shopify.formatMoney(cents, '{{amount}}');
          return symbol + raw;
        }
        return symbol + amount;
      },

      // Listen for cart changes from other sources (e.g., add to cart)
      listenForCartChanges() {
        // Listen for theme's cart update events
        document.addEventListener('cart:refresh', () => {
          this.refreshCart();
        });

        // Listen for Shopify's built-in events
        document.addEventListener('cart.requestComplete', (event) => {
          if (event.detail?.cart) {
            this.updateCartDisplay(event.detail.cart);
          } else {
            this.refreshCart();
          }
        });

        // Listen for theme cart update events (dispatched by ProductFormComponent and others)
        document.addEventListener('cart:update', (event) => {
          try {
            const resource = event?.detail?.resource || event?.detail?.data || event?.detail || null;
            if (resource && resource.items) {
              this.updateCartDisplay(resource);
            } else if (event?.detail?.resource) {
              this.updateCartDisplay(event.detail.resource);
            } else {
              // fallback to fetching full cart when resource not provided
              this.refreshCart();
            }
          } catch (err) {
            this.refreshCart();
          }
        });

        // Additional listeners to catch add-to-cart actions across themes
        // Catch form submits that post to /cart/add
        document.addEventListener('submit', (e) => {
          try {
            const form = e.target;
            if (form && form.action && form.action.indexOf('/cart/add') !== -1) {
              // Give the theme's own handlers a chance to run, then refresh
              setTimeout(() => this.refreshCart(), 400);
            }
          } catch (err) {
            // ignore
          }
        }, true);

        // Catch clicks on elements that may trigger AJAX add-to-cart
        document.addEventListener('click', (e) => {
          try {
            const btn = e.target.closest('[data-add-to-cart], [data-action="add-to-cart"], .add-to-cart, button.add-to-cart');
            if (btn) {
              setTimeout(() => this.refreshCart(), 400);
            }
          } catch (err) {
            // ignore
          }
        });

        // Monkey-patch fetch to detect network calls to /cart/add.js and ensure a refresh
        if (typeof window.fetch === 'function' && !window.__cart_manager_fetch_hooked) {
          window.__cart_manager_fetch_hooked = true;
          const _fetch = window.fetch.bind(window);
          window.fetch = function(input, init) {
            const url = (typeof input === 'string') ? input : (input && input.url) ? input.url : '';
            const result = _fetch(input, init);
            try {
              if (url && (url.indexOf('/cart/add') !== -1 || url.indexOf('/cart.js') !== -1 || url.indexOf('/cart/change') !== -1)) {
                result.then(() => {
                  setTimeout(() => {
                    try { CartManager.refreshCart(); } catch (e) {}
                  }, 80);
                }).catch(()=>{});
              }
            } catch (err) {
              // ignore
            }
            return result;
          };
        }
      },

      // Refresh cart from server
      refreshCart() {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            this.updateCartDisplay(cart);
          })
          .catch(error => {
            console.error('Cart refresh error:', error);
          });
      }
    };

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => CartManager.init());
    } else {
      CartManager.init();
    }

    // Expose CartManager globally for manual refresh
    window.CartManager = CartManager;
  })();
</script>
