{% liquid
  assign block_settings = block.settings
%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div
  {{ block.shopify_attributes }}
  class="modern-cart-wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? %}
    {%- comment -%} Empty State {%- endcomment -%}
    <div class="cart-empty-state">
      <div class="cart-empty-icon-wrapper">
        <div class="cart-empty-icon-circle">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="cart-empty-icon-svg">
            <path d="M8 16L6 20V38C6 39.1 6.9 40 8 40H40C41.1 40 42 39.1 42 38V20L40 16H8Z" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 16V10C16 7.8 17.8 6 20 6H28C30.2 6 32 7.8 32 10V16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="28" r="1.2" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <h1 class="cart-empty-heading">Your cart is empty</h1>
      <p class="cart-empty-text">Start adding your favorite items to your cart!</p>
      <a
        class="cart-empty-button"
        href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
      >
        Continue Shopping
      </a>
    </div>
  {%- else -%}
    {%- comment -%} Cart Items {%- endcomment -%}
    <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">{{- cart.item_count -}}</span>
    
    <form
      action="{{ routes.cart_url }}"
      class="modern-cart-form"
      id="cart-form"
      method="post"
    >
      <div class="modern-cart-items" id="cart-items-container">
        {% for item in cart.items %}
          <div
            class="cart-item"
            ref="cartItemRows[]"
            data-parent-key="{{ item.parent_relationship.parent.key }}"
            data-key="{{ item.key }}"
            data-line-index="{{ item.index }}"
          >
            {%- comment -%} Product Image {%- endcomment -%}
            <div class="cart-item__image">
              {% if item.image %}
                <a href="{{ item.url }}" class="cart-item__image-link">
                  <img 
                    src="{{ item.image | image_url: width: 200 }}" 
                    alt="{{ item.product.title | escape }}"
                    class="cart-item__img" 
                    loading="lazy"
                  />
                </a>
              {% else %}
                <div class="cart-item__image-link cart-item__image-placeholder">
                  <svg viewBox="0 0 100 100" fill="none">
                    <rect width="100" height="100" fill="#f8f8f8"/>
                    <path d="M30 40L50 60L70 40M50 30V70" stroke="#d0d0d0" stroke-width="2"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            {%- comment -%} Product Details {%- endcomment -%}
            <div class="cart-item__details">
              {%- comment -%} Product Info Row {%- endcomment -%}
              <div class="cart-item__info-row">
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  
                  {%- comment -%} Variants {%- endcomment -%}
                  {% if item.product.has_only_default_variant == false %}
                    <div class="cart-item__variants">
                      {% for option in item.options_with_values %}{{ option.value }}{% unless forloop.last %} • {% endunless %}{% endfor %}
                    </div>
                  {% endif %}
                </div>
                <div class="cart-item__price">{{ item.final_line_price | money }}</div>
              </div>

              {%- comment -%} Controls Row {%- endcomment -%}
              <div class="cart-item__controls-row">
                <div class="cart-item__line-price">{{ item.final_line_price | money }}</div>

                <div class="cart-item__actions">
                  <div class="cart-item__quantity">
                    <button
                      type="button"
                      class="qty-btn qty-btn--minus"
                      data-action="decrease"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Decrease quantity"
                    >
                      <svg width="12" height="2" viewBox="0 0 12 2" fill="none">
                        <path d="M0 1H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>

                    <input
                      type="number"
                      class="qty-input"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Quantity"
                      readonly
                    />

                    <button
                      type="button"
                      class="qty-btn qty-btn--plus"
                      data-action="increase"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Increase quantity"
                    >
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M6 0V12M0 6H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                  </div>

                  <button
                    type="button"
                    class="cart-item__remove"
                    data-action="remove"
                    data-line="{{ item.index | plus: 1 }}"
                    aria-label="Remove {{ item.product.title | escape }}"
                  >
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M3 5h12M7 8v4M11 8v4M4 5l1 9a1 1 0 001 1h6a1 1 0 001-1l1-9M7 5V3.5A.5.5 0 017.5 3h3a.5.5 0 01.5.5V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>

              {%- comment -%} Error Message {%- endcomment -%}
              <div class="cart-item__error hidden" data-error="{{ item.index | plus: 1 }}">
                <span class="cart-item__error-text"></span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </form>
  {%- endif -%}
</div>

<style>
/* ==========================================
   CART DESIGN - COMPLETE & AUTO-UPDATING
   ========================================== */

:root {
  --cart-primary: #1a5c3a;
  --cart-primary-hover: #174F19;
  --cart-text-primary: #1a1a1a;
  --cart-text-secondary: #666666;
  --cart-text-tertiary: #999999;
  --cart-border: #e5e7eb;
  --cart-bg: #ffffff;
  --cart-bg-hover: #fafafa;
  --cart-red: #ef4444;
  --cart-red-light: #fee2e2;
}

.modern-cart-wrapper {
  width: 100%;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

/* ==========================================
   PERFECT EMPTY STATE
   ========================================== */

.cart-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 3rem 1.5rem 4rem;
  text-align: center;
  min-height: 400px;
  background: transparent;
  opacity: 0;
  animation: fadeInUp 0.4s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cart-empty-icon-wrapper {
  margin-bottom: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-empty-icon-circle {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  background: rgba(230, 242, 235, 0.5);
  border: 2.5px solid #2d6e4d;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.cart-empty-icon-svg {
  color: #2d6e4d;
  display: block;
  width: 48px;
  height: 48px;
}

.cart-empty-heading {
  font-size: 2rem;
  font-weight: 400;
  color: #1a1a1a;
  margin: 0 0 0.75rem 0;
  letter-spacing: -0.01em;
  line-height: 1.2;
  font-family: 'Times New Roman', Times, serif;
}

.cart-empty-text {
  font-size: 0.9375rem;
  color: #4a4a4a;
  margin: 0 0 2.5rem 0;
  line-height: 1.5;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
  font-weight: 400;
}

.cart-empty-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.875rem 3rem;
  background: #1a5c3a;
  color: white;
  font-size: 0.9375rem;
  font-weight: 500;
  border: none;
  border-radius: 25px;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.25s ease;
  letter-spacing: 0.01em;
  position: relative;
  overflow: hidden;
  min-width: 260px;
}

.cart-empty-button:hover {
  background: #174F19;
  transform: translateY(-1px);
}

/* ==========================================
   CART ITEMS CONTAINER
   ========================================== */

.modern-cart-form {
  width: 100%;
}

.modern-cart-items {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ==========================================
   CART ITEM - MATCHING SCREENSHOT
   ========================================== */

.cart-item {
  display: flex;
  gap: 1rem;
  padding: 1.25rem 1rem;
  background: var(--cart-bg);
  border-bottom: 1px solid var(--cart-border);
  transition: background 0.15s ease;
  position: relative;
}

.cart-item:hover {
  background: var(--cart-bg-hover);
}

.cart-item:last-child {
  border-bottom: none;
}

/* ==========================================
   PRODUCT IMAGE
   ========================================== */

.cart-item__image {
  width: 75px;
  height: 75px;
  flex-shrink: 0;
}

.cart-item__image-link {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 8px;
  overflow: hidden;
  background: #f8f8f8;
  border: 1px solid rgba(0,0,0,0.06);
}

.cart-item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ==========================================
   PRODUCT DETAILS
   ========================================== */

.cart-item__details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-width: 0;
}

/* INFO ROW: Title, Variants, Price */
.cart-item__info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
}

.cart-item__info {
  flex: 1;
  min-width: 0;
}

.cart-item__title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--cart-text-primary);
  text-decoration: none;
  line-height: 1.3;
  display: block;
  margin-bottom: 0.3rem;
  letter-spacing: -0.01em;
}

.cart-item__title:hover {
  color: var(--cart-primary);
}

.cart-item__variants {
  font-size: 0.875rem;
  color: var(--cart-text-secondary);
  line-height: 1.4;
  margin: 0;
}

.cart-item__price {
  font-size: 1rem;
  font-weight: 600;
  color: var(--cart-text-primary);
  white-space: nowrap;
  flex-shrink: 0;
  letter-spacing: -0.01em;
}

/* CONTROLS ROW: Line Price + Quantity + Remove */
.cart-item__controls-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}

.cart-item__line-price {
  font-weight: 700;
  color: var(--cart-primary);
  font-size: 1.0625rem;
  white-space: nowrap;
  letter-spacing: -0.01em;
}

.cart-item__actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-left: auto;
}

.cart-item__quantity {
  display: inline-flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 6px;
  padding: 2px;
  border: 1px solid #e0e0e0;
  gap: 2px;
}

.qty-btn {
  width: 32px;
  height: 32px;
  background: transparent;
  border: none;
  color: var(--cart-text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s ease;
  padding: 0;
  border-radius: 4px;
}

.qty-btn:hover:not(:disabled) {
  background: #e0e0e0;
  color: var(--cart-text-primary);
}

.qty-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.qty-input {
  width: 36px;
  border: none;
  background: transparent;
  text-align: center;
  font-weight: 600;
  color: var(--cart-text-primary);
  font-size: 0.9375rem;
  padding: 0;
  margin: 0;
  letter-spacing: -0.01em;
}

.cart-item__remove {
  color: var(--cart-text-tertiary);
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 6px;
  transition: all 0.15s ease;
  line-height: 1;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
}

.cart-item__remove:hover {
  color: var(--cart-red);
  background: var(--cart-red-light);
}

/* ==========================================
   ERROR MESSAGE
   ========================================== */

.cart-item__error {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 0.75rem;
  background: var(--cart-red-light);
  border-radius: 4px;
  font-size: 0.75rem;
  color: var(--cart-red);
  line-height: 1.4;
}

.cart-item__error.hidden {
  display: none;
}

/* ==========================================
   MOBILE RESPONSIVE
   ========================================== */

@media screen and (max-width: 749px) {
  .cart-item {
    padding: 1rem 0.875rem;
    gap: 0.875rem;
  }

  .cart-item__image {
    width: 68px;
    height: 68px;
  }

  .cart-item__title {
    font-size: 0.9375rem;
  }

  .cart-item__variants {
    font-size: 0.8125rem;
  }

  .cart-item__price {
    font-size: 0.9375rem;
  }

  .cart-item__line-price {
    font-size: 1rem;
  }

  .qty-btn {
    width: 30px;
    height: 30px;
  }

  .qty-input {
    width: 34px;
    font-size: 0.875rem;
  }
}

@media screen and (max-width: 480px) {
  .cart-item {
    gap: 0.75rem;
    padding: 0.875rem 0.75rem;
  }

  .cart-item__image {
    width: 64px;
    height: 64px;
  }

  .cart-item__info-row {
    gap: 0.75rem;
  }

  .cart-item__title {
    font-size: 0.875rem;
  }

  .cart-item__variants {
    font-size: 0.75rem;
  }

  .cart-item__price,
  .cart-item__line-price {
    font-size: 0.875rem;
  }

  .cart-item__actions {
    gap: 0.625rem;
  }

  .qty-btn {
    width: 28px;
    height: 28px;
  }

  .qty-input {
    width: 32px;
  }
}

/* Empty state responsive */
@media (max-width: 768px) {
  .cart-empty-state {
    padding: 2.5rem 1.25rem 3.5rem;
  }
  
  .cart-empty-icon-circle {
    width: 120px;
    height: 120px;
  }
  
  .cart-empty-heading {
    font-size: 1.75rem;
  }
}

@media (max-width: 640px) {
  .cart-empty-state {
    padding: 2.25rem 1rem 3.25rem;
  }
  
  .cart-empty-icon-circle {
    width: 110px;
    height: 110px;
  }
  
  .cart-empty-heading {
    font-size: 1.625rem;
  }
}

/* ==========================================
   ACCESSIBILITY
   ========================================== */

.visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}

.qty-btn:focus-visible,
.cart-item__remove:focus-visible,
.cart-item__title:focus-visible,
.cart-empty-button:focus-visible {
  outline: 2px solid var(--cart-primary);
  outline-offset: 2px;
  border-radius: 4px;
}

@media (prefers-reduced-motion: reduce) {
  .cart-empty-state {
    animation: none !important;
  }
  
  * {
    transition-duration: 0.01ms !important;
  }
}
</style>

<script>
  // Enhanced Cart Functionality with Auto-Update
  (function() {
    'use strict';

    const CartManager = {
      init() {
        this.cartForm = document.querySelector('.modern-cart-form');
        if (!this.cartForm) return;

        this.moneyFormat = window.theme?.moneyFormat || '{{amount}}';
        this.bindEvents();
        this.listenForCartChanges();
      },

      bindEvents() {
        // Quantity decrease buttons
        document.querySelectorAll('[data-action="decrease"]').forEach(btn => {
          btn.addEventListener('click', (e) => this.handleDecrease(e));
        });

        // Quantity increase buttons
        document.querySelectorAll('[data-action="increase"]').forEach(btn => {
          btn.addEventListener('click', (e) => this.handleIncrease(e));
        });

        // Remove buttons
        document.querySelectorAll('[data-action="remove"]').forEach(btn => {
          btn.addEventListener('click', (e) => this.handleRemove(e));
        });
      },

      handleDecrease(e) {
        e.preventDefault();
        const button = e.currentTarget;
        const line = parseInt(button.dataset.line);
        const input = document.querySelector(`.qty-input[data-line="${line}"]`);
        const currentValue = parseInt(input.value);
        const newValue = Math.max(0, currentValue - 1);
        
        if (newValue >= 0) {
          this.updateQuantity(line, newValue, button);
        }
      },

      handleIncrease(e) {
        e.preventDefault();
        const button = e.currentTarget;
        const line = parseInt(button.dataset.line);
        const input = document.querySelector(`.qty-input[data-line="${line}"]`);
        const currentValue = parseInt(input.value);
        const newValue = currentValue + 1;
        
        this.updateQuantity(line, newValue, button);
      },

      handleRemove(e) {
        e.preventDefault();
        const button = e.currentTarget;
        const line = parseInt(button.dataset.line);
        this.updateQuantity(line, 0, button);
      },

      updateQuantity(line, newQuantity, button) {
        if (button) button.disabled = true;

        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: newQuantity
          })
        })
        .then(response => response.json())
        .then(cart => {
          if (newQuantity === 0) {
            this.removeCartItem(line, cart);
          } else {
            this.updateCartDisplay(cart);
          }
        })
        .catch(error => {
          console.error('Cart update error:', error);
          this.showError(line, 'Unable to update quantity');
        })
        .finally(() => {
          if (button) button.disabled = false;
        });
      },

      removeCartItem(line, cart) {
        const cartItem = document.querySelector(`[data-line-index="${line - 1}"]`);
        if (cartItem) {
          cartItem.style.opacity = '0';
          cartItem.style.transform = 'translateX(-20px)';
          
          setTimeout(() => {
            cartItem.remove();
            this.updateCartDisplay(cart);
          }, 250);
        } else {
          this.updateCartDisplay(cart);
        }
      },

      updateCartDisplay(cart) {
        // Update cart count in all possible locations
        const cartCountSelectors = [
          '[ref="cartItemCount"]',
          '.cart-count',
          '.cart-item-count',
          '[data-cart-count]',
          '#cart-count',
          '.cart-drawer__count',
          '[data-cart-item-count]'
        ];
        
        cartCountSelectors.forEach(selector => {
          const elements = document.querySelectorAll(selector);
          elements.forEach(el => {
            el.textContent = cart.item_count;
            el.setAttribute('data-count', cart.item_count);
          });
        });

        // Update each cart item
        cart.items.forEach((item, index) => {
          const cartItem = document.querySelector(`[data-line-index="${index}"]`);
          
          if (cartItem) {
            const qtyInput = cartItem.querySelector('.qty-input');
            if (qtyInput) {
              qtyInput.value = item.quantity;
            }

            const linePrice = cartItem.querySelector('.cart-item__line-price');
            if (linePrice) {
              linePrice.textContent = this.formatMoney(item.final_line_price);
            }

            const price = cartItem.querySelector('.cart-item__price');
            if (price) {
              price.textContent = this.formatMoney(item.final_line_price);
            }
          }
        });

        // Dispatch custom event for other scripts
        document.dispatchEvent(new CustomEvent('cart:updated', { 
          detail: cart,
          bubbles: true 
        }));
        
        // Show empty state if no items
        if (cart.item_count === 0) {
          this.showEmptyCart();
        }
      },

      showEmptyCart() {
        const cartWrapper = document.querySelector('.modern-cart-wrapper');
        if (!cartWrapper) return;
        
        const cartForm = cartWrapper.querySelector('.modern-cart-form');
        if (cartForm) {
          cartForm.style.opacity = '0';
          cartForm.style.transform = 'translateY(-10px)';
          
          setTimeout(() => {
            cartWrapper.innerHTML = `
              <div class="cart-empty-state">
                <div class="cart-empty-icon-wrapper">
                  <div class="cart-empty-icon-circle">
                    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="cart-empty-icon-svg">
                      <path d="M8 16L6 20V38C6 39.1 6.9 40 8 40H40C41.1 40 42 39.1 42 38V20L40 16H8Z" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M16 16V10C16 7.8 17.8 6 20 6H28C30.2 6 32 7.8 32 10V16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      <circle cx="24" cy="28" r="1.2" fill="currentColor"/>
                    </svg>
                  </div>
                </div>
                <h1 class="cart-empty-heading">Your cart is empty</h1>
                <p class="cart-empty-text">Start adding your favorite items to your cart!</p>
                <a class="cart-empty-button" href="/collections/all">Continue Shopping</a>
              </div>
            `;
          }, 250);
        }
      },

      showError(line, message) {
        const errorEl = document.querySelector(`[data-error="${line}"]`);
        if (errorEl) {
          const textEl = errorEl.querySelector('.cart-item__error-text');
          if (textEl) textEl.textContent = message;
          errorEl.classList.remove('hidden');
          setTimeout(() => errorEl.classList.add('hidden'), 3500);
        }
      },

      formatMoney(cents) {
        if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
          return Shopify.formatMoney(cents, this.moneyFormat);
        }
        return 'Dhs. ' + (cents / 100).toFixed(2);
      },

      // Listen for cart changes from other sources (e.g., add to cart)
      listenForCartChanges() {
        // Listen for theme's cart update events
        document.addEventListener('cart:refresh', () => {
          this.refreshCart();
        });

        // Listen for Shopify's built-in events
        document.addEventListener('cart.requestComplete', (event) => {
          if (event.detail?.cart) {
            this.updateCartDisplay(event.detail.cart);
          } else {
            this.refreshCart();
          }
        });
      },

      // Refresh cart from server
      refreshCart() {
        fetch('/cart.js')
          .then(response => response.json())
          .then(cart => {
            this.updateCartDisplay(cart);
          })
          .catch(error => {
            console.error('Cart refresh error:', error);
          });
      }
    };

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => CartManager.init());
    } else {
      CartManager.init();
    }

    // Expose CartManager globally for manual refresh
    window.CartManager = CartManager;
  })();
</script>
