{% liquid
  assign block_settings = block.settings
%}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div
  {{ block.shopify_attributes }}
  class="modern-cart-wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? %}
    {%- comment -%} Empty State {%- endcomment -%}
    <div class="cart-empty-state">
      <div class="cart-empty-icon-wrapper">
        <div class="cart-empty-icon-circle">
          <svg width="70" height="70" viewBox="0 0 24 24" fill="none" class="cart-empty-icon-svg">
            <path d="M6 8L5 11V20C5 21.1 5.9 22 7 22H21C22.1 22 23 21.1 23 20V11L22 8H6Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 8V5C9 3.3 10.3 2 12 2C13.7 2 15 3.3 15 5V8" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="22" r="0.7" fill="currentColor" opacity="0.5"/>
          </svg>
        </div>
      </div>
      <h1 class="cart-empty-heading">Your cart is empty</h1>
      <p class="cart-empty-text">Start adding your favorite items to your cart!</p>
      <a
        class="cart-empty-button"
        href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
      >
        Continue Shopping
      </a>
    </div>
  {%- else -%}
    {%- comment -%} Cart Items {%- endcomment -%}
    <span class="visually-hidden" ref="cartItemCount" aria-hidden="true">{{- cart.item_count -}}</span>
    
    <form
      action="{{ routes.cart_url }}"
      class="modern-cart-form"
      id="cart-form"
      method="post"
    >
      <div class="modern-cart-items">
        {% for item in cart.items %}
          <div
            class="cart-item"
            ref="cartItemRows[]"
            data-parent-key="{{ item.parent_relationship.parent.key }}"
            data-key="{{ item.key }}"
            data-line-index="{{ item.index }}"
          >
            {%- comment -%} Product Image {%- endcomment -%}
            <div class="cart-item__image">
              {% if item.image %}
                <a href="{{ item.url }}" class="cart-item__image-link">
                  <img 
                    src="{{ item.image | image_url: width: 200 }}" 
                    alt="{{ item.product.title | escape }}"
                    class="cart-item__img" 
                    loading="lazy"
                  />
                </a>
              {% else %}
                <div class="cart-item__image-link cart-item__image-placeholder">
                  <svg viewBox="0 0 100 100" fill="none">
                    <rect width="100" height="100" fill="#f8f8f8"/>
                    <path d="M30 40L50 60L70 40M50 30V70" stroke="#d0d0d0" stroke-width="2"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            {%- comment -%} Product Details {%- endcomment -%}
            <div class="cart-item__details">
              {%- comment -%} Top Row: Title, Variants, Unit Price {%- endcomment -%}
              <div class="cart-item__top-row">
                <div class="cart-item__info">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  
                  {%- comment -%} Variants - ONLY ONCE {%- endcomment -%}
                  {% if item.product.has_only_default_variant == false %}
                    <div class="cart-item__variants">
                      {% for option in item.options_with_values %}{{ option.value }}{% unless forloop.last %} • {% endunless %}{% endfor %}
                    </div>
                  {% endif %}
                </div>
                <div class="cart-item__unit-price">{{ item.original_price | money }}</div>
              </div>

              {%- comment -%} Bottom Row: Line Total, Quantity Controls, Remove {%- endcomment -%}
              <div class="cart-item__bottom-row">
                <div class="cart-item__line-total">{{ item.final_line_price | money }}</div>

                <div class="cart-item__controls-group">
                  <div class="cart-item__quantity">
                    <button
                      type="button"
                      class="qty-btn"
                      data-action="decrease"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Decrease quantity"
                    >
                      <svg width="10" height="2" viewBox="0 0 10 2" fill="none">
                        <path d="M0 1H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>

                    <input
                      type="number"
                      class="qty-input"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Quantity"
                      readonly
                    />

                    <button
                      type="button"
                      class="qty-btn"
                      data-action="increase"
                      data-line="{{ item.index | plus: 1 }}"
                      aria-label="Increase quantity"
                    >
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                        <path d="M5 0V10M0 5H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </button>
                  </div>

                  <button
                    type="button"
                    class="cart-item__remove"
                    data-action="remove"
                    data-line="{{ item.index | plus: 1 }}"
                    aria-label="Remove {{ item.product.title | escape }}"
                  >
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M2 4h12M6.5 7v4M9.5 7v4M3 4l1 9a1 1 0 001 1h6a1 1 0 001-1l1-9M6 4V2.5A.5.5 0 016.5 2h3a.5.5 0 01.5.5V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>

              {%- comment -%} Error Message {%- endcomment -%}
              <div class="cart-item__error hidden" data-error="{{ item.index | plus: 1 }}">
                <span class="cart-item__error-text"></span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </form>
  {%- endif -%}
</div>

<style>
/* ==========================================
   MINIMALIST CART DESIGN - PERFECT EMPTY STATE
   ========================================== */

:root {
  --cart-primary: #1a5c3a;
  --cart-primary-hover: #174F19;
  --cart-text-primary: #1a1a1a;
  --cart-text-secondary: #666666;
  --cart-text-tertiary: #999999;
  --cart-border: #e5e7eb;
  --cart-bg: #ffffff;
  --cart-bg-hover: #fafafa;
  --cart-red: #ef4444;
  --cart-red-light: #fee2e2;
}

.modern-cart-wrapper {
  width: 100%;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

/* ==========================================
   PERFECT EMPTY STATE - WORKS FOR BOTH CASES
   ========================================== */

.cart-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rem 2rem;
  text-align: center;
  min-height: 500px;
  background: transparent;
  opacity: 0;
  animation: fadeInUp 0.5s ease forwards;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cart-empty-icon-wrapper {
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-empty-icon-circle {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 92, 58, 0.08) 0%, rgba(26, 92, 58, 0.04) 100%);
  border: 2px solid var(--cart-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  box-shadow: 0 4px 20px rgba(26, 92, 58, 0.08);
}

.cart-empty-icon-circle::before {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 92, 58, 0.04) 0%, transparent 100%);
  z-index: -1;
}

.cart-empty-icon-svg {
  color: var(--cart-primary);
  display: block;
  animation: floatSmooth 4s ease-in-out infinite;
  width: 55%;
  height: 55%;
}

.cart-empty-heading {
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--cart-text-primary);
  margin: 0 0 0.875rem 0;
  letter-spacing: -0.025em;
  line-height: 1.2;
}

.cart-empty-text {
  font-size: 1rem;
  color: var(--cart-text-secondary);
  margin: 0 0 2.75rem 0;
  line-height: 1.6;
  max-width: 380px;
  margin-left: auto;
  margin-right: auto;
}

.cart-empty-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 1rem 3.25rem;
  background: var(--cart-primary);
  color: white;
  font-size: 1rem;
  font-weight: 600;
  border: none;
  border-radius: 50px;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: -0.01em;
  box-shadow: 0 4px 16px rgba(26, 92, 58, 0.2);
  position: relative;
  overflow: hidden;
  min-width: 240px;
}

.cart-empty-button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.5s ease, height 0.5s ease;
  z-index: 0;
}

.cart-empty-button:hover::before {
  width: 320px;
  height: 320px;
}

.cart-empty-button:hover {
  background: var(--cart-primary-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(26, 92, 58, 0.28);
}

.cart-empty-button:active {
  transform: translateY(0);
  box-shadow: 0 4px 16px rgba(26, 92, 58, 0.2);
}

/* Animations */
@keyframes floatSmooth {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

/* ==========================================
   RESPONSIVE EMPTY STATE
   ========================================== */

@media (max-width: 768px) {
  .cart-empty-state {
    padding: 3.5rem 1.5rem;
    min-height: 450px;
  }
  
  .cart-empty-icon-wrapper {
    margin-bottom: 1.875rem;
  }
  
  .cart-empty-icon-circle {
    width: 115px;
    height: 115px;
  }
  
  .cart-empty-icon-circle::before {
    inset: -6px;
  }
  
  .cart-empty-heading {
    font-size: 1.625rem;
  }
  
  .cart-empty-text {
    font-size: 0.9375rem;
    margin-bottom: 2.25rem;
  }
  
  .cart-empty-button {
    padding: 0.9375rem 2.75rem;
    font-size: 0.9375rem;
    min-width: 220px;
  }
}

@media (max-width: 640px) {
  .cart-empty-state {
    padding: 3rem 1.25rem;
    min-height: 400px;
  }
  
  .cart-empty-icon-wrapper {
    margin-bottom: 1.625rem;
  }
  
  .cart-empty-icon-circle {
    width: 105px;
    height: 105px;
  }
  
  .cart-empty-heading {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .cart-empty-text {
    font-size: 0.875rem;
    margin-bottom: 2rem;
    max-width: 320px;
  }
  
  .cart-empty-button {
    width: 90%;
    max-width: 280px;
    padding: 0.875rem 2.25rem;
    font-size: 0.875rem;
  }
}

@media (max-width: 480px) {
  .cart-empty-state {
    padding: 2.5rem 1rem;
    min-height: 360px;
  }
  
  .cart-empty-icon-circle {
    width: 95px;
    height: 95px;
  }
  
  .cart-empty-heading {
    font-size: 1.375rem;
  }
  
  .cart-empty-text {
    font-size: 0.8125rem;
  }
}

/* ==========================================
   CART ITEMS
   ========================================== */

.modern-cart-form {
  width: 100%;
}

.modern-cart-items {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ==========================================
   CART ITEM - CLEAN TWO-ROW LAYOUT
   ========================================== */

.cart-item {
  display: flex;
  gap: 0.875rem;
  padding: 1rem;
  background: var(--cart-bg);
  border-bottom: 1px solid var(--cart-border);
  transition: background 0.15s ease;
}

.cart-item:hover {
  background: var(--cart-bg-hover);
}

.cart-item:last-child {
  border-bottom: none;
}

/* ==========================================
   PRODUCT IMAGE
   ========================================== */

.cart-item__image {
  width: 64px;
  height: 64px;
  flex-shrink: 0;
}

.cart-item__image-link {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 8px;
  overflow: hidden;
  background: #f8f8f8;
  border: 1px solid rgba(0,0,0,0.04);
}

.cart-item__img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

/* ==========================================
   PRODUCT DETAILS - TWO ROWS
   ========================================== */

.cart-item__details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  min-width: 0;
}

/* TOP ROW: Title + Variants + Unit Price */
.cart-item__top-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.75rem;
}

.cart-item__info {
  flex: 1;
  min-width: 0;
}

.cart-item__title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--cart-text-primary);
  text-decoration: none;
  line-height: 1.3;
  display: block;
  margin-bottom: 0.25rem;
  letter-spacing: -0.01em;
}

.cart-item__title:hover {
  color: var(--cart-primary);
}

.cart-item__variants {
  font-size: 0.8125rem;
  color: var(--cart-text-secondary);
  line-height: 1.3;
  margin: 0;
}

.cart-item__unit-price {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--cart-text-primary);
  white-space: nowrap;
  flex-shrink: 0;
  letter-spacing: -0.01em;
}

/* BOTTOM ROW: Line Total + Quantity + Remove */
.cart-item__bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
}

.cart-item__line-total {
  font-weight: 700;
  color: var(--cart-primary);
  font-size: 1rem;
  white-space: nowrap;
  letter-spacing: -0.01em;
}

.cart-item__controls-group {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin-left: auto;
}

.cart-item__quantity {
  display: inline-flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 6px;
  padding: 0;
  border: 1px solid #e5e5e5;
}

.qty-btn {
  width: 28px;
  height: 28px;
  background: transparent;
  border: none;
  color: var(--cart-text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s ease;
  padding: 0;
  border-radius: 4px;
}

.qty-btn:hover:not(:disabled) {
  background: #e5e5e5;
  color: var(--cart-text-primary);
}

.qty-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.qty-input {
  width: 32px;
  border: none;
  background: transparent;
  text-align: center;
  font-weight: 600;
  color: var(--cart-text-primary);
  font-size: 0.875rem;
  padding: 0;
  margin: 0;
  letter-spacing: -0.01em;
}

.cart-item__remove {
  color: var(--cart-text-tertiary);
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 5px;
  transition: all 0.15s ease;
  line-height: 1;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
}

.cart-item__remove:hover {
  color: var(--cart-red);
  background: var(--cart-red-light);
}

/* ==========================================
   ERROR MESSAGE
   ========================================== */

.cart-item__error {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem;
  background: var(--cart-red-light);
  border-radius: 4px;
  font-size: 0.75rem;
  color: var(--cart-red);
  line-height: 1.4;
}

.cart-item__error.hidden {
  display: none;
}

/* ==========================================
   MOBILE RESPONSIVE
   ========================================== */

@media screen and (max-width: 749px) {
  .cart-item {
    padding: 0.875rem;
    gap: 0.75rem;
  }

  .cart-item__image {
    width: 60px;
    height: 60px;
  }

  .cart-item__title {
    font-size: 0.875rem;
  }

  .cart-item__variants {
    font-size: 0.75rem;
  }

  .cart-item__unit-price {
    font-size: 0.8125rem;
  }

  .cart-item__line-total {
    font-size: 0.9375rem;
  }

  .qty-btn {
    width: 26px;
    height: 26px;
  }

  .qty-input {
    width: 28px;
    font-size: 0.8125rem;
  }
}

@media screen and (max-width: 480px) {
  .cart-item {
    gap: 0.625rem;
    padding: 0.75rem;
  }

  .cart-item__image {
    width: 56px;
    height: 56px;
  }

  .cart-item__top-row {
    gap: 0.5rem;
  }

  .cart-item__title {
    font-size: 0.8125rem;
  }

  .cart-item__variants {
    font-size: 0.6875rem;
  }

  .cart-item__unit-price,
  .cart-item__line-total {
    font-size: 0.8125rem;
  }

  .cart-item__controls-group {
    gap: 0.5rem;
  }
}

/* ==========================================
   ACCESSIBILITY
   ========================================== */

.visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  white-space: nowrap !important;
  border: 0 !important;
}

.qty-btn:focus-visible,
.cart-item__remove:focus-visible,
.cart-item__title:focus-visible,
.cart-empty-button:focus-visible {
  outline: 2px solid var(--cart-primary);
  outline-offset: 2px;
  border-radius: 4px;
}

@media (prefers-reduced-motion: reduce) {
  .cart-empty-state,
  .cart-empty-icon-svg,
  .cart-empty-button::before {
    animation: none !important;
  }
  
  * {
    transition-duration: 0.01ms !important;
  }
}
</style>

<script>
  // Modern Cart Functionality - Improved
  document.addEventListener('DOMContentLoaded', function() {
    const cartForm = document.querySelector('.modern-cart-form');
    if (!cartForm) return;

    const moneyFormat = window.theme && window.theme.moneyFormat ? window.theme.moneyFormat : '{{amount}}';

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return 'Dhs. ' + (cents / 100).toFixed(2);
    }

    function updateCartDisplay(cart) {
      const cartCountSelectors = [
        '[ref="cartItemCount"]',
        '.cart-count',
        '.cart-item-count',
        '[data-cart-count]',
        '#cart-count'
      ];
      
      cartCountSelectors.forEach(selector => {
        const cartCount = document.querySelector(selector);
        if (cartCount) {
          cartCount.textContent = cart.item_count;
          cartCount.setAttribute('data-count', cart.item_count);
        }
      });

      cart.items.forEach((item, index) => {
        const cartItem = document.querySelector(`[data-line-index="${index}"]`);
        
        if (cartItem) {
          const qtyInput = cartItem.querySelector('.qty-input');
          if (qtyInput) {
            qtyInput.value = item.quantity;
          }

          const lineTotal = cartItem.querySelector('.cart-item__line-total');
          if (lineTotal) {
            lineTotal.textContent = formatMoney(item.final_line_price);
          }
        }
      });

      document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      
      if (cart.item_count === 0) {
        showEmptyCart();
      }
    }

    function showEmptyCart() {
      const cartWrapper = document.querySelector('.modern-cart-wrapper');
      if (!cartWrapper) return;
      
      // Fade out current content
      const cartForm = cartWrapper.querySelector('.modern-cart-form');
      if (cartForm) {
        cartForm.style.opacity = '0';
        cartForm.style.transform = 'translateY(-10px)';
        
        setTimeout(() => {
          cartWrapper.innerHTML = `
            <div class="cart-empty-state">
              <div class="cart-empty-icon-wrapper">
                <div class="cart-empty-icon-circle">
                  <svg width="70" height="70" viewBox="0 0 24 24" fill="none" class="cart-empty-icon-svg">
                    <path d="M6 8L5 11V20C5 21.1 5.9 22 7 22H21C22.1 22 23 21.1 23 20V11L22 8H6Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 8V5C9 3.3 10.3 2 12 2C13.7 2 15 3.3 15 5V8" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="12" cy="22" r="0.7" fill="currentColor" opacity="0.5"/>
                  </svg>
                </div>
              </div>
              <h1 class="cart-empty-heading">Your cart is empty</h1>
              <p class="cart-empty-text">Start adding your favorite items to your cart!</p>
              <a class="cart-empty-button" href="/collections/all">Continue Shopping</a>
            </div>
          `;
        }, 200);
      }
    }

    function updateQuantity(line, newQuantity, button) {
      if (button) button.disabled = true;

      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          line: line,
          quantity: newQuantity
        })
      })
      .then(response => response.json())
      .then(cart => {
        if (newQuantity === 0) {
          const cartItem = document.querySelector(`[data-line-index="${line - 1}"]`);
          if (cartItem) {
            cartItem.style.opacity = '0';
            cartItem.style.transform = 'translateX(-10px)';
            setTimeout(() => {
              cartItem.remove();
              updateCartDisplay(cart);
            }, 200);
          }
        } else {
          updateCartDisplay(cart);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showError(line, 'Unable to update quantity');
      })
      .finally(() => {
        if (button) button.disabled = false;
      });
    }

    function showError(line, message) {
      const errorEl = document.querySelector(`[data-error="${line}"]`);
      if (errorEl) {
        const textEl = errorEl.querySelector('.cart-item__error-text');
        if (textEl) textEl.textContent = message;
        errorEl.classList.remove('hidden');
        setTimeout(() => errorEl.classList.add('hidden'), 3000);
      }
    }

    // Event Listeners
    document.querySelectorAll('[data-action="decrease"]').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const line = parseInt(this.dataset.line);
        const input = document.querySelector(`.qty-input[data-line="${line}"]`);
        const currentValue = parseInt(input.value);
        const newValue = Math.max(0, currentValue - 1);
        
        if (newValue >= 0) {
          updateQuantity(line, newValue, this);
        }
      });
    });

    document.querySelectorAll('[data-action="increase"]').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const line = parseInt(this.dataset.line);
        const input = document.querySelector(`.qty-input[data-line="${line}"]`);
        const currentValue = parseInt(input.value);
        const newValue = currentValue + 1;
        
        updateQuantity(line, newValue, this);
      });
    });

    document.querySelectorAll('[data-action="remove"]').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const line = parseInt(this.dataset.line);
        updateQuantity(line, 0, this);
      });
    });
  });
</script>
